# Production Environment Variables
# Copy this to .env.production and fill in your actual values

# API Configuration
API_PORT=4000
API_BASE_URL=https://api.infamousfreight.com
NODE_ENV=production
APP_PORT=4000

# Database
# Fly.io production database (replace USERNAME/PASSWORD/DB):
# Example: postgresql://USERNAME:PASSWORD@infamous-freight-db.flycast:5432/infamous_freight_prod
DATABASE_URL=postgresql://USERNAME:PASSWORD@infamous-freight-db.flycast:5432/infamous_freight_prod
DIRECT_URL=postgresql://USERNAME:PASSWORD@infamous-freight-db.flycast:5432/infamous_freight_prod

# Redis Cache (Priority 3)
REDIS_URL=redis://default:password@redis-host:6379
REDIS_TTL=300

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=infamous-freight
JWT_AUDIENCE=infamous-freight-api
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Cookie Security
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=if_refresh_token
AUTH_COOKIE_DOMAIN=.infamousfreight.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_PATH=/
COOKIE_SECRET=replace-with-min-32-char-secret-value
PASSWORD_PEPPER=

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=production

# CORS
CORS_ORIGIN=https://www.infamousfreight.com,https://infamousfreight.com
CORS_ORIGINS=https://www.infamousfreight.com,https://infamousfreight.com

# Security / Auth Tuning
RATE_LIMIT_AUTH_MAX=10
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# App Persistence / Webhooks
PERSISTENCE_MODE=auto
WEBHOOK_SECRET=replace-with-webhook-signing-secret

# Storage (S3/R2)
S3_BUCKET=infamous-freight
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
AVATAR_STORAGE=local
AVATAR_UPLOAD_DIR=apps/api/public/uploads
AVATAR_MAX_FILE_SIZE_MB=5
AVATAR_MAX_DIMENSIONS=2048x2048
AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp
AVATAR_DATA_STORE=apps/api/data/avatars.json

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_SUCCESS_URL=https://www.infamousfreight.com/billing/success
STRIPE_CANCEL_URL=https://www.infamousfreight.com/billing/cancel

# Voice Upload
VOICE_MAX_FILE_SIZE_MB=10

# WebSocket (Priority 3)
WEBSOCKET_PORT=8080
WEBSOCKET_PATH=/ws

# Mobile Push Notifications (Priority 2)
EXPO_PROJECT_ID=your-expo-project-id
EXPO_ACCESS_TOKEN=your-expo-access-token

# Monitoring
LOG_LEVEL=info

# Deploy (CI/CD)
FLY_API_TOKEN=
