# Infamous Freight production environment example
# Copy values into the correct platform secret manager. Do not commit real secrets.

# Canonical public website
SITE_URL=https://www.infamousfreight.com
PUBLIC_SITE_URL=https://www.infamousfreight.com
FRONTEND_URL=https://www.infamousfreight.com
CORS_ORIGINS=https://www.infamousfreight.com
# Legacy alias:
CORS_ORIGIN=https://www.infamousfreight.com

# API
NODE_ENV=production
PORT=3000
API_PUBLIC_URL=https://infamous-freight.fly.dev
RATE_LIMIT_ENABLED=true
# Legacy compatibility:
API_RATE_LIMIT_ENABLED=true
VITE_API_URL=/api
VITE_SOCKET_URL=wss://www.infamousfreight.com/socket.io

# Database
DATABASE_URL=<production-postgres-connection-string>

# Redis, if enabled
REDIS_URL=<production-redis-connection-string>

# Stripe
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>
STRIPE_PUBLISHABLE_KEY=<stripe-publishable-key>
VITE_STRIPE_PUBLIC_KEY=<stripe-publishable-key>

# Supabase
SUPABASE_URL=<supabase-project-url>
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_KEY=<supabase-service-key>
# Legacy alias for older tooling:
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-key>
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
VITE_SUPABASE_URL=<supabase-project-url>
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_PUBLIC_SUPABASE_URL=<supabase-project-url>

# Sentry, optional
SENTRY_DSN=<api-sentry-dsn>
SENTRY_AUTH_TOKEN=<sentry-auth-token>
SENTRY_ORG=<sentry-org>
SENTRY_PROJECT=<sentry-project>
VITE_SENTRY_DSN=<frontend-sentry-dsn>
NEXT_PUBLIC_SENTRY_DSN=<frontend-sentry-dsn>

# GitHub Actions
FLY_API_TOKEN=<rotated-fly-deploy-token>

# External integrations, only if enabled
DAT_API_KEY=<dat-api-key>
TRUCKSTOP_API_KEY=<truckstop-api-key>
LOADBOARD_API_KEY=<123loadboard-api-key>
SAMSARA_API_TOKEN=<samsara-token>
MOTIVE_CLIENT_ID=<motive-client-id>
MOTIVE_CLIENT_SECRET=<motive-client-secret>
QBO_CLIENT_ID=<quickbooks-client-id>
QBO_CLIENT_SECRET=<quickbooks-client-secret>
XERO_CLIENT_ID=<xero-client-id>
XERO_CLIENT_SECRET=<xero-client-secret>
SENDGRID_API_KEY=<sendgrid-api-key>
FROM_EMAIL=noreply@infamousfreight.com
