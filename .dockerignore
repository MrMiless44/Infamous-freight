# Dependencies (never ship local installs)
node_modules/
**/node_modules/
.pnpm-store/

# Turborepo / task caches
.turbo/
.cache/

# Test outputs
coverage/
**/coverage/

# Build outputs (keep source, drop artifacts)
dist/
**/dist/
build/
**/build/

# Next.js build artifacts (don’t send to builder)
apps/web/.next/
apps/web/out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS cruft
.DS_Store

# Local env files (keep examples)
.env
.env.*
!.env.example
!.env.production.example
!apps/web/.env.example
!apps/*/.env.example
!packages/*/.env.example

# Do NOT ignore markdown globally — monorepo builds and Dockerfile COPY statements rely on repository files.
# (If you want to reduce context size, prefer a tighter fly build.context or a per-app Dockerfile.)

# Keep Git metadata out of image contexts
.git/