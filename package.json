{
  "name": "infamous-freight",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "pnpm": "9.x"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @infamous/api dev",
    "dev:api": "pnpm --filter @infamous/api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build:shared": "pnpm --filter @infamous-freight/shared build",
    "prisma:generate": "pnpm -r --if-present prisma:generate",
    "build": "pnpm run prisma:generate && pnpm run build:shared && pnpm -r build",
    "build:nocheck": "pnpm run prisma:generate && pnpm run build:shared && pnpm -r --if-present run build:nocheck",
    "deploy:nocheck": "pnpm run build:nocheck && pnpm run audit:prod && pnpm run smoke:release",
    "typecheck": "pnpm run prisma:generate && pnpm run build:shared && pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm run prisma:generate && pnpm run build:shared && pnpm -r --if-present --workspace-concurrency=1 test",
    "test:ci": "pnpm run prisma:generate && pnpm run build:shared && pnpm -r --if-present --workspace-concurrency=1 test",
    "audit": "pnpm audit",
    "audit:prod": "pnpm audit --prod",
    "audit:ci": "pnpm run audit && pnpm run audit:prod",
    "format:check": "prettier --check . --ignore-unknown",
    "format": "prettier --write . --ignore-unknown",
    "fly:preflight": "bash scripts/fly-preflight.sh",
    "fly:deploy:api": "bash scripts/fly-deploy-api.sh",
    "validate": "pnpm run prisma:generate && pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "smoke:release": "bash scripts/release-smoke-check.sh",
    "deploy:check": "pnpm validate && pnpm audit:prod && pnpm smoke:release",
    "deploy:work": "bash scripts/deploy-work-branch.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "hono@<4.11.10": ">=4.11.10",
      "hono@<4.12.4": ">=4.12.4",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "hono@<4.12.7": ">=4.12.7",
      "fast-xml-parser@>=4.0.0-beta.3 <4.5.5": ">=4.5.5",
      "fast-xml-parser@>=5.0.0 <5.5.6": ">=5.5.6",
      "effect@<3.20.0": ">=3.20.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7",
      "brace-expansion@<1.1.13": "1.1.13",
      "node-forge@<=1.3.3": ">=1.4.0",
      "node-forge@<1.4.0": ">=1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "picomatch@4.0.3": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "brace-expansion@5.0.4": "5.0.5"
    }
  }
}
