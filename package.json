{
  "name": "infamous-freight",
  "private": true,
  "engines": {
    "node": "22.x",
    "pnpm": "9.x"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @infamous/api dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @infamous-freight/shared build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test"
  }
}
