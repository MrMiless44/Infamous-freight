{
  "name": "infaemous-freight-enterprises",
  "private": true,
  "version": "1.0.0",
  "description": "Infæmous Freight Enterprises ♊️ — AI-Powered Freight & Logistics Automation Platform",
  "author": "Santorio Djuan Miles",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "install:ci": "pnpm install --frozen-lockfile",
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:restart": "supabase stop && supabase start",
    "supabase:reset": "supabase db reset",
    "supabase:migrate": "supabase migration up",
    "supabase:migrate:new": "supabase migration new",
    "supabase:studio": "supabase studio",
    "supabase:types": "supabase gen types typescript --local > apps/web/types/supabase.ts",
    "supabase:functions:serve": "supabase functions serve",
    "supabase:functions:deploy": "supabase functions deploy",
    "supabase:status": "supabase status",
    "supabase:logs": "supabase logs",
    "lint": "pnpm -r run lint",
    "lint:web": "pnpm --filter web lint",
    "lint:fix": "pnpm -r run lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:web": "pnpm --filter web typecheck",
    "build": "pnpm -r run build",
    "build:fast": "SKIP_TYPE_CHECK=1 pnpm -r run build",
    "build:shared": "pnpm --filter @infamous-freight/shared build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:mobile": "pnpm --filter mobile build",
    "build:ai": "pnpm --filter ai build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm --filter api test:coverage",
    "deploy:vercel": "cd apps/web && npx vercel deploy --prod --yes --scope infaemous",
    "deploy:fly": "flyctl deploy --config apps/api/fly.toml --remote-only",
    "deploy:all": "pnpm run deploy:vercel && pnpm run deploy:fly",
    "status": "pnpm run status:vercel && pnpm run status:fly",
    "status:vercel": "curl -sf https://infamous.vercel.app/api/health | jq .",
    "status:fly": "flyctl status --app infamous-freight-as-3gw",
    "logs:vercel": "cd apps/web && npx vercel logs --scope infaemous",
    "logs:fly": "flyctl logs --app infamous-freight-as-3gw",
    "ci:install": "corepack enable && pnpm install --frozen-lockfile",
    "ci:build": "pnpm -r build",
    "go-live:verify": "bash scripts/genesis-go-live-verify.sh",
    "prepare": "husky",
    "deploy:production": "bash deploy/production-vercel-railway.sh"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.24.0",
      "lodash": "^4.17.21",
      "hono": "^4.6.10",
      "fast-xml-parser": "^4.4.1",
      "esbuild@<=0.24.2": ">=0.25.0",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2"
    }
  },
  "devDependencies": {
    "firebase-tools": "^14.24.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
