{
  "name": "infamous-freight",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:ai": "pnpm --filter ai dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "secret:scan": "pnpm -r secret:scan",
    "prisma:generate": "pnpm --filter api prisma:generate",
    "prisma:migrate:deploy": "pnpm --filter api prisma:migrate:deploy",
    "repo:audit": "bash scripts/repo-audit.sh",
    "repo:bootstrap-readmes": "bash scripts/bootstrap-readmes.sh"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
