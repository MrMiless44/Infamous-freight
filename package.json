{
  "name": "infamous-freight",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "start:api": "pnpm --filter ./apps/api run start",
    "prisma:generate": "pnpm --filter ./apps/api exec prisma generate",
    "prisma:format": "pnpm --filter ./apps/api exec prisma format",
    "prisma:validate": "pnpm --filter ./apps/api exec prisma validate",
    "prisma:migrate:status": "pnpm --filter ./apps/api exec prisma migrate status",
    "dev": "turbo dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "volta": {
    "node": "20.11.0",
    "pnpm": "9.0.0"
  }
}
