{
  "name": "infamous-freight-enterprises",
  "version": "2.1.0",
  "description": "Infæmous Freight - AI-powered freight management platform",
  "author": "Santorio Djuan Miles",
  "license": "Proprietary",
  "copyright": "© 2025 Infæmous Freight. All Rights Reserved.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "cd web && bun run --bun next dev",
    "dev:api": "cd api && npm run dev",
    "build": "bun run --bun next build",
    "build:shared": "cd packages/shared && npm run build",
    "build:api": "cd api && npm run build",
    "start": "cd api && npm start",
    "start:api": "cd api && npm start",
    "test": "cd api && npm test",
    "test:api": "cd api && npm test",
    "test:e2e": "cd tests/e2e && npm test",
    "test:coverage": "cd api && npm run test:coverage",
    "lint": "cd api && npm run lint",
    "lint:fix": "cd api && npm run lint:fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "check:types": "npm run typecheck",
    "typecheck": "cd packages/shared && npm run typecheck && cd ../../api && npm run typecheck",
    "validate": "npm run format:check && npm run lint && npm run check:types && npm run test",
    "clean": "rm -rf api/node_modules packages/*/node_modules node_modules",
    "install:all": "npm install && cd api && npm install && cd ../packages/shared && npm install",
    "prisma:generate": "cd api && npm run prisma:generate",
    "prisma:migrate": "cd api && npm run prisma:migrate",
    "prisma:migrate:dev": "cd api && npm run prisma:migrate:dev",
    "prisma:studio": "cd api && npm run prisma:studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up -d --build",
    "env:setup": "./scripts/setup-environments.sh",
    "env:validate": "./scripts/env-validate.sh",
    "env:check": "./scripts/env-validate.sh",
    "release:version": "node ./scripts/release-version.js",
    "security:audit": "pnpm audit --audit-level=high",
    "security:check": "pnpm audit && npm run lint",
    "prepare": "husky install || true"
  },
  "workspaces": [
    "api",
    "packages/*",
    "tests/e2e"
  ],
  "devDependencies": {
    "@21yunbox/netlify-plugin-21yunbox-deploy-to-china-cdn": "^1.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.58.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.2.7",
    "next": "^16.1.4",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.19",
    "ai": "^6.0.49",
    "dotenv": "^16.6.1",
    "eslint-config-prettier": "^10.1.8",
    "pg": "~8.17.2"
  }
}
