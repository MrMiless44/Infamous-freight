{
  "name": "infamous-freight",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "install:ci": "pnpm install --frozen-lockfile",
    "lint": "pnpm -r run lint",
    "lint:web": "pnpm --filter web lint",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:web": "pnpm --filter web typecheck",
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @infamous-freight/shared build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:mobile": "pnpm --filter mobile build",
    "build:ai": "pnpm --filter ai build"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "lodash": ">=4.17.23",
      "hono": ">=4.11.7",
      "fast-xml-parser": ">=5.3.4"
    }
  }
}
