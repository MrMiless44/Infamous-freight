{
  "name": "infamous-freight",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "prisma:generate": "pnpm --filter ./apps/api exec prisma generate",
    "prisma:validate": "pnpm --filter ./apps/api exec prisma validate",
    "prisma:migrate:deploy": "pnpm --filter ./apps/api exec prisma migrate deploy",
    "secret:scan": "bash ./scripts/check-secrets.sh",
    "repo:audit": "bash scripts/repo-audit.sh",
    "repo:bootstrap-readmes": "bash scripts/bootstrap-readmes.sh"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
