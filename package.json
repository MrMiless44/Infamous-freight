{
  "name": "infamous-freight",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "pnpm": "9.x"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @infamous/api dev",
    "dev:api": "pnpm --filter @infamous/api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build:shared": "pnpm --filter @infamous-freight/shared build",
    "build": "pnpm run build:shared && pnpm -r build",
    "typecheck": "pnpm run build:shared && pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm run build:shared && pnpm -r --if-present test",
    "test:ci": "pnpm run build:shared && pnpm -r --if-present test -- --runInBand",
    "format:check": "prettier --check . --ignore-unknown",
    "format": "prettier --write . --ignore-unknown",
    "validate": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "smoke:release": "bash scripts/release-smoke-check.sh",
    "deploy:check": "pnpm validate && pnpm smoke:release"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "eslint-config-prettier": "^10.0.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@eslint/js": "^10.0.0"
  }
}
