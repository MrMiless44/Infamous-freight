{
  "name": "infamous-freight",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:ai": "pnpm --filter ai dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "format": "prettier --write .",
    "prisma:generate": "pnpm --filter ./apps/api exec prisma generate",
    "prisma:validate": "pnpm --filter ./apps/api exec prisma validate",
    "prisma:migrate:deploy": "pnpm --filter ./apps/api exec prisma migrate deploy",
    "secret:scan": "bash ./scripts/check-secrets.sh"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
