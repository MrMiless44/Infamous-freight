# Supabase Local Development
# Project-specific environment variables for local Supabase instance

# API URL (local development)
API_URL=http://localhost:54321
API_EXTERNAL_URL=http://localhost:54321

# Database
DB_HOST=localhost
DB_PORT=54322
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Auth
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Studio
STUDIO_PORT=54323

# Inbucket (email testing)
INBUCKET_PORT=54324

# Storage
STORAGE_BACKEND=file

# Supabase project reference
# Get from: https://supabase.com/dashboard/project/_/settings/general
SUPABASE_PROJECT_ID=infamous-freight

# Supabase Auth Keys
# For local dev, these are auto-generated
