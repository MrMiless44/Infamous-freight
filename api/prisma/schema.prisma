// Prisma schema for Infamous Freight Enterprises

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SHIPPER
  DRIVER
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum PlanStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum VehicleType {
  CAR
  SUV
  VAN
  BOX_TRUCK
  STRAIGHT_TRUCK
  SEMI
}

enum JobStatus {
  DRAFT
  REQUIRES_PAYMENT
  OPEN
  ACCEPTED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
  REFUNDED
}

enum JobEventType {
  CREATED
  PAYMENT_INITIATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  OPENED
  HELD
  ACCEPTED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELED
  NOTE
}

enum PodAssetKind {
  PHOTO
  SIGNATURE
}

enum JobOfferStatus {
  OFFERED
  ACCEPTED
  DECLINED
  EXPIRED
}

// ============================================
// Multi-tenancy (Phase 19)
// ============================================

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  // Per-tenant encryption key (encrypted by master key)
  dataKeyEnc String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users            User[]
  jobs             Job[]
  auditLogs        OrgAuditLog[]
  billing          OrgBilling?
  usage            OrgUsage[]
  contracts        EnterpriseContract[]
  churnPredictions ChurnPrediction[]

  @@index([slug])
  @@index([isActive])
  @@map("organizations")
}

// ============================================
// Billing (Phase 20)
// ============================================

enum BillingPlan {
  STARTER
  GROWTH
  ENTERPRISE
  CUSTOM
}

model OrgBilling {
  id             String      @id @default(cuid())
  organizationId String      @unique
  plan           BillingPlan @default(STARTER)

  // Stripe integration
  stripeCustomerId String? @unique
  stripeSubId      String? @unique
  stripeStatus     String? @default("incomplete") // active, past_due, canceled

  // Pricing
  monthlyBase  Float @default(99) // Base monthly fee
  monthlyQuota Int   @default(100) // Included jobs per month
  overagePrice Float @default(1.50) // Per-job overage

  // Billing cycle
  billingCycleStart DateTime?
  nextBillingDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
  @@index([stripeStatus])
  @@map("org_billing")
}

model OrgUsage {
  id             String @id @default(cuid())
  organizationId String
  month          String // YYYY-MM format

  jobs          Int   @default(0) // Job completions this month
  revenue       Float @default(0) // Total revenue generated
  overageJobs   Int   @default(0) // Jobs over quota
  overageCharge Float @default(0) // Overage cost

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, month])
  @@index([organizationId])
  @@index([month])
  @@map("org_usage")
}

model AiUsageRecord {
  id                       String   @id @default(cuid())
  tenantId                 String?
  stripeSubscriptionItemId String
  quantity                 Int
  stripeUsageRecordId      String   @unique
  createdAt                DateTime @default(now())

  @@index([tenantId])
  @@index([stripeSubscriptionItemId])
  @@map("ai_usage_records")
}

model OrgInvoice {
  id             String @id @default(cuid())
  organizationId String
  month          String // YYYY-MM format

  // Invoice details
  stripeInvoiceId String? @unique
  stripeStatus    String? @default("draft")

  baseFee       Float @default(0)
  overageCharge Float @default(0)
  totalAmount   Float @default(0)

  pdfUrl String? // S3 or Stripe invoice PDF

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@unique([organizationId, month])
  @@index([organizationId])
  @@index([month])
  @@map("org_invoices")
}

model OrgAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([organizationId, entity])
  @@index([createdAt])
  @@map("org_audit_logs")
}

// ============================================

model User {
  id    String   @id @default(uuid())
  email String   @unique
  name  String?
  role  UserRole @default(SHIPPER)

  // Phase 19: Organization (multi-tenancy)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Phase 6: notification channels
  phone         String?
  expoPushToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Subscription / billing
  planTier             PlanTier   @default(FREE)
  planStatus           PlanStatus @default(NONE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planRenewsAt         DateTime?

  // Relations
  driverProfile     DriverProfile?
  jobsAsShipper     Job[]               @relation("jobsAsShipper")
  jobsAsDriver      Job[]               @relation("jobsAsDriver")
  shipments         Shipment[]
  payments          OldPayment[]        @relation("userPayments")
  jobPayments       JobPayment[]        @relation("userJobPayments")
  subscriptions     Subscription[]
  entitlements      Entitlement[]
  aiEvents          AiEvent[]
  jobOffers         JobOffer[]
  driverPerformance DriverPerformance[]

  @@index([email])
  @@index([role])
  @@index([organizationId])
  @@index([createdAt])
  @@index([phone])
  @@index([expoPushToken])
  @@map("users")
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments Shipment[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("drivers")
}

model Shipment {
  id          String   @id @default(uuid())
  trackingId  String   @unique
  userId      String
  driverId    String?
  origin      String
  destination String
  status      String   @default("pending")
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([trackingId])
  @@index([userId])
  @@index([status])
  @@index([driverId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([userId, status])
  @@map("shipments")
}

model AiEvent {
  id        String   @id @default(uuid())
  userId    String
  command   String
  response  String?
  provider  String   @default("openai")
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
  @@map("ai_events")
}

model OldPayment {
  id                    String   @id @default(uuid())
  userId                String
  stripePaymentIntentId String?  @unique
  amount                Float // in cents or currency
  currency              String   @default("usd")
  status                String   @default("pending")
  description           String?
  metadata              String? // JSON
  encryptedCardLast4    String? // Encrypted last 4 digits
  encryptedMetadata     String? // Encrypted sensitive metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user User @relation("userPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([createdAt])
  @@index([userId, status])
  @@map("payments")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  stripePriceId        String?
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@index([createdAt])
  @@map("subscriptions")
}

model StripeCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  email            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@map("stripe_customers")
}

model Entitlement {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  key       String // e.g. "plan", "features"
  value     String // e.g. "starter|pro|enterprise"
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("entitlements")
}

// ============================================
// Marketplace Models (DoorDash-style)
// ============================================

model DriverProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  lastLat        Float?
  lastLng        Float?
  lastLocationAt DateTime?

  vehicles Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("driver_profiles")
}

model Vehicle {
  id       String        @id @default(cuid())
  driverId String
  driver   DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  type          VehicleType
  nickname      String?
  maxWeightLbs  Int
  maxVolumeCuFt Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@map("vehicles")
}

model Job {
  id String @id @default(cuid())

  // Phase 19: Organization (multi-tenancy)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  shipperId String
  shipper   User   @relation("jobsAsShipper", fields: [shipperId], references: [id], onDelete: Restrict)

  driverId String?
  driver   User?   @relation("jobsAsDriver", fields: [driverId], references: [id], onDelete: SetNull)

  heldByDriverId String?
  heldUntil      DateTime?

  offerWave          Int       @default(0)
  offerWaveNextAt    DateTime?
  offerWaveStartedAt DateTime?

  otpRequired     Boolean   @default(true)
  deliveryOtpHash String?
  deliveredAt     DateTime?
  pickedUpAt      DateTime?

  podSignatureName String?
  podSignatureData String?
  podNotes         String?

  podRequirePhoto     Boolean @default(false)
  podRequireSignature Boolean @default(false)
  podRequireOtp       Boolean @default(false)
  podPolicyVersion    Int     @default(1)

  status JobStatus @default(DRAFT)

  pickupAddress String
  pickupLat     Float
  pickupLng     Float

  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  requiredVehicle VehicleType
  weightLbs       Int
  volumeCuFt      Int
  notes           String?

  estimatedMiles   Float
  estimatedMinutes Int
  priceUsd         Decimal @db.Decimal(10, 2)

  payment           JobPayment?
  events            JobEvent[]
  podAssets         PodAsset[]
  jobOffers         JobOffer[]
  dispatchDecisions DispatchDecision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([shipperId])
  @@index([driverId])
  @@index([heldByDriverId])
  @@index([heldUntil])
  @@index([offerWave, offerWaveNextAt])
  @@index([otpRequired])
  @@index([deliveredAt])
  @@index([pickedUpAt])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

model PodAsset {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  kind      PodAssetKind
  key       String
  url       String
  mimeType  String
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@unique([jobId, kind, key])
  @@index([jobId, kind, createdAt])
  @@map("pod_assets")
}

model JobOffer {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  driverId String
  driver   User   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  status     JobOfferStatus @default(OFFERED)
  expiresAt  DateTime
  acceptedAt DateTime?

  rank          Int?
  wave          Int?
  distanceMiles Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, driverId])
  @@index([jobId, status, expiresAt])
  @@index([driverId, status, expiresAt])
  @@map("job_offers")
}

model JobPayment {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("userJobPayments", fields: [userId], references: [id], onDelete: Cascade)

  status    PaymentStatus @default(INITIATED)
  amountUsd Decimal       @db.Decimal(10, 2)

  stripeCheckoutId String?
  stripePaymentId  String?
  stripeChargeId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripeCheckoutId])
  @@index([stripeChargeId])
  @@map("job_payments")
}

model WebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  // Optional: aids debugging
  jobId       String?
  stripeObjId String?

  @@index([id])
  @@index([type])
  @@index([createdAt])
  @@index([jobId])
  @@map("webhook_events")
}

model JobEvent {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  type        JobEventType
  actorUserId String?
  message     String?
  actorRole   UserRole?
  metadata    String?

  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([type, createdAt])
  @@map("job_events")
}

// ============================================
// Sales & Marketing (Phase 21)
// ============================================

enum LeadType {
  SHIPPER
  DRIVER
  ENTERPRISE
  OTHER
}

enum LeadSource {
  LANDING_PAGE_SHIPPER
  LANDING_PAGE_DRIVER
  LANDING_PAGE_ENTERPRISE
  PAID_AD
  REFERRAL
  ORGANIC_SEARCH
  DIRECT
  OTHER
}

enum ReferralStatus {
  PENDING
  COMPLETED
  PAID
  FAILED
}

model Lead {
  id      String  @id @default(cuid())
  name    String
  email   String  @unique
  company String?
  phone   String?

  type   LeadType    @default(OTHER)
  source LeadSource?

  // Qualification
  estimatedMonthlyVolume Int? // For enterprise
  estimatedMonthlyBudget Decimal? @db.Decimal(12, 2) // For enterprise
  currentProvider        String? // Current logistics provider
  painPoints             String? // What problems they're trying to solve

  // Tracking
  status     String  @default("new") // new | qualified | contacted | demo_scheduled | negotiating | won | lost
  notes      String?
  assignedTo String? // Sales rep email

  // Conversion tracking
  demoScheduledAt DateTime?
  convertedOrgId  String? // If they signed up
  convertedAt     DateTime?

  metadata String? // JSON: utm params, browser info, etc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  opportunities SalesOpportunity[]
  demoBooking   DemoBooking?

  @@index([email])
  @@index([type])
  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([convertedAt])
  @@map("leads")
}

model DemoBooking {
  id     String @id @default(cuid())
  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Calendly / Google Calendar event ID
  calendarEventId  String?
  calendarProvider String? // calendly | google | other

  scheduledFor DateTime
  duration     Int      @default(30) // minutes

  // Confirmation
  confirmationSent Boolean   @default(false)
  confirmedAt      DateTime?

  // Actual meeting
  status       String  @default("scheduled") // scheduled | completed | no_show | canceled
  zoomLink     String?
  recordingUrl String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([scheduledFor])
  @@index([status])
  @@map("demo_bookings")
}

model Referral {
  id String @id @default(cuid())

  referrerId   String // Email or user ID of the person who referred
  refereeEmail String // Email of person being referred

  // Reward
  rewardAmount Decimal @default(100) @db.Decimal(10, 2)
  rewardType   String  @default("credit") // credit | cash | percentage

  // Tracking
  status ReferralStatus @default(PENDING)

  // When referee signs up
  refereeOrgId    String?
  refereeSignupAt DateTime?

  // When condition met (e.g., 10 jobs completed)
  conditionMet DateTime?
  paidAt       DateTime?

  metadata String? // JSON: tracking info

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
  @@index([refereeEmail])
  @@index([status])
  @@index([createdAt])
  @@map("referrals")
}

model CrmSync {
  id String @id @default(cuid())

  entityType String // lead | org | subscription | job
  entityId   String

  provider String // hubspot | salesforce | notion | slack
  syncedId String // ID in external system

  // Sync metadata
  status    String  @default("synced") // synced | failed | pending
  lastError String?

  syncedAt   DateTime
  nextSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([provider])
  @@index([status])
  @@map("crm_syncs")
}

model MetricsSnapshot {
  id String @id @default(cuid())

  // Revenue
  mrr          Decimal @db.Decimal(12, 2)
  gmv          Decimal @db.Decimal(12, 2)
  platformTake Decimal @db.Decimal(12, 2)

  // Users
  activeDrivers  Int
  activeShippers Int
  totalOrgs      Int

  // Activity
  jobsLast30 Int
  jobsLast7  Int
  jobsToday  Int

  // Growth
  newOrgsLast30 Int
  churnedLast30 Int

  // Quality
  avgJobsPerDriver Decimal @db.Decimal(10, 2)
  avgRevenuePerOrg Decimal @db.Decimal(12, 2)

  // Engagement
  activeOrgsPercent Decimal @db.Decimal(5, 2) // 0-100
  driverRetention   Decimal @db.Decimal(5, 2)

  snapshotDate DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([snapshotDate])
  @@map("metrics_snapshots")
}

// ============================================
// PHASE 22: AI-DRIVEN REVENUE OPERATIONS
// ============================================

enum DealStage {
  NEW
  QUALIFYING
  QUALIFIED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  PROPOSAL_SENT
  NEGOTIATING
  CONTRACT_SENT
  WON
  LOST
  NURTURE
}

enum OutboundStatus {
  DRAFT
  SCHEDULED
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  EXECUTED
  EXPIRED
}

enum PricingStrategy {
  STANDARD
  SURGE
  DISCOUNT
  ENTERPRISE_CUSTOM
  PROMOTIONAL
}

model SalesOpportunity {
  id String @id @default(cuid())

  // Linked to lead
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  // AI-generated scoring
  dealScore  Int @default(0) // 0-100
  confidence Int @default(50) // AI confidence level

  // Deal details
  stage       DealStage @default(NEW)
  value       Decimal?  @db.Decimal(12, 2)
  probability Int       @default(10) // % chance of closing

  // Recommendations
  recommendedPlan String? // STARTER | GROWTH | ENTERPRISE
  expectedMrr     Decimal? @db.Decimal(10, 2)

  // AI insights
  aiSummary  String? // AI-generated deal summary
  nextAction String? // email | call | demo | proposal | nurture
  urgency    String  @default("medium") // low | medium | high | urgent

  // Tracking
  ownerId           String? // Sales rep if assigned
  lastContactAt     DateTime?
  expectedCloseDate DateTime?

  // Outcome
  wonAt      DateTime?
  lostAt     DateTime?
  lostReason String?

  metadata String? // JSON: additional AI insights

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([dealScore])
  @@index([stage])
  @@index([urgency])
  @@index([createdAt])
  @@map("sales_opportunities")
}

model OutboundCampaign {
  id String @id @default(cuid())

  name String
  type String @default("email") // email | sms | linkedin

  // Targeting
  targetIndustry    String?
  targetRegion      String?
  targetCompanySize String? // small | medium | enterprise

  // Content (AI-generated)
  subject      String?
  body         String  @db.Text
  callToAction String?

  // Status
  status OutboundStatus @default(DRAFT)

  // Performance
  totalSent    Int @default(0)
  totalOpened  Int @default(0)
  totalClicked Int @default(0)
  totalReplied Int @default(0)
  totalBounced Int @default(0)

  // Timing
  scheduledFor DateTime?
  sentAt       DateTime?

  createdBy String? // User ID or "genesis-ai"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages OutboundMessage[]

  @@index([status])
  @@index([scheduledFor])
  @@map("outbound_campaigns")
}

model OutboundMessage {
  id String @id @default(cuid())

  campaignId String
  campaign   OutboundCampaign @relation(fields: [campaignId], references: [id])

  // Recipient
  recipientEmail   String
  recipientName    String?
  recipientCompany String?

  // Content (personalized)
  subject String?
  body    String  @db.Text

  // Status
  status OutboundStatus @default(SCHEDULED)

  // Tracking
  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  repliedAt DateTime?

  // If converted to lead
  leadId String?

  metadata String? // JSON: tracking pixels, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([recipientEmail])
  @@index([status])
  @@index([sentAt])
  @@map("outbound_messages")
}

model EnterpriseContract {
  id String @id @default(cuid())

  // Linked to org and opportunity
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])

  opportunityId String?

  // Contract details
  contractType String         @default("standard") // standard | custom | pilot
  status       ContractStatus @default(DRAFT)

  // Terms
  annualValue  Decimal @db.Decimal(12, 2)
  contractTerm Int     @default(12) // months
  paymentTerms String?

  // Documents
  contractUrl String?
  dpaUrl      String?
  soc2Url     String?

  // Signature tracking
  signatureRequestId String? // DocuSign, etc.
  signedByName       String?
  signedByEmail      String?
  signedAt           DateTime?

  // Dates
  startDate DateTime?
  endDate   DateTime?
  autoRenew Boolean   @default(true)

  // Generated content
  aiGenerated Boolean @default(false)
  generatedBy String? // "genesis-ai" or user ID

  metadata String? // JSON: custom terms

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
  @@index([signedAt])
  @@map("enterprise_contracts")
}

model DynamicPricing {
  id String @id @default(cuid())

  // What is being priced
  jobId       String?
  vehicleType String?
  region      String?

  // Base pricing
  basePrice Decimal @db.Decimal(10, 2)

  // Multipliers
  demandMultiplier   Decimal @default(1.0) @db.Decimal(5, 2)
  urgencyMultiplier  Decimal @default(1.0) @db.Decimal(5, 2)
  distanceMultiplier Decimal @default(1.0) @db.Decimal(5, 2)
  timeMultiplier     Decimal @default(1.0) @db.Decimal(5, 2)

  // Final price
  finalPrice Decimal @db.Decimal(10, 2)

  // Context
  strategy    PricingStrategy @default(STANDARD)
  surgeReason String? // "low_supply" | "high_demand" | "peak_hours" | "weather"

  // Availability data
  availableDrivers Int?
  totalDrivers     Int?
  demandScore      Int? // 0-100

  // AI recommendation
  aiRecommended Boolean @default(false)
  aiConfidence  Int? // 0-100

  appliedAt DateTime  @default(now())
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([strategy])
  @@index([appliedAt])
  @@map("dynamic_pricing")
}

model RevenueOptimization {
  id String @id @default(cuid())

  // What is being optimized
  targetEntity String // "pricing" | "discounts" | "marketing" | "churn"

  // AI recommendation
  recommendation String  @db.Text
  impact         String? // "Estimated +15% MRR"
  confidence     Int // 0-100

  // Action
  actionType String // "increase_price" | "run_campaign" | "offer_discount"
  actionData String? @db.Text // JSON: specific action params

  // Status
  status String @default("pending") // pending | approved | implemented | rejected

  // Outcome tracking
  implementedAt DateTime?
  actualImpact  String?

  createdBy  String  @default("genesis-ai")
  approvedBy String? // User ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetEntity])
  @@index([status])
  @@index([createdAt])
  @@map("revenue_optimizations")
}

// ============================================
// PHASE 23: AUTONOMOUS OPERATIONS
// ============================================

enum FraudRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudType {
  PAYMENT_FRAUD
  IDENTITY_THEFT
  FAKE_DRIVER
  FAKE_SHIPPER
  COLLUSION
  ACCOUNT_TAKEOVER
  SUSPICIOUS_PATTERN
}

enum ChurnRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChurnReason {
  POOR_SERVICE
  HIGH_COST
  LOW_USAGE
  COMPETITOR
  SUPPORT_ISSUES
  TECHNICAL_ISSUES
  UNKNOWN
}

enum ComplianceType {
  TAX_FILING
  DOT_REPORT
  INSURANCE_RENEWAL
  DRIVER_LICENSE_CHECK
  VEHICLE_INSPECTION
  QUARTERLY_REPORT
  ANNUAL_REPORT
}

enum ComplianceStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  OVERDUE
}

model FraudAlert {
  id String @id @default(cuid())

  // What triggered the alert
  entityType String // "user" | "org" | "job" | "payment"
  entityId   String

  // Fraud classification
  fraudType FraudType
  riskLevel FraudRiskLevel
  riskScore Int // 0-100

  // Detection details
  detectedBy String @default("fraud-ai") // "fraud-ai" | "manual" | "rule-based"
  signals    String @db.Text // JSON: array of fraud signals

  // AI analysis
  aiExplanation String? @db.Text
  confidence    Int // 0-100

  // Status
  status String @default("active") // active | investigating | resolved | false_positive

  // Actions taken
  actionsTaken String?   @db.Text // JSON: array of actions
  blockedAt    DateTime?
  resolvedAt   DateTime?
  resolvedBy   String?
  resolution   String? // "blocked" | "warned" | "false_positive" | "legitimate"

  // Related entities
  userId String?
  orgId  String?
  jobId  String?

  metadata String? @db.Text // JSON: additional context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([fraudType])
  @@index([riskLevel])
  @@index([status])
  @@index([createdAt])
  @@map("fraud_alerts")
}

model ChurnPrediction {
  id String @id @default(cuid())

  // Target
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])

  // Prediction
  riskLevel   ChurnRiskLevel
  riskScore   Int // 0-100 (100 = will churn)
  probability Decimal        @db.Decimal(5, 2) // 0.00 - 100.00%

  // Analysis
  primaryReason ChurnReason?
  signals       String       @db.Text // JSON: array of churn signals
  aiExplanation String?      @db.Text

  // Intervention
  recommendedActions String?   @db.Text // JSON: array of retention actions
  interventionSent   Boolean   @default(false)
  interventionType   String? // "email" | "call" | "discount" | "upgrade"
  interventionDate   DateTime?

  // Outcome
  churned       Boolean   @default(false)
  churnedAt     DateTime?
  retained      Boolean   @default(false)
  retainedUntil DateTime?

  // Prediction metadata
  predictionDate DateTime @default(now())
  expiresAt      DateTime // Re-evaluate after this date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([riskLevel])
  @@index([riskScore])
  @@index([churned])
  @@index([predictionDate])
  @@map("churn_predictions")
}

model DispatchDecision {
  id String @id @default(cuid())

  // Job context
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // AI decision
  selectedDriverId   String?
  alternativeDrivers String? @db.Text // JSON: array of backup options

  // Optimization factors
  optimizationGoal  String   @default("cost") // cost | speed | quality | balance
  estimatedDuration Int? // minutes
  estimatedCost     Decimal? @db.Decimal(10, 2)
  routeOptimality   Decimal  @db.Decimal(5, 2) // 0-100%

  // AI reasoning
  aiReasoning String? @db.Text
  confidence  Int // 0-100

  // Alternative analysis
  alternativesConsidered Int     @default(0)
  rejectionReasons       String? @db.Text // JSON: why others rejected

  // Outcome
  accepted    Boolean   @default(false)
  acceptedAt  DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?

  // Performance tracking
  actualDuration Int?
  actualCost     Decimal? @db.Decimal(10, 2)
  accuracy       Decimal? @db.Decimal(5, 2) // How close to estimate

  decisionMadeAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([selectedDriverId])
  @@index([optimizationGoal])
  @@index([decisionMadeAt])
  @@map("dispatch_decisions")
}

model ComplianceTask {
  id String @id @default(cuid())

  // What needs to be done
  type   ComplianceType
  status ComplianceStatus @default(PENDING)

  // Target
  entityType String // "org" | "driver" | "vehicle" | "platform"
  entityId   String?

  // Timing
  dueDate     DateTime
  submittedAt DateTime?
  approvedAt  DateTime?

  // Document generation
  documentUrl  String?
  documentType String? // "pdf" | "csv" | "xml"

  // AI automation
  autoGenerated Boolean @default(false)
  generatedBy   String? // "compliance-ai" | "manual" | user ID

  // Filing details
  filingAuthority    String? // "IRS" | "DOT" | "DMV" | etc
  confirmationNumber String?

  // Status tracking
  reminder1Sent DateTime?
  reminder2Sent DateTime?
  escalated     Boolean   @default(false)
  escalatedAt   DateTime?

  // Metadata
  notes    String? @db.Text
  metadata String? @db.Text // JSON: additional details

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([entityType, entityId])
  @@map("compliance_tasks")
}

model DriverPerformance {
  id String @id @default(cuid())

  // Driver
  driverId String
  driver   User   @relation(fields: [driverId], references: [id])

  // Performance metrics (trailing 30 days)
  totalJobs     Int @default(0)
  completedJobs Int @default(0)
  cancelledJobs Int @default(0)

  // Quality metrics
  avgRating      Decimal @db.Decimal(3, 2) // 0.00 - 5.00
  onTimeRate     Decimal @db.Decimal(5, 2) // 0-100%
  completionRate Decimal @db.Decimal(5, 2) // 0-100%

  // Efficiency metrics
  avgJobDuration   Int? // minutes
  avgRevenuePerJob Decimal? @db.Decimal(10, 2)
  utilizationRate  Decimal  @db.Decimal(5, 2) // 0-100% (active hours / total hours)

  // Safety metrics
  accidentCount  Int     @default(0)
  violationCount Int     @default(0)
  safetyScore    Decimal @db.Decimal(5, 2) // 0-100

  // AI analysis
  performanceScore Int // 0-100 (composite score)
  performanceTier  String @default("average") // excellent | good | average | poor

  // Coaching
  coachingRecommendations String? @db.Text // JSON: array of recommendations
  improvementAreas        String? @db.Text // JSON: areas needing work
  strengths               String? @db.Text // JSON: what driver does well

  // Trending
  trendDirection String  @default("stable") // improving | stable | declining
  scoreChange    Decimal @db.Decimal(5, 2) // +/- change from last period

  // Risk flags
  atRisk      Boolean @default(false)
  riskFactors String? @db.Text // JSON: what's concerning

  // Period
  periodStart DateTime
  periodEnd   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverId, periodStart])
  @@index([driverId])
  @@index([performanceScore])
  @@index([performanceTier])
  @@index([periodStart])
  @@map("driver_performance")
}

enum CoverageType {
  AUTO
  CARGO
  CONTINGENT_CARGO
  GENERAL_LIABILITY
  ERRORS_OMISSIONS
  WORKERS_COMP
  CYBER
}

enum InsuranceCertStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ComplianceState {
  COMPLIANT
  WARNING
  NON_COMPLIANT
  SUSPENDED
}

model InsuranceCertificate {
  id              String              @id @default(cuid())
  orgId           String
  carrierId       String?
  providerName    String?
  policyNumber    String?
  coverageType    CoverageType
  effectiveDate   DateTime?
  expirationDate  DateTime?
  limitsJson      Json?
  documentUrl     String
  extractedJson   Json?
  status          InsuranceCertStatus @default(PENDING)
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orgId, carrierId])
  @@index([orgId, coverageType])
  @@index([orgId, status])
}

model CoverageRequirement {
  id                 String       @id @default(cuid())
  orgId              String
  coverageType       CoverageType
  minLimitsJson      Json?
  requiredForJson    Json?
  requiredStatesJson Json?
  graceDays          Int          @default(7)
  warningDays        Int          @default(14)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([orgId, coverageType])
}

model InsuranceComplianceStatus {
  id              String          @id @default(cuid())
  orgId           String
  carrierId       String
  state           ComplianceState @default(COMPLIANT)
  reasonsJson     Json?
  lastEvaluatedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([orgId, carrierId])
  @@index([orgId, state])
}

model InsuranceEventLog {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String?
  carrierId   String?
  eventType   String
  payloadJson Json?
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, carrierId])
}

model InsuranceQuoteRequest {
  id          String   @id @default(cuid())
  orgId       String
  userId      String?
  carrierId   String?
  loadId      String?
  requestType String
  partner     String?
  payloadJson Json?
  status      String   @default("INITIATED")
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, loadId])
}
