{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@ai/*": ["apps/ai/src/*"],
      "@api/*": ["apps/api/src/*"],
      "@mobile/*": ["apps/mobile/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@worker/*": ["apps/worker/src/*"],
      "@infamous-freight/shared": ["packages/shared/src"],
      "@infamous-freight/shared/*": ["packages/shared/src/*"]
    }
  }
}
