engine-strict=false
# Netlify installs UI-managed build plugins with npm before running the app build.
# Some third-party plugins publish stale engine ranges; keep installs non-blocking.

# Improve resilience for transient npm registry/network failures (e.g. HTTP 502).
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-timeout=120000
network-concurrency=16
