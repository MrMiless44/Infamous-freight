# ═══════════════════════════════════════════
# Infæmous Freight — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════

# Node environment
NODE_ENV=development

# API server port
PORT=4000

# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infamous_dev

# Redis connection URL
REDIS_URL=redis://localhost:6379

# JWT signing secret (min 32 chars)
JWT_SECRET=replace-me

# Comma-separated CORS origins (leave unset to allow all in dev)
# CORS_ORIGIN=https://app.infamousfreight.com

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
STORAGE_SECRET_KEY=
EMAIL_API_KEY=
SMS_API_KEY=
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
