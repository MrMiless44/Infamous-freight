# App
NODE_ENV=development
APP_ENV=development
APP_NAME=infamous-freight
LOG_LEVEL=info
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/infamous_freight

# Cache / Queue
REDIS_URL=

# Auth
# Must be at least 32 chars in production
JWT_SECRET=change_me_to_a_32_char_random_secret_in_prod
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Routing / CORS
# Comma-separated allowed origins. Required in production.
CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# Observability
SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=

# Web (public)
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Deploy
FLY_API_TOKEN=
RAILWAY_TOKEN=

# Integrations
WEBHOOK_SECRET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
EMAIL_API_KEY=
SMS_API_KEY=
STRIPE_SECRET_KEY=sk_test_placeholder
SENDGRID_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
