# ============================================================
# Infamous Freight — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Variables are grouped into:
#   [REQUIRED]            — must be set for the app to start
#   [OPTIONAL]            — feature-flags or sensible defaults exist
#   [DEPLOYMENT-SPECIFIC] — only needed in CI/CD or hosted environments
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

# Runtime environment (development | test | staging | production)
NODE_ENV=development

# TCP port the API server binds to
PORT=3000

# PostgreSQL connection string
# Local dev: postgresql://postgres:postgres@localhost:5432/infamous_freight
DATABASE_URL=

# Redis connection string (used for caching and job queues)
# Local dev: redis://localhost:6379
REDIS_URL=

# Secret used to sign JWT access tokens (min 32 chars, keep secret)
JWT_SECRET=

# ── OPTIONAL ────────────────────────────────────────────────

# RS256 key pair — provide both to enable asymmetric JWT signing.
# Leave blank to fall back to HS256 via JWT_SECRET above.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# Sentry DSN for error reporting (leave blank to disable)
SENTRY_DSN=

# Shared HMAC secret for verifying inbound webhook payloads
WEBHOOK_SECRET=

# Object-storage credentials (S3-compatible)
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Transactional email provider API key
EMAIL_API_KEY=

# SMS / notification provider API key
SMS_API_KEY=

# ── DEPLOYMENT-SPECIFIC ─────────────────────────────────────

# Fly.io API token (used by deploy-api.yml workflow)
FLY_API_TOKEN=
