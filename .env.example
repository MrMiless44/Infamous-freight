# Environment Configuration Template

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Application Ports
# ============================================
# API server port (default: 4000, Docker internal: 3001)
API_PORT=4000
# Web server port (default: 3000)
WEB_PORT=3000

# ============================================
# Application URLs
# ============================================
# Canonical web app URL (e.g., https://app.example.com)
APP_URL=http://localhost:3000
# Railway Production URLs
APP_URL_PROD=https://infamous-freight-web-production.up.railway.app

# Canonical API URL (e.g., https://api.example.com)
API_URL=http://localhost:4000
# Railway Production API URL
API_URL_PROD=https://infamous-freight-api-production.up.railway.app

# Frontend-side API base URL (used by Next.js client)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
# Railway Production
NEXT_PUBLIC_API_BASE_URL_PROD=https://infamous-freight-api-production.up.railway.app/api

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Development: postgresql://infamous:infamouspass@localhost:5432/infamous_freight
# Docker: postgresql://infamous:infamouspass@postgres:5432/infamous_freight
# Fly.io (fill in real user/password/db):
# Example (Fly): postgresql://USERNAME:PASSWORD@infamous-freight-db.flycast:5432/infamous_freight
# Example (Railway external): postgresql://postgres:PASSWORD@switchyard.proxy.rlwy.net:57333/railway?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@xxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true

# Test database (optional, for running tests)
TEST_DATABASE_URL=postgresql://infamous:infamouspass@localhost:5432/infamous_freight_test

# ============================================
# Supabase Configuration (Optional - Alternative to API DB)
# ============================================
# Supabase is a managed PostgreSQL backend with built-in auth
# Get these from: https://supabase.com/dashboard → Select Project → Settings → API
# Note: If using Supabase for auth, the web app connects directly to Supabase
# The API can integrate with Supabase for unified auth if desired

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Supabase anon key (public, for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (secret, for server-side use - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Docker Configuration
# ============================================
# PostgreSQL settings
POSTGRES_USER=infamous
POSTGRES_PASSWORD=infamouspass
POSTGRES_DB=infamous_freight
POSTGRES_PORT=5432

# Redis settings
REDIS_PASSWORD=redispass
REDIS_PORT=6379
REDIS_URL=redis://:redispass@redis:6379

# ============================================
# Authentication & Security
# ============================================
# JWT secret for token signing (MUST be changed in production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_long_random_value_minimum_32_characters

# ============================================
# Email & Alerts
# ============================================
# SendGrid API key for transactional emails
SENDGRID_API_KEY=
# Default from address
SENDGRID_FROM_EMAIL=noreply@infamousfreight.com
SENDGRID_FROM_NAME=Infamous Freight
# Comma-separated alert recipients
ALERT_EMAILS=alerts@infamousfreight.com,ops@infamousfreight.com

# AWS SES Configuration (Cost Optimization - Free Tier Alternative)
# Use AWS SES instead of SendGrid to save $20/month
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_FROM_EMAIL=noreply@infamousfreight.com
AWS_SES_FROM_NAME=Infamous Freight

# ============================================
# Railway Production Environment
# ============================================
# DATABASE_URL - Auto-set by Railway PostgreSQL plugin (SSL 16.11)
# REDIS_URL - Auto-set by Railway Redis plugin
# For Railway, set these in the Railway dashboard:
# NODE_ENV=production
# API_PORT=3001
# WEB_PORT=3000
# JWT_SECRET=[generate secure random value]

# ============================================
# Multi-Tenancy & Encryption (Phase 19)
# ============================================
# Master encryption key (AES-256) for encrypting data keys
# CRITICAL: Store this in a secure key management service (KMS, Vault)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your_32_byte_hex_master_key_here

# Enable token rotation for enhanced security
ENABLE_TOKEN_ROTATION=false

# Organization settings
# Allow self-serve org creation (true|false)
ALLOW_ORG_SIGNUP=true

# ============================================
# AI Configuration
# ============================================
# AI Synthetic Engine URL (internal endpoint)
AI_SYNTHETIC_ENGINE_URL=http://localhost:4000/internal/ai-sim
# AI API Key
AI_SYNTHETIC_API_KEY=Qrx1AsDrBT0miJJltcWFuRk0yy-28Vdv8epYhwT-
# AI Security Mode (strict|permissive)
AI_SECURITY_MODE=strict
# AI provider (openai|anthropic|synthetic)
AI_PROVIDER=synthetic
# AI model override (used by OpenAI provider)
AI_MODEL=gpt-4
# AI Cost Optimization - Route 95% to synthetic, 5% to real AI
AI_OPENAI_FALLBACK_RATE=0.05

# ============================================
# Public Web Configuration (Next.js)
# ============================================
# Public app name
NEXT_PUBLIC_APP_NAME=Infæmous Freight
# Public environment
NEXT_PUBLIC_ENV=development
# Public API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
# Preferred public API URL for browser/client calls
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# For production, override these with your deployed API endpoint, for example:
# NEXT_PUBLIC_API_BASE_URL=https://infamous-freight-api.fly.dev/api
# NEXT_PUBLIC_API_URL=https://infamous-freight-api.fly.dev/api

# ============================================
# Payment Processing (Stripe) - Phase 2 + Phase 20
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Non-production example publishable key (use pk_test_... for local/dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_example_publishable_key_here
STRIPE_PRICE_OPERATOR=price_operator_xxx
STRIPE_PRICE_FLEET=price_fleet_xxx
AI_METERED_PRICE_ID=price_ai_metered_xxx
INTELLIGENCE_ADDON_PRICE_ID=price_intel_xxx

# Public app URL (used for redirect after Checkout)
PUBLIC_APP_URL=http://localhost:3000
# API URL (used for webhook validation)
PUBLIC_API_URL=http://localhost:3001

# ============================================
# Stripe Billing (Phase 20 - Subscriptions)
# ============================================
# Stripe Price IDs for subscription plans (from Stripe Dashboard)
# Create 3 products: Starter, Growth, Enterprise
# Each with recurring monthly pricing
STRIPE_PRICE_STARTER=price_1OxXxXxXxXxXxXxXxXxXxXxX
STRIPE_PRICE_GROWTH=price_1OxXxXxXxXxXxXxXxXxXxXxX
STRIPE_PRICE_ENTERPRISE=price_1OxXxXxXxXxXxXxXxXxXxXxX

# Stripe Metered Billing (for overage tracking)
# Create metered billing items for overage fees
STRIPE_METERED_STARTER=price_1OxXxXxXxXxXxXxXxXxXxXxX
STRIPE_METERED_GROWTH=price_1OxXxXxXxXxXxXxXxXxXxXxX

# Billing Configuration
# Send invoices automatically (true|false)
SEND_INVOICES=false
# Invoice timezone (default: America/Los_Angeles)
INVOICE_TIMEZONE=America/Los_Angeles
# Invoice email (from address)
INVOICE_FROM_EMAIL=billing@infamousfreight.com

# ============================================
# Payment Processing (PayPal)
# ============================================
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# PayPal environment (sandbox|live)
PAYPAL_ENV=sandbox

# ============================================
# Bank Transfer Configuration (Cost Optimization - 0% Fees)
# ============================================
# Plaid API credentials for bank account verification
# Sign up at: https://plaid.com/
# Use Plaid to enable bank transfers with 0% fees (vs 2.9% + $0.30 for cards)
PLAID_CLIENT_ID=
PLAID_SECRET=
# Plaid environment (sandbox|development|production)
PLAID_ENV=sandbox

# ============================================
# Billing Configuration
# ============================================
BILLING_CURRENCY=usd
TRIAL_PERIOD_DAYS=14
USAGE_TRACKING_ENABLED=true

# ============================================
# Notifications (Optional)
# ============================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
# Enable Redis caching for cost optimization (saves ~$35/month with 40-60% hit rate)
REDIS_CACHE_ENABLED=true
# Cache TTL for different endpoints (seconds)
CACHE_TTL_SHIPMENTS=300
CACHE_TTL_ANALYTICS=600
CACHE_TTL_ROUTES=1800

# ============================================
# Logging & Performance Monitoring
# ============================================
# Log level (error|warn|info|debug|trace)
LOG_LEVEL=info
# Performance warning threshold (milliseconds)
PERF_WARN_THRESHOLD_MS=1000
# Performance error threshold (milliseconds)
PERF_ERROR_THRESHOLD_MS=5000
# Sentry Error Tracking & APM
SENTRY_DSN=https://your-sentry-dsn@sentry.io/PROJECT_ID
# Cost Optimization: Sample only 10% of traces (saves $22/month, fits free tier)
SENTRY_TRACES_SAMPLE_RATE=0.1
# Datadog APM (optional)
DD_TRACE_ENABLED=false
DD_SERVICE=infamous-freight-api
DD_ENV=development
DD_RUNTIME_METRICS_ENABLED=false
# Enable application performance monitoring features
PERFORMANCE_MONITORING_ENABLED=false

# ============================================
# Outbound HTTP (SSRF Guard)
# ============================================
OUTBOUND_HTTP_ALLOWLIST=api.open-meteo.com,open-meteo.com,hooks.slack.com
OUTBOUND_HTTP_BLOCK_PRIVATE=true
OUTBOUND_HTTP_TIMEOUT_MS=8000

# ============================================
# Analytics & Monitoring
# ============================================
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Plausible Analytics (Privacy-friendly)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# ============================================
# Netlify
# ============================================
# Personal access token for Netlify CLI/automation
NETLIFY_AUTH_TOKEN=nfp_4dA2aKnF8KTCPG9eWTXoxUUWrzwgKWfN3efb

# ============================================
# Email & Notifications (NEW - Recommendations)
# ============================================
# Sendgrid (Email service)
VITE_SENDGRID_API_KEY=your_sendgrid_key_here
VITE_SENDGRID_FROM_EMAIL=noreply@infamousfreight.com

# Slack Notifications
VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Maps & Geolocation (NEW - Recommendations)
# ============================================
# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox (Alternative)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ============================================
# GitHub OAuth (NEW - Recommendations)
# ============================================
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ============================================
# Rate Limiting Configuration (Tunable)
# ============================================
# General rate limiting (requests per window)
RATE_LIMIT_GENERAL_WINDOW_MS=15
RATE_LIMIT_GENERAL_MAX=100
# Authentication rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=15
RATE_LIMIT_AUTH_MAX=5
# AI service rate limiting
RATE_LIMIT_AI_WINDOW_MS=1
RATE_LIMIT_AI_MAX=20
# Billing rate limiting
RATE_LIMIT_BILLING_WINDOW_MS=15
RATE_LIMIT_BILLING_MAX=30
# Voice processing rate limiting
RATE_LIMIT_VOICE_WINDOW_MS=1
RATE_LIMIT_VOICE_MAX=10
# Export operations (reports, data dumps)
RATE_LIMIT_EXPORT_WINDOW_MS=60
RATE_LIMIT_EXPORT_MAX=5
# Password reset rate limiting (24-hour window)
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=1440
RATE_LIMIT_PASSWORD_RESET_MAX=3
# Webhook operations rate limiting
RATE_LIMIT_WEBHOOK_WINDOW_MS=1
RATE_LIMIT_WEBHOOK_MAX=100

# ============================================
# Voice Processing Configuration (Phase 17)
# ============================================
# Max file size for voice uploads (MB)
VOICE_MAX_FILE_SIZE_MB=10
# Supported audio formats (comma-separated)
VOICE_SUPPORTED_FORMATS=mp3,wav,ogg,m4a
# Voice processing timeout (seconds)
VOICE_PROCESSING_TIMEOUT_SEC=30

# ============================================
# Audit & Export Configuration (Phase 19)
# ============================================
# Enable audit logging
ENABLE_AUDIT_LOGGING=true
# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=365
# Audit exports base path
AUDIT_EXPORT_BASE_PATH=/var/exports

# ============================================
# Feature Flags (Control rollout)
# ============================================
# AI Commands feature (true|false)
ENABLE_AI_COMMANDS=true
# Voice Processing feature (true|false)
ENABLE_VOICE_PROCESSING=true
# New Billing system (true|false)
ENABLE_NEW_BILLING=true
# Cost Optimization Features
FEATURE_AWS_SES_ENABLED=true
FEATURE_BANK_TRANSFER_ENABLED=true
FEATURE_AI_SYNTHETIC_ENHANCED=true
FEATURE_REDIS_CACHE_ENABLED=true
FEATURE_BATCH_QUEUE_ENABLED=true
# Analytics tracking (true|false)
VITE_ENABLE_ANALYTICS=true
# Error tracking (true|false)
VITE_ENABLE_ERROR_TRACKING=true
# Performance monitoring (true|false)
VITE_ENABLE_PERFORMANCE_MONITORING=true
# A/B Testing (true|false)
VITE_ENABLE_A_B_TESTING=false

# ============================================
# Security Headers & CSP
# ============================================
# Content Security Policy report URI
CSP_REPORT_URI=/api/security/csp-violations
# CORS allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# SEO & Meta (NEW - Recommendations)
# ============================================
VITE_META_TITLE=Infamous Freight Enterprises | Global Logistics
VITE_META_DESCRIPTION=Enterprise freight management platform serving 120+ countries
VITE_OG_IMAGE=https://infamousfreight.com/og-image.png

# ============================================
# Batch Queue Configuration (Cost Optimization)
# ============================================
# Enable request batching to reduce API calls by 80% (saves ~$30/month)
BATCH_QUEUE_ENABLED=true
# Batch sizes for different services
BATCH_SIZE_MAPBOX=10
BATCH_SIZE_AI=5
BATCH_SIZE_WEATHER=20
# Flush intervals (milliseconds)
BATCH_FLUSH_INTERVAL_MAPBOX=1000
BATCH_FLUSH_INTERVAL_AI=500
BATCH_FLUSH_INTERVAL_WEATHER=2000

# ============================================
# Cost Monitoring & Alerts
# ============================================
# Monthly cost alert threshold (dollars)
COST_ALERT_THRESHOLD_MONTHLY=2700
# Cost alert email recipients
COST_ALERT_EMAILS=finance@infamousfreight.com,ops@infamousfreight.com

# ============================================
# SECURITY WARNING
# ============================================
# ⚠️ Never commit real secrets to version control
# Use a secrets manager (HashiCorp Vault, AWS Secrets Manager, 1Password, etc)

# ============================================
# PHASE 2: Uber Freight Integration
# ============================================
# Uber Freight OAuth2 credentials (obtain from Uber for Business Partner portal)
UBER_FREIGHT_CLIENT_ID=your_client_id_here
UBER_FREIGHT_CLIENT_SECRET=your_client_secret_here

# ============================================
# PHASE 2: Webhook Configuration
# ============================================
# Webhook signing secret (HMAC-256 key for verifying incoming webhooks)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here

# Webhook retry configuration
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_INITIAL_DELAY_MS=1000
WEBHOOK_RETRY_MAX_DELAY_MS=60000

# Webhook processing interval (how often to process queue)
WEBHOOK_PROCESSING_INTERVAL_MS=5000

# ============================================
# PHASE 2: Analytics Configuration
# ============================================
# How long to cache analytics dashboard (seconds)
ANALYTICS_CACHE_TTL_SECONDS=3600

# Daily analytics data retention (days)
ANALYTICS_DAILY_RETENTION_DAYS=365

# Max users that can be fetched in leaderboard query
ANALYTICS_USER_LIMIT_PER_QUERY=10000

# ============================================
# PHASE 2: Feature Flags
# ============================================
# Enable Uber Freight load board integration
ENABLE_UBER_FREIGHT=true

# Enable webhook event system
ENABLE_WEBHOOKS=true

# Enable analytics dashboards
ENABLE_ANALYTICS_DASHBOARDS=true

# ============================================
# END OF FILE
