# Environment Configuration Template

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Application Ports
# ============================================
# API server port (default: 4000, Docker internal: 3001)
API_PORT=4000
# Web server port (default: 3000)
WEB_PORT=3000

# ============================================
# Application URLs
# ============================================
# Canonical web app URL (e.g., https://app.example.com)
APP_URL=http://localhost:3000
# Canonical API URL (e.g., https://api.example.com)
API_URL=http://localhost:4000

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Development: postgresql://infamous:infamouspass@localhost:5432/infamous_freight
# Docker: postgresql://infamous:infamouspass@postgres:5432/infamous_freight
DATABASE_URL=postgresql://infamous:infamouspass@localhost:5432/infamous_freight

# Test database (optional, for running tests)
TEST_DATABASE_URL=postgresql://infamous:infamouspass@localhost:5432/infamous_freight_test

# ============================================
# Docker Configuration
# ============================================
# PostgreSQL settings
POSTGRES_USER=infamous
POSTGRES_PASSWORD=infamouspass
POSTGRES_DB=infamous_freight
POSTGRES_PORT=5432

# Redis settings
REDIS_PASSWORD=redispass
REDIS_PORT=6379
REDIS_URL=redis://:redispass@redis:6379

# ============================================
# Authentication & Security
# ============================================
# JWT secret for token signing (MUST be changed in production)
JWT_SECRET=replace_with_long_random_value_minimum_32_characters

# ============================================
# AI Configuration
# ============================================
# AI Synthetic Engine URL (internal endpoint)
AI_SYNTHETIC_ENGINE_URL=http://localhost:4000/internal/ai-sim
# AI API Key
AI_SYNTHETIC_API_KEY=Qrx1AsDrBT0miJJltcWFuRk0yy-28Vdv8epYhwT-
# AI Security Mode (strict|permissive)
AI_SECURITY_MODE=strict

# ============================================
# Public Web Configuration (Next.js)
# ============================================
# Public app name
NEXT_PUBLIC_APP_NAME=Infæmous Freight
# Public environment
NEXT_PUBLIC_ENV=development
# Public API base URL
NEXT_PUBLIC_API_BASE=http://localhost:4000/api
# Preferred public API URL for browser/client calls
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================
# Payment Processing (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ============================================
# Payment Processing (PayPal)
# ============================================
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# PayPal environment (sandbox|live)
PAYPAL_ENV=sandbox

# ============================================
# Billing Configuration
# ============================================
BILLING_CURRENCY=usd
TRIAL_PERIOD_DAYS=14
USAGE_TRACKING_ENABLED=true

# ============================================
# Notifications (Optional)
# ============================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Logging & Performance Monitoring
# ============================================
# Log level (error|warn|info|debug|trace)
LOG_LEVEL=info
# Performance warning threshold (milliseconds)
PERF_WARN_THRESHOLD_MS=1000
# Performance error threshold (milliseconds)
PERF_ERROR_THRESHOLD_MS=5000
# Sentry Error Tracking & APM
SENTRY_DSN=https://your-sentry-dsn@sentry.io/PROJECT_ID
SENTRY_TRACES_SAMPLE_RATE=0.1
# Datadog APM (optional)
DD_TRACE_ENABLED=false
DD_SERVICE=infamous-freight-api
DD_ENV=development
DD_RUNTIME_METRICS_ENABLED=false

# ============================================
# Analytics & Monitoring
# ============================================
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Plausible Analytics (Privacy-friendly)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# ============================================
# Email & Notifications (NEW - Recommendations)
# ============================================
# Sendgrid (Email service)
VITE_SENDGRID_API_KEY=your_sendgrid_key_here
VITE_SENDGRID_FROM_EMAIL=noreply@infamousfreight.com

# Slack Notifications
VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Maps & Geolocation (NEW - Recommendations)
# ============================================
# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox (Alternative)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ============================================
# GitHub OAuth (NEW - Recommendations)
# ============================================
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ============================================
# Rate Limiting Configuration (Tunable)
# ============================================
# General rate limiting (requests per window)
RATE_LIMIT_GENERAL_WINDOW_MS=15
RATE_LIMIT_GENERAL_MAX=100
# Authentication rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=15
RATE_LIMIT_AUTH_MAX=5
# AI service rate limiting
RATE_LIMIT_AI_WINDOW_MS=1
RATE_LIMIT_AI_MAX=20
# Billing rate limiting
RATE_LIMIT_BILLING_WINDOW_MS=15
RATE_LIMIT_BILLING_MAX=30
# Voice processing rate limiting
RATE_LIMIT_VOICE_WINDOW_MS=1
RATE_LIMIT_VOICE_MAX=10

# ============================================
# Feature Flags (Control rollout)
# ============================================
# AI Commands feature (true|false)
ENABLE_AI_COMMANDS=true
# Voice Processing feature (true|false)
ENABLE_VOICE_PROCESSING=true
# New Billing system (true|false)
ENABLE_NEW_BILLING=true
# Analytics tracking (true|false)
VITE_ENABLE_ANALYTICS=true
# Error tracking (true|false)
VITE_ENABLE_ERROR_TRACKING=true
# Performance monitoring (true|false)
VITE_ENABLE_PERFORMANCE_MONITORING=true
# A/B Testing (true|false)
VITE_ENABLE_A_B_TESTING=false

# ============================================
# Security Headers & CSP
# ============================================
# Content Security Policy report URI
CSP_REPORT_URI=/api/security/csp-violations
# CORS allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# SEO & Meta (NEW - Recommendations)
# ============================================
VITE_META_TITLE=Infamous Freight Enterprises | Global Logistics
VITE_META_DESCRIPTION=Enterprise freight management platform serving 120+ countries
VITE_OG_IMAGE=https://infamousfreight.com/og-image.png

# ============================================
# SECURITY WARNING
# ============================================
# ⚠️ Never commit real secrets to version control
# ⚠️ Use environment-specific .env files that are gitignored
# ⚠️ In production, use secure secret management (e.g., Vault, AWS Secrets Manager)
# ⚠️ See RECOMMENDATIONS_COMPLETE.md for setup instructions
