# App
NODE_ENV=development
APP_ENV=development
APP_NAME=infamous-freight
LOG_LEVEL=info
PORT=3000
API_PORT=4000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/infamous_freight

# Cache / Queue
REDIS_URL=

# Auth
# Required: generate with: openssl rand -base64 32
JWT_SECRET=your-secure-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_IN=15m
JWT_ISSUER=infamous-freight
JWT_AUDIENCE=infamous-freight-api
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=if_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_PATH=/
COOKIE_SECRET=
PASSWORD_PEPPER=

# Routing / CORS
CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
API_BASE_URL=http://localhost:4000/api
WEB_BASE_URL=http://localhost:3000
RATE_LIMIT_AUTH_MAX=10
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Web (public)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Observability
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=

# Storage (AWS S3 / R2)
S3_BUCKET=infamous-freight
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
AVATAR_STORAGE=local
AVATAR_UPLOAD_DIR=apps/api/public/uploads
AVATAR_MAX_FILE_SIZE_MB=5
AVATAR_MAX_DIMENSIONS=2048x2048
AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp
AVATAR_DATA_STORE=apps/api/data/avatars.json
PERSISTENCE_MODE=auto

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# AI
AI_PROVIDER=stub
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Integrations
WEBHOOK_SECRET=
SENDGRID_API_KEY=
GOOGLE_MAPS_API_KEY=

# Deploy
FLY_API_TOKEN=
RAILWAY_TOKEN=
