#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

set -eu

COMMIT_MSG_FILE="${1:?commit message file is required}"
COMMIT_MSG="$(head -n 1 "$COMMIT_MSG_FILE")"

PATTERN='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([a-zA-Z0-9._/-]+\))?: .{1,}$'

if ! printf '%s' "$COMMIT_MSG" | grep -Eq "$PATTERN"; then
  echo "Invalid commit message."
  echo "Use: type(scope): message"
  echo "Example: feat(api): add shipment status transition guard"
  exit 1
fi
