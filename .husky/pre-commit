#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

set -eu

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "==> husky pre-commit: Infamous Freight"

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required but not installed."
  exit 1
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files. Skipping pre-commit."
  exit 0
fi

echo "==> Checking staged diff for obvious secrets"
if git diff --cached -- . ':(exclude)pnpm-lock.yaml' | grep -E -i \
  '(api[_-]?key|secret|password|token|aws_access_key_id|aws_secret_access_key|private[_-]?key|BEGIN (RSA|EC|OPENSSH) PRIVATE KEY)' \
  >/dev/null
then
  echo "Potential secret detected in staged changes. Commit blocked."
  exit 1
fi

echo "==> Formatting staged files with Prettier"
PRETTIER_TARGETS="$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|json|md|yml|yaml|css|scss|html)$' || true)"
if [ -n "$PRETTIER_TARGETS" ]; then
  printf '%s\n' "$PRETTIER_TARGETS" | tr '\n' '\0' | xargs -0 pnpm exec prettier --write
  printf '%s\n' "$PRETTIER_TARGETS" | tr '\n' '\0' | xargs -0 git add
fi

echo "==> Lint-fixing staged JS/TS files"
ESLINT_TARGETS="$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx)$' || true)"
if [ -n "$ESLINT_TARGETS" ]; then
  printf '%s\n' "$ESLINT_TARGETS" | tr '\n' '\0' | xargs -0 pnpm exec eslint --fix
  printf '%s\n' "$ESLINT_TARGETS" | tr '\n' '\0' | xargs -0 git add
fi

echo "==> Running docs validation when docs files are staged"
DOC_TARGETS="$(printf '%s\n' "$STAGED_FILES" | grep -E '(^README\.md$|^docs/|\.md$)' || true)"
if [ -n "$DOC_TARGETS" ]; then
  if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts['lint:docs'] ? 0 : 1)" 2>/dev/null; then
    pnpm run lint:docs
  fi
fi

echo "==> Running fast repo guardrails for critical paths"
if printf '%s\n' "$STAGED_FILES" | grep -E '^(apps/api|apps/web|apps/mobile|packages/shared|packages/ui|packages/config|prisma|\.github|\.devcontainer)/' >/dev/null
then
  pnpm lint
fi

echo "✅ husky pre-commit passed"
