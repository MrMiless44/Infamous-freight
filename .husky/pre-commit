#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Type checking
echo "📝 Type checking..."
pnpm typecheck || {
  echo "❌ Type check failed. Fix errors before committing."
  exit 1
}

# Lint staged files
echo "🧹 Linting..."
pnpm lint || {
  echo "❌ Linting failed. Fix errors before committing."
  exit 1
}

# Run API tests (fast validation)
echo "🧪 Running API tests..."
pnpm --filter api test --bail --silent || {
  echo "❌ API tests failed. Fix tests before committing."
  exit 1
}

echo "✅ Pre-commit checks passed!"
