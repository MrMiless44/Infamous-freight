PORT=3000

# GitHub App Webhook secret (must match App settings)
GITHUB_WEBHOOK_SECRET="..."

# GitHub App identity
GITHUB_APP_ID="123456"
# IMPORTANT: keep newlines; if storing in env, escape as \n and we will unescape.
GITHUB_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Required for Copilot assignment call (PAT or user-to-server token)
GITHUB_COPILOT_USER_TOKEN="ghp_..."

# Protect admin endpoints
ADMIN_BEARER_TOKEN="a-long-random-secret"

# Optional
AUDIT_MAX=200
IDEMPOTENCY_FILE="/tmp/deliveries.json"
