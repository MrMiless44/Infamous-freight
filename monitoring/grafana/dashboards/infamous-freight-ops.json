{\n  "title": "Infæmous Freight — Operations Dashboard",\n  "uid": "infamous-freight-ops",\n  "schemaVersion": 38,\n  "version": 1,\n  "refresh": "30s",\n  "tags": ["infamous-freight", "operations"],\n  "time": { "from": "now-1h", "to": "now" },\n  "panels": [\n    {\n      "id": 1,\n      "title": "HTTP Request Rate",\n      "type": "timeseries",\n      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },\n      "targets": [{\n        "expr": "sum(rate(infamous_http_requests_total[5m])) by (route, method)",\n        "legendFormat": "{{method}} {{route}}"\n      }]\n    },\n    {\n      "id": 2,\n      "title": "HTTP p95 Latency",\n      "type": "timeseries",\n      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },\n      "targets": [{\n        "expr": "histogram_quantile(0.95, sum(rate(infamous_http_request_duration_seconds_bucket[5m])) by (le, route))",\n        "legendFormat": "p95 {{route}}"\n      }],\n      "fieldConfig": { "defaults": { "unit": "s", "thresholds": {\n        "steps": [\n          { "color": "green", "value": null },\n          { "color": "yellow", "value": 0.5 },\n          { "color": "red", "value": 1 }\n        ]\n      }} }\n    },\n    {\n      "id": 3,\n      "title": "Error Rate",\n      "type": "stat",\n      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },\n      "targets": [{\n        "expr": "sum(rate(infamous_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(infamous_http_requests_total[5m])) * 100",\n        "legendFormat": "Error %"\n      }],\n      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": {\n        "steps": [\n          { "color": "green", "value": null },\n          { "color": "yellow", "value": 1 },\n          { "color": "red", "value": 5 }\n        ]\n      }} }\n    },\n    {\n      "id": 4,\n      "title": "Queue Depths",\n      "type": "timeseries",\n      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },\n      "targets": [{\n        "expr": "infamous_queue_depth",\n        "legendFormat": "{{queue_name}}"\n      }],\n      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }\n    },\n    {\n      "id": 5,\n      "title": "Job Processing Rate",\n      "type": "timeseries",\n      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },\n      "targets": [{\n        "expr": "sum(rate(infamous_jobs_total{status=\"completed\"}[5m])) by (queue_name)",\n        "legendFormat": "{{queue_name}} completed/s"\n      }, {\n        "expr": "sum(rate(infamous_jobs_total{status=\"failed\"}[5m])) by (queue_name)",\n        "legendFormat": "{{queue_name}} failed/s"\n      }]\n    },\n    {\n      "id": 6,\n      "title": "Cache Hit Rate",\n      "type": "gauge",\n      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 6 },\n      "targets": [{\n        "expr": "sum(rate(infamous_cache_operations_total{result=\"hit\"}[5m])) / sum(rate(infamous_cache_operations_total[5m])) * 100"\n      }],\n      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,\n        "thresholds": { "steps": [\n          { "color": "red", "value": null },\n          { "color": "yellow", "value": 70 },\n          { "color": "green", "value": 90 }\n        ]}\n      }}\n    },\n    {\n      "id": 7,\n      "title": "Webhook Delivery Success Rate",\n      "type": "gauge",\n      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 6 },\n      "targets": [{\n        "expr": "sum(rate(infamous_webhook_deliveries_total{status=\"success\"}[5m])) / sum(rate(infamous_webhook_deliveries_total[5m])) * 100"\n      }],\n      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,\n        "thresholds": { "steps": [\n          { "color": "red", "value": null },\n          { "color": "yellow", "value": 90 },\n          { "color": "green", "value": 98 }\n        ]}\n      }}\n    },\n    {\n      "id": 8,\n      "title": "DB Query p99 Duration",\n      "type": "timeseries",\n      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },\n      "targets": [{\n        "expr": "infamous_db_query_duration_seconds{quantile=\"0.99\"}",\n        "legendFormat": "{{model}}.{{operation}} p99"\n      }],\n      "fieldConfig": { "defaults": { "unit": "s" } }\n    },\n    {\n      "id": 9,\n      "title": "Active Shipments by Status",\n      "type": "piechart",\n      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 8 },\n      "targets": [{\n        "expr": "sum(infamous_active_shipments) by (status)",\n        "legendFormat": "{{status}}"\n      }]\n    },\n    {\n      "id": 10,\n      "title": "Rate Shop Duration p95",\n      "type": "timeseries",\n      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 8 },\n      "targets": [{\n        "expr": "histogram_quantile(0.95, sum(rate(infamous_rate_shop_duration_seconds_bucket[5m])) by (le, cache_hit))",\n        "legendFormat": "cache_hit={{cache_hit}}"\n      }],\n      "fieldConfig": { "defaults": { "unit": "s" } }\n    },\n    {\n      "id": 11,\n      "title": "Node.js Heap Usage",\n      "type": "timeseries",\n      "gridPos": { "x": 12, "y": 18, "w": 8, "h": 8 },\n      "targets": [{\n        "expr": "infamous_nodejs_heap_size_used_bytes",\n        "legendFormat": "Heap Used"\n      }, {\n        "expr": "infamous_nodejs_heap_size_total_bytes",\n        "legendFormat": "Heap Total"\n      }],\n      "fieldConfig": { "defaults": { "unit": "bytes" } }\n    }\n  ]\n}