{
  "dashboard": {
    "title": "Database Health & Performance",
    "description": "PostgreSQL and database performance metrics",
    "tags": ["database", "postgresql", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Database Connections",
        "type": "gauge",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "options": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Database Up Status",
        "type": "gauge",
        "targets": [
          {
            "expr": "pg_up",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "options": {
          "mappings": {
            "type": "value",
            "options": {
              "1": {
                "text": "Up",
                "color": "green"
              },
              "0": {
                "text": "Down",
                "color": "red"
              }
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "targets": [
          {
            "expr": "rate(pg_stat_io_heap_blks_hit[5m]) / (rate(pg_stat_io_heap_blks_hit[5m]) + rate(pg_stat_io_heap_blks_read[5m])) * 100",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "options": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Query Latency (Mean)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pg_stat_statements_mean_exec_time[5m])",
            "legendFormat": "Query Time (ms)",
            "refId": "A"
          }
        ],
        "options": {
          "yaxes": [
            {
              "format": "ms",
              "label": "Milliseconds"
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Transactions Per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pg_stat_database_xact_commit[5m]) + rate(pg_stat_database_xact_rollback[5m])",
            "legendFormat": "Transactions/sec",
            "refId": "A"
          }
        ],
        "options": {
          "yaxes": [
            {
              "format": "tps",
              "label": "TPS"
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Database Size",
        "type": "gauge",
        "targets": [
          {
            "expr": "pg_database_size_bytes / 1024 / 1024 / 1024",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "options": {
          "unit": "GB"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 7,
        "title": "Table Size (Top 10)",
        "type": "graph",
        "targets": [
          {
            "expr": "topk(10, pg_table_size_bytes) / 1024 / 1024",
            "legendFormat": "{{ schemaname }}.{{ tablename }}",
            "refId": "A"
          }
        ],
        "options": {
          "yaxes": [
            {
              "format": "MB",
              "label": "Size (MB)"
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      }
    ]
  }
}
