# API Environment Configuration

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
API_PORT=4000
API_HOST=0.0.0.0

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection
# Local example: postgresql://infamous:infamouspass@localhost:5432/infamous_freight
# Railway external example (replace host/port/db from Railway "Connect" panel):
#   postgresql://postgres:PASSWORD@<RAILWAY_HOST>:<RAILWAY_PORT>/<RAILWAY_DB>?sslmode=require
DATABASE_URL=postgresql://infamous:infamouspass@localhost:5432/infamous_freight
TEST_DATABASE_URL=postgresql://infamous:infamouspass@localhost:5432/infamous_freight_test

# Database pool configuration
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET=replace_with_long_random_value_minimum_32_characters
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# JWT Rotation (JWKS-based, optional)
AUTH_JWKS_URI=
AUTH_AUDIENCE=
AUTH_ISSUER=

# Audit Log (tamper-evident hash chain)
AUDIT_LOG_DIR=./data
AUDIT_LOG_FILE=./data/audit.log
AUDIT_LOG_SALT=change-me-to-random-salt

# Idempotency TTL (seconds)
IDEMPOTENCY_TTL_SECONDS=900

# ============================================
# CORS Configuration
# ============================================
# Comma-separated allowlist (NO wildcards in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com,https://staging.yourdomain.com

# ============================================
# AI Configuration
# ============================================
AI_PROVIDER=synthetic
AI_SYNTHETIC_ENGINE_URL=http://localhost:4000/internal/ai-sim
AI_SYNTHETIC_API_KEY=Qrx1AsDrBT0miJJltcWFuRk0yy-28Vdv8epYhwT-
AI_SECURITY_MODE=strict
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# Voice Processing
# ============================================
VOICE_MAX_FILE_SIZE_MB=10
ENABLE_VOICE_PROCESSING=true

# ============================================
# Payment Processing
# ============================================
# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CONNECT_RETURN_URL=https://your-web-domain.com/connect/return
STRIPE_CONNECT_REFRESH_URL=https://your-web-domain.com/connect/refresh

# Stripe Subscription Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly

# Stripe Billing + Checkout (seat plans, metered usage, add-ons)
STRIPE_PRO_PRICE_ID=price_pro_seat_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_seat_monthly
STRIPE_AI_METERED_PRICE_ID=price_ai_actions_metered
STRIPE_AI_METERED_LOOKUP_KEY=iff_ai_action_metered
STRIPE_VOICE_PRICE_ID=price_voice_seat_monthly
STRIPE_WHITE_LABEL_PRICE_ID=price_white_label_monthly
STRIPE_ANALYTICS_PRICE_ID=price_analytics_export_monthly
STRIPE_USAGE_REPORT_KEY=change_me_for_cron_jobs

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_ENV=sandbox

# Billing configuration
BILLING_CURRENCY=usd
TRIAL_PERIOD_DAYS=14
USAGE_TRACKING_ENABLED=true

# Public web URL (used for Stripe redirects)
PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Marketplace & Pricing
# ============================================
# Pay-per-delivery pricing defaults
PRICE_BASE_USD=6.00
PRICE_PER_MILE_USD=1.85
PRICE_PER_MINUTE_USD=0.20
PRICE_MINIMUM_USD=9.99

# Plan discounts (percent off delivery)
DISCOUNT_STARTER_PCT=10
DISCOUNT_PRO_PCT=20
DISCOUNT_ENTERPRISE_PCT=30

# Matching defaults
MATCH_RADIUS_MILES=10

# ---------- Mapbox ETA (Phase 13) ----------
MAPBOX_ACCESS_TOKEN=
MAPBOX_MATRIX_PROFILE=mapbox/driving
MAPBOX_ETA_CACHE_TTL_SECONDS=30
MAPBOX_ETA_MAX_CANDIDATES=50

# ---------- Redis / BullMQ (Phase 15) ----------
REDIS_URL=redis://localhost:6379

# Worker concurrency
WORKER_CONCURRENCY_DISPATCH=10
WORKER_CONCURRENCY_EXPIRY=5
WORKER_CONCURRENCY_ETA=2

# ETA rate limiting (Mapbox)
ETA_RATE_LIMIT_MAX=50          # jobs
ETA_RATE_LIMIT_DURATION_MS=60000

# Offer expiry sweeper
OFFER_EXPIRY_SWEEP_SECONDS=15

# Hold expiry sweeper
HOLD_EXPIRY_SWEEP_SECONDS=15

# Waves orchestration
WAVE_QUEUE_ENABLED=true

# Bull Board (ops)
BULLBOARD_ENABLED=true
BULLBOARD_PATH=/ops/queues

# ---------- Holds (Phase 7) ----------
JOB_HOLD_SECONDS=90
HOLD_RADIUS_MILES=10

# ---------- POD / OTP (Phase 8) ----------
OTP_REQUIRED_DEFAULT=true
OTP_LENGTH=6
OTP_HASH_SALT=change-me

# ---------- Object Storage (S3/R2 compatible) ----------
STORAGE_PROVIDER=s3

STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Public base URL to access objects (CDN or bucket public URL)
# e.g. https://pub-xxxx.r2.dev OR https://<bucket>.s3.amazonaws.com
STORAGE_PUBLIC_BASE_URL=

# Signed URL TTL (seconds)
STORAGE_PRESIGN_TTL_SECONDS=900

# ---------- Offers (Phase 10) ----------
OFFER_EXPIRY_SECONDS=30
OFFER_FANOUT_DEFAULT_COUNT=10

# ---------- Offer Waves (Phase 11) ----------
WAVE_RADIUS_MILES=10

WAVE1_COUNT=3
WAVE1_EXPIRY_SECONDS=30

WAVE2_COUNT=10
WAVE2_EXPIRY_SECONDS=30

WAVE3_COUNT=50
WAVE3_EXPIRY_SECONDS=60
WAVE3_ENABLED=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_GENERAL_WINDOW_MS=15
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=15
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AI_WINDOW_MS=1
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_BILLING_WINDOW_MS=15
RATE_LIMIT_BILLING_MAX=30
RATE_LIMIT_VOICE_WINDOW_MS=1
RATE_LIMIT_VOICE_MAX=10
RATE_LIMIT_EXPORT_WINDOW_MS=60
RATE_LIMIT_EXPORT_MAX=5
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=1440
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_WEBHOOK_WINDOW_MS=1
RATE_LIMIT_WEBHOOK_MAX=100

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=infamous:

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
PERF_WARN_THRESHOLD_MS=1000
PERF_ERROR_THRESHOLD_MS=5000

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# Datadog
DD_TRACE_ENABLED=false
DD_SERVICE=infamous-freight-api
DD_ENV=development
DD_RUNTIME_METRICS_ENABLED=false
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126

# ============================================
# Email & Notifications
# ============================================
# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@infamousfreight.com
SENDGRID_FROM_NAME=Infamous Freight

# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts

# Discord
DISCORD_WEBHOOK_URL=

# ---------- POD Policy (Phase 12) ----------
# Always require at least one POD photo
POD_REQUIRE_PHOTO_ALWAYS=true

# Require signature for jobs >= this amount (USD)
POD_SIGNATURE_MIN_USD=25

# Require OTP for jobs >= this amount (USD)
POD_OTP_MIN_USD=50

# Require OTP for these vehicle types (comma separated)
POD_OTP_VEHICLES=BOX_TRUCK,STRAIGHT_TRUCK,SEMI

# Require photo for these vehicle types
POD_PHOTO_VEHICLES=CARGO_VAN,SPRINTER,BOX_TRUCK,STRAIGHT_TRUCK,SEMI

# Require signature for these vehicle types
POD_SIGNATURE_VEHICLES=CARGO_VAN,SPRINTER,BOX_TRUCK,STRAIGHT_TRUCK,SEMI

# ---------- Expo Push ----------
EXPO_PUSH_ENABLED=true

# ---------- Twilio SMS (optional fallback) ----------
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_COMMANDS=true
ENABLE_VOICE_PROCESSING=true
ENABLE_NEW_BILLING=true
ENABLE_ANALYTICS=true
ENABLE_ERROR_TRACKING=true
ENABLE_PERFORMANCE_MONITORING=true

# ============================================
# Security
# ============================================
CSP_REPORT_URI=/api/csp-violation
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true
TRUST_PROXY=false

# Git hooks: Activate with `git config core.hooksPath .githooks`

# ============================================
# Development
# ============================================
ENABLE_API_DOCS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_PRETTY_LOGS=true
# ============================================
# Persistence (Phase-13)
# ============================================
# If DATABASE_URL is set and PERSISTENCE_MODE=auto, DB-backed persistence is enabled.
# avatars, avatar selections, and genesis history will be persisted to Postgres.
# If DATABASE_URL is missing or PERSISTENCE_MODE=json, fallback to JSON/in-memory store (safe for development).
# PERSISTENCE_MODE=auto
# Example: DATABASE_URL=postgresql://infamous:infamous@localhost:5432/infamous?schema=public
# To use local Docker Postgres: pnpm db:up (requires docker + docker-compose)
# ============================================
# Stripe (optional, Phase-14)
# ============================================
# If STRIPE_SECRET_KEY is set, Stripe Checkout + Portal + Webhooks are enabled.
# Without it, /v1/billing endpoints return "not configured" (safe for CI).
# STRIPE_SECRET_KEY=sk_live_or_test
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_SUCCESS_URL=https://YOUR_WEB_DOMAIN/account/billing?success=1
# STRIPE_CANCEL_URL=https://YOUR_WEB_DOMAIN/pricing?canceled=1
# ============================================
# Monitoring & Observability (Phase 18)
# ============================================
# Sentry (error tracking + performance tracing)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Release/Build identifier (for error tracking)
RELEASE_SHA=
