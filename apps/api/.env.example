# Infamous Freight Enterprises - Configuration Example
# Copy this to .env and fill in the values
# Generated: 2026-02-22T17:24:08.985Z

# NODE
# Application environment
# Options: development, test, production
NODE_ENV=development

# API
# API server port
API_PORT=4000

# API base URL for clients
API_BASE_URL=http://localhost:4000

# WEB
# Web server port
WEB_PORT=3000

# Web app base URL
WEB_BASE_URL=http://localhost:3000

# JWT
# JWT signing secret (min 32 chars)
JWT_SECRET=undefined

# JWT token expiry
JWT_EXPIRY=1h

# CORS
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# DATABASE
# PostgreSQL connection string
DATABASE_URL=undefined

# LOG
# Logging level
# Options: debug, info, warn, error
LOG_LEVEL=info

# PERF
# Warn on queries/requests exceeding this duration (ms)
PERF_WARN_THRESHOLD_MS=1000

# Error on queries/requests exceeding this duration (ms)
PERF_ERROR_THRESHOLD_MS=5000

# RATE
# General rate limit (requests per 15 minutes)
RATE_LIMIT_GENERAL_MAX=100

# Auth rate limit (requests per 15 minutes)
RATE_LIMIT_AUTH_MAX=5

# AI rate limit (requests per minute)
RATE_LIMIT_AI_MAX=20

# Billing rate limit (requests per 15 minutes)
RATE_LIMIT_BILLING_MAX=30

# Voice upload rate limit (per minute)
RATE_LIMIT_VOICE_MAX=10

# SMS per user rate limit (per hour)
RATE_LIMIT_SMS_USER_MAX=20

# SMS per organization rate limit (per 24 hours)
RATE_LIMIT_SMS_ORG_MAX=200

# Export rate limit (per hour)
RATE_LIMIT_EXPORT_MAX=5

# Password reset attempts (per 24 hours)
RATE_LIMIT_PASSWORD_RESET_MAX=3

# Webhook rate limit (per minute)
RATE_LIMIT_WEBHOOK_MAX=100

# AI
# AI provider (openai|anthropic|synthetic)
# Options: openai, anthropic, synthetic
AI_PROVIDER=synthetic

# OPENAI
# OpenAI API key
OPENAI_API_KEY=undefined

# ANTHROPIC
# Anthropic API key
ANTHROPIC_API_KEY=undefined

# REDIS
# Redis connection URL (optional)
REDIS_URL=your-value-here

# CACHE
# Cache TTL in seconds
CACHE_TTL_SECONDS=300

# SLOW
# Threshold for slow query warnings (ms)
SLOW_QUERY_MS=500

# VOICE
# Max voice file upload size (MB)
VOICE_MAX_FILE_SIZE_MB=10

# SENTRY
# Sentry error tracking DSN
SENTRY_DSN=your-value-here

# DATADOG
# Datadog app ID for RUM
DATADOG_APP_ID=your-value-here

# Datadog client token for RUM
DATADOG_CLIENT_TOKEN=your-value-here

# Datadog site
# Options: datadoghq.com, datadoghq.eu
DATADOG_SITE=datadoghq.com

# WEBHOOK
# Webhook signing secret
WEBHOOK_SECRET=undefined

# ALLOW
# Allow x-user-id header for development
ALLOW_X_USER_ID=false

# ENABLE
# Enable detailed query logging
ENABLE_QUERY_LOGGING=false

# AUTH
# JWKS URI for JWT key rotation
AUTH_JWKS_URI=your-value-here

# Auth audience claim
AUTH_AUDIENCE=your-value-here

# Auth issuer claim
AUTH_ISSUER=your-value-here
