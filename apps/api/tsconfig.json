{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@infamous-freight/shared": ["../../packages/shared/src"],
      "@infamous-freight/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
