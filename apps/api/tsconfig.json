{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@infamous-freight/shared": ["../../packages/shared/dist"],
      "@infamous-freight/shared/*": ["../../packages/shared/dist/*"]
    },
    // Suppress lint-style checks better handled by ESLint
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noImplicitReturns": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.js",
    // Legacy standalone entry point that conflicts with the canonical server.ts → app.ts path.
    // src/index.ts was a duplicate Express app; keep server.ts as the single entry.
    "src/index.ts"
  ]
}
