{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@infamous-freight/shared": ["../../packages/shared/dist"],
      "@infamous-freight/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.js",
    // Legacy standalone entry point that conflicts with the canonical server.ts → app.ts path.
    // src/index.ts was a duplicate Express app; keep server.ts as the single entry.
    "src/index.ts"
  ]
}
