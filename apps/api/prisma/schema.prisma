  start_date       DateTime?
  end_date         DateTime?
  template_id      String?
  generated_at     DateTime @default(now())
  processing_time_ms Int?

  @@index([type])
  @@index([generated_at])
  @@index([start_date])
  @@index([end_date])
  @@map("bi_reports")
}

model ReportSchedule {
  id            String   @id @default(uuid())
  report_type   String
  frequency     String
  recipients    String[]
  format        String
  configuration Json?
  next_run      DateTime
  last_run      DateTime?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@index([frequency])
  @@index([next_run])
  @@index([is_active])
  @@index([report_type])
  @@map("report_schedules")
}

// ============================================
// PARTNER & REFERRAL PROGRAMS (TIER 2)
// ============================================

model Partner {
  id                String           @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  // Partner Details
  name              String           @unique
  email             String           @unique
  website           String?
  
  // Tier & Commission
  tier              PartnerTier      @default(RESELLER)
  commissionRate    Float            @default(0.20) // 20% default
  
  // Status
  isActive          Boolean          @default(true)
  approvedAt        DateTime?
  
  // Earnings
  totalEarnings     Float            @default(0)
  transactionCount  Int              @default(0)
  
  // Metadata
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  commissions       PartnerCommission[]

  @@index([tier])
  @@index([isActive])
  @@index([createdAt])
  @@map("partners")
}

model PartnerCommission {
  id                String   @id @default(cuid())
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  
  // Transaction
  transactionId     String
  amount            Float
  commissionRate    Float
  commission        Float
  
  // Tracking
  createdAt         DateTime @default(now())
  paidAt            DateTime?
  status            String   @default("pending") // pending | processing | paid | failed

  @@index([partnerId])
  @@index([createdAt])
  @@map("partner_commissions")
}

model UpsellOpportunity {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Opportunity
  opportunityType   String   // upgrade | addon | seat_expansion
  targetTier        String?  // Suggested tier
  estimatedValue    Float?
  
  // Personalization
  reason            String?  // Why this org is a good fit
  contextJson       Json?    // Usage patterns, etc
  
  // Campaign
  campaignId        String?
  campaignStatus    String   @default("draft") // draft | active | completed
  
  // Results
  exposed           DateTime?
  clicked           DateTime?
  converted         DateTime?
  
  @@index([organizationId])
  @@index([campaignStatus])
  @@map("upsell_opportunities")
}

// ============================================
// DISASTER RECOVERY & BACKUPS (TIER 1)
// ============================================

model BackupLog {
  id                String   @id @default(cuid())
  
  // Backup Details
  backupType        String   // full | incremental | wal
  backupDate        DateTime @default(now())
  s3Key             String
  
  // Metadata
  size              BigInt?  // Bytes
  status            String   @default("success") // success | failed
  checksumSha256    String?
  
  // Verification
  verified          Boolean  @default(false)
  verifiedAt        DateTime?
  
  // Retention
  retentionUntil    DateTime?
  
  @@index([backupDate])
  @@index([status])
  @@index([backupType])
  @@map("backup_logs")
}

model RestoreLog {
  id                String   @id @default(cuid())
  backupLogId       String?
  
  // Restore Details
  initiatedAt       DateTime @default(now())
  completedAt       DateTime?
  status            String   @default("pending") // pending | in_progress | success | failed
  
  // Context
  reason            String   // disaster | test | manual
  initiatedBy       String?
  
  // Result
  rto               Int?     // Minutes
  rpo               Int?     // Minutes
  errors            String?
  
  @@index([status])
  @@index([initiatedAt])
  @@map("restore_logs")
}
