model ChurnPrediction {
  id String @id @default(cuid())

  // Target
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])

  // Prediction
  riskLevel   ChurnRiskLevel
  riskScore   Int // 0-100 (100 = will churn)
  probability Decimal        @db.Decimal(5, 2) // 0.00 - 100.00%

  // Analysis
  primaryReason ChurnReason?
  signals       String       @db.Text // JSON: array of churn signals
  aiExplanation String?      @db.Text

  // Intervention
  recommendedActions String?   @db.Text // JSON: array of retention actions
  interventionSent   Boolean   @default(false)
  interventionType   String? // "email" | "call" | "discount" | "upgrade"
  interventionDate   DateTime?

  // Outcome
  churned       Boolean   @default(false)
  churnedAt     DateTime?
  retained      Boolean   @default(false)
  retainedUntil DateTime?

  // Prediction metadata
  predictionDate DateTime @default(now())
  expiresAt      DateTime // Re-evaluate after this date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([riskLevel])
  @@index([riskScore])
  @@index([churned])
  @@index([predictionDate])
  @@map("churn_predictions")
}

model DispatchDecision {
  id String @id @default(cuid())

