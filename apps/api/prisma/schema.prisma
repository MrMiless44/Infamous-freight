// Prisma schema for Infamous Freight Enterprises

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SHIPPER
  DRIVER
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum PlanStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum VehicleType {
  CAR
  SUV
  VAN
  BOX_TRUCK
  STRAIGHT_TRUCK
  SEMI
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum JobStatus {
  DRAFT
  REQUIRES_PAYMENT
  OPEN
  ACCEPTED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
  REFUNDED
}

enum JobEventType {
  CREATED
  PAYMENT_INITIATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  OPENED
  HELD
  ACCEPTED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELED
  NOTE
}

enum PodAssetKind {
  PHOTO
  SIGNATURE
}

enum JobOfferStatus {
  OFFERED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum WebhookEventStatus {
  PENDING
  PROCESSED
  FAILED
}

// ============================================
// Multi-tenancy (Phase 19)
// ============================================

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  // Per-tenant encryption key (encrypted by master key)
  dataKeyEnc String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  jobs                Job[]
  auditLogs           OrgAuditLog[]
  billing             OrgBilling?
  usage               OrgUsage[]
  contracts           EnterpriseContract[]
  churnPredictions    ChurnPrediction[]
  usageMetrics        UsageMetric[]
  
  // Tier 1-3: Security & Compliance
  encryptionKeys      EncryptionKey[]
  complianceAudits    ComplianceAudit[]
  complianceReports   ComplianceReport[]
  upsellOpportunities UpsellOpportunity[]
  partners            Partner[]

  @@index([slug])
  @@index([isActive])
  @@map("organizations")
}

// ============================================
// Billing (Phase 20)
// ============================================

enum BillingPlan {
  STARTER
  GROWTH
  ENTERPRISE
  CUSTOM
}

model OrgBilling {
  id             String      @id @default(cuid())
  organizationId String      @unique
  plan           BillingPlan @default(STARTER)

  // Stripe integration
  stripeCustomerId String? @unique
  stripeSubId      String? @unique
  stripeStatus     String? @default("incomplete") // active, past_due, canceled

  // Pricing
  monthlyBase  Float @default(99) // Base monthly fee
  monthlyQuota Int   @default(100) // Included jobs per month
  overagePrice Float @default(1.50) // Per-job overage

  // Billing cycle
  billingCycleStart DateTime?
  nextBillingDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
  @@index([stripeStatus])
  @@map("org_billing")
}

model OrgUsage {
  id             String @id @default(cuid())
  organizationId String
  month          String // YYYY-MM format

  jobs          Int   @default(0) // Job completions this month
  revenue       Float @default(0) // Total revenue generated
  overageJobs   Int   @default(0) // Jobs over quota
  overageCharge Float @default(0) // Overage cost

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, month])
  @@index([organizationId])
  @@index([month])
  @@map("org_usage")
}

model AiUsageRecord {
  id                       String   @id @default(cuid())
  tenantId                 String?
  stripeSubscriptionItemId String
  quantity                 Int
  stripeUsageRecordId      String   @unique
  createdAt                DateTime @default(now())

  @@index([tenantId])
  @@index([stripeSubscriptionItemId])
  @@map("ai_usage_records")
}

model OrgInvoice {
  id             String @id @default(cuid())
  organizationId String
  month          String // YYYY-MM format

  // Invoice details
  stripeInvoiceId String? @unique
  stripeStatus    String? @default("draft")

  baseFee       Float @default(0)
  overageCharge Float @default(0)
  totalAmount   Float @default(0)

  pdfUrl String? // S3 or Stripe invoice PDF

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@unique([organizationId, month])
  @@index([organizationId])
  @@index([month])
  @@map("org_invoices")
}

model OrgAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([organizationId, entity])
  @@index([createdAt])
  @@map("org_audit_logs")
}

// ============================================
// Compliance
// ============================================

model Dispute {
  id            String   @id @default(uuid())
  userId        String
  transactionId String
  processor     String
  status        String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionId])
  @@index([status])
  @@index([createdAt])
  @@map("disputes")
}

model EnforcementAction {
  id        String   @id @default(uuid())
  userId    String
  level     String
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@index([createdAt])
  @@map("enforcement_actions")
}

model RiskScore {
  id        String   @id @default(uuid())
  userId    String
  score     Float
  factors   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([score])
  @@index([createdAt])
  @@map("risk_scores")
}

// ============================================

model User {
  id    String   @id @default(uuid())
  email String   @unique
  name  String?
  role  UserRole @default(SHIPPER)

  // Phase 19: Organization (multi-tenancy)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Phase 6: notification channels
  phone         String?
  expoPushToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Subscription / billing
  planTier             PlanTier   @default(FREE)
  planStatus           PlanStatus @default(NONE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planRenewsAt         DateTime?

  // Relations
  driverProfile        DriverProfile?
  jobsAsShipper        Job[]                  @relation("jobsAsShipper")
  jobsAsDriver         Job[]                  @relation("jobsAsDriver")
  shipments            Shipment[]
  payments             OldPayment[]           @relation("userPayments")
  jobPayments          JobPayment[]           @relation("userJobPayments")
  subscriptions        Subscription[]
  entitlements         Entitlement[]
  aiEvents             AiEvent[]
  jobOffers            JobOffer[]
  driverPerformance    DriverPerformance[]
  disputes             Dispute[]
  enforcementActions   EnforcementAction[]
  riskScores           RiskScore[]
  driverPayouts        DriverPayout[]

  // Tier 1-3: Security & Compliance
  twoFactorAuth        TwoFactorAuth?
  dataProcessingLogs   DataProcessingLog[]
  userConsents         UserConsent[]
  securityEvents       SecurityEvent[]
  anomalyDetections    AnomalyDetection[]
  usageMetrics         UsageMetric[]
  referralsCreated     Referral[] @relation("referralsCreated")
  referralsReceived    Referral[] @relation("referralsReceived")

  @@index([email])
  @@index([role])
  @@index([organizationId])
  @@index([createdAt])
  @@index([phone])
  @@index([expoPushToken])
  @@map("users")
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments Shipment[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("drivers")
}

model Shipment {
  id          String         @id @default(uuid())
  trackingId  String         @unique
  userId      String
  driverId    String?
  origin      String
  destination String
  status      ShipmentStatus @default(CREATED)
  reference   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([trackingId])
  @@index([userId])
  @@index([status])
  @@index([driverId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([userId, status])
  @@map("shipments")
}

model AiEvent {
  id        String   @id @default(uuid())
  userId    String
  command   String
  response  String?
  provider  String   @default("openai")
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
  @@map("ai_events")
}

model OldPayment {
  id                    String   @id @default(uuid())
  userId                String
  stripePaymentIntentId String?  @unique
  amount                Float // in cents or currency
  currency              String   @default("usd")
  status                String   @default("pending")
  description           String?
  metadata              String? // JSON
  encryptedCardLast4    String? // Encrypted last 4 digits
  encryptedMetadata     String? // Encrypted sensitive metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user User @relation("userPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([createdAt])
  @@index([userId, status])
  @@map("payments")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  stripePriceId        String?
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@index([createdAt])
  @@map("subscriptions")
}

model StripeCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  email            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@map("stripe_customers")
}

model Entitlement {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  key       String // e.g. "plan", "features"
  value     String // e.g. "starter|pro|enterprise"
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("entitlements")
}

// ============================================
// Marketplace Models (DoorDash-style)
// ============================================

model DriverProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  stripeAccountId String? @unique
  stripeOnboarded Boolean @default(false)

  lastLat        Float?
  lastLng        Float?
  lastLocationAt DateTime?

  vehicles Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("driver_profiles")
}

model Vehicle {
  id       String        @id @default(cuid())
  driverId String
  driver   DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  type          VehicleType
  nickname      String?
  maxWeightLbs  Int
  maxVolumeCuFt Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@map("vehicles")
}

model Job {
  id String @id @default(cuid())

  // Phase 19: Organization (multi-tenancy)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  shipperId String
  shipper   User   @relation("jobsAsShipper", fields: [shipperId], references: [id], onDelete: Restrict)

  driverId String?
  driver   User?   @relation("jobsAsDriver", fields: [driverId], references: [id], onDelete: SetNull)

  heldByDriverId String?
  heldUntil      DateTime?

  offerWave          Int       @default(0)
  offerWaveNextAt    DateTime?
  offerWaveStartedAt DateTime?

  otpRequired     Boolean   @default(true)
  deliveryOtpHash String?
  deliveredAt     DateTime?
  pickedUpAt      DateTime?

  podSignatureName String?
  podSignatureData String?
  podNotes         String?

  podRequirePhoto     Boolean @default(false)
  podRequireSignature Boolean @default(false)
  podRequireOtp       Boolean @default(false)
  podPolicyVersion    Int     @default(1)

  status JobStatus @default(DRAFT)

  pickupAddress String
  pickupLat     Float
  pickupLng     Float

  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  requiredVehicle VehicleType
  weightLbs       Int
  volumeCuFt      Int
  notes           String?

  estimatedMiles   Float
  estimatedMinutes Int
  priceUsd         Decimal @db.Decimal(10, 2)

  payment           JobPayment?
  events            JobEvent[]
  podAssets         PodAsset[]
  jobOffers         JobOffer[]
  dispatchDecisions DispatchDecision[]
  driverPayout      DriverPayout?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([shipperId])
  @@index([driverId])
  @@index([heldByDriverId])
  @@index([heldUntil])
  @@index([offerWave, offerWaveNextAt])
  @@index([otpRequired])
  @@index([deliveredAt])
  @@index([pickedUpAt])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

model PodAsset {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  kind      PodAssetKind
  key       String
  url       String
  mimeType  String
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@unique([jobId, kind, key])
  @@index([jobId, kind, createdAt])
  @@map("pod_assets")
}

model JobOffer {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  driverId String
  driver   User   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  status     JobOfferStatus @default(OFFERED)
  expiresAt  DateTime
  acceptedAt DateTime?

  rank          Int?
  wave          Int?
  distanceMiles Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, driverId])
  @@index([jobId, status, expiresAt])
  @@index([driverId, status, expiresAt])
  @@map("job_offers")
}

model JobPayment {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("userJobPayments", fields: [userId], references: [id], onDelete: Cascade)

  status    PaymentStatus @default(INITIATED)
  amountUsd Decimal       @db.Decimal(10, 2)

  stripeCheckoutId String?
  stripePaymentId  String?
  stripeChargeId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripeCheckoutId])
  @@index([stripeChargeId])
  @@map("job_payments")
}

model DriverPayout {
  id       String @id @default(cuid())
  jobId    String @unique
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  driverId String
  driver   User   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  amountCents Int
  currency    String      @default("usd")
  status      PayoutStatus @default(PENDING)

  stripeTransferId String?
  paidAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId, status])
  @@index([createdAt])
  @@map("driver_payouts")
}

model WebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  payload    String?
  source     String?            @default("stripe")
  status     WebhookEventStatus @default(PENDING)
  retryCount Int                @default(0)
  lastError  String?
  nextRetry  DateTime?
  updatedAt  DateTime           @updatedAt

  // Optional: aids debugging
  jobId       String?
  stripeObjId String?

  @@index([id])
  @@index([type])
  @@index([createdAt])
  @@index([jobId])
  @@index([status])
  @@index([nextRetry])
  @@index([status, nextRetry])
  @@map("webhook_events")
}

model JobEvent {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  type        JobEventType
  actorUserId String?
  message     String?
  actorRole   UserRole?
  metadata    String?

  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([type, createdAt])
  @@map("job_events")
}

// ============================================
// Sales & Marketing (Phase 21)
// ============================================

enum LeadType {
  SHIPPER
  DRIVER
  ENTERPRISE
  OTHER
}

enum LeadSource {
  LANDING_PAGE_SHIPPER
  LANDING_PAGE_DRIVER
  LANDING_PAGE_ENTERPRISE
  PAID_AD
  REFERRAL
  ORGANIC_SEARCH
  DIRECT
  OTHER
}

enum ReferralStatus {
  PENDING
  COMPLETED
  PAID
  FAILED
}

model Lead {
  id      String  @id @default(cuid())
  name    String
  email   String  @unique
  company String?
  phone   String?

  type   LeadType    @default(OTHER)
  source LeadSource?

  // Qualification
  estimatedMonthlyVolume Int? // For enterprise
  estimatedMonthlyBudget Decimal? @db.Decimal(12, 2) // For enterprise
  currentProvider        String? // Current logistics provider
  painPoints             String? // What problems they're trying to solve

  // Tracking
  status     String  @default("new") // new | qualified | contacted | demo_scheduled | negotiating | won | lost
  notes      String?
  assignedTo String? // Sales rep email

  // Conversion tracking
  demoScheduledAt DateTime?
  convertedOrgId  String? // If they signed up
  convertedAt     DateTime?

  metadata String? // JSON: utm params, browser info, etc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  opportunities SalesOpportunity[]
  demoBooking   DemoBooking?

  @@index([email])
  @@index([type])
  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([convertedAt])
  @@map("leads")
}

model DemoBooking {
  id     String @id @default(cuid())
  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Calendly / Google Calendar event ID
  calendarEventId  String?
  calendarProvider String? // calendly | google | other

  scheduledFor DateTime
  duration     Int      @default(30) // minutes

  // Confirmation
  confirmationSent Boolean   @default(false)
  confirmedAt      DateTime?

  // Actual meeting
  status       String  @default("scheduled") // scheduled | completed | no_show | canceled
  zoomLink     String?
  recordingUrl String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([scheduledFor])
  @@index([status])
  @@map("demo_bookings")
}

model Referral {
  id String @id @default(cuid())

  referrerUserId   String
  referrer         User   @relation("referralsCreated", fields: [referrerUserId], references: [id], onDelete: Cascade)
  
  refereeEmail     String
  referreeUserId   String?
  referree         User?  @relation("referralsReceived", fields: [referreeUserId], references: [id], onDelete: SetNull)

  // Reward
  rewardAmount Decimal @default(100) @db.Decimal(10, 2)
  rewardType   String  @default("credit") // credit | cash | percentage

  // Tracking
  status ReferralStatus @default(PENDING)

  // When referee signs up
  refereeOrgId    String?
  refereeSignupAt DateTime?

  // When condition met (e.g., 10 jobs completed)
  conditionMet DateTime?
  paidAt       DateTime?

  metadata String? // JSON: tracking info

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerUserId])
  @@index([refereeEmail])
  @@index([status])
  @@index([createdAt])
  @@map("referrals")
}

model CrmSync {
  id String @id @default(cuid())

  entityType String // lead | org | subscription | job
  entityId   String

  provider String // hubspot | salesforce | notion | slack
  syncedId String // ID in external system

  // Sync metadata
  status    String  @default("synced") // synced | failed | pending
  lastError String?

  syncedAt   DateTime
  nextSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([provider])
  @@index([status])
  @@map("crm_syncs")
}

model MetricsSnapshot {
  id String @id @default(cuid())

  // Revenue
  mrr          Decimal @db.Decimal(12, 2)
  gmv          Decimal @db.Decimal(12, 2)
  platformTake Decimal @db.Decimal(12, 2)

  // Users
  activeDrivers  Int
  activeShippers Int
  totalOrgs      Int

  // Activity
  jobsLast30 Int
  jobsLast7  Int
  jobsToday  Int

  // Growth
  newOrgsLast30 Int
  churnedLast30 Int

  // Quality
  avgJobsPerDriver Decimal @db.Decimal(10, 2)
  avgRevenuePerOrg Decimal @db.Decimal(12, 2)

  // Engagement
  activeOrgsPercent Decimal @db.Decimal(5, 2) // 0-100
  driverRetention   Decimal @db.Decimal(5, 2)

  snapshotDate DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([snapshotDate])
  @@map("metrics_snapshots")
}

// ============================================
// PHASE 22: AI-DRIVEN REVENUE OPERATIONS
// ============================================

enum DealStage {
  NEW
  QUALIFYING
  QUALIFIED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  PROPOSAL_SENT
  NEGOTIATING
  CONTRACT_SENT
  WON
  LOST
  NURTURE
}

enum OutboundStatus {
  DRAFT
  SCHEDULED
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  EXECUTED
  EXPIRED
}

enum PricingStrategy {
  STANDARD
  SURGE
  DISCOUNT
  ENTERPRISE_CUSTOM
  PROMOTIONAL
}

model SalesOpportunity {
  id String @id @default(cuid())

  // Linked to lead
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  // AI-generated scoring
  dealScore  Int @default(0) // 0-100
  confidence Int @default(50) // AI confidence level

  // Deal details
  stage       DealStage @default(NEW)
  value       Decimal?  @db.Decimal(12, 2)
  probability Int       @default(10) // % chance of closing

  // Recommendations
  recommendedPlan String? // STARTER | GROWTH | ENTERPRISE
  expectedMrr     Decimal? @db.Decimal(10, 2)

  // AI insights
  aiSummary  String? // AI-generated deal summary
  nextAction String? // email | call | demo | proposal | nurture
  urgency    String  @default("medium") // low | medium | high | urgent

  // Tracking
  ownerId           String? // Sales rep if assigned
  lastContactAt     DateTime?
  expectedCloseDate DateTime?

  // Outcome
  wonAt      DateTime?
  lostAt     DateTime?
