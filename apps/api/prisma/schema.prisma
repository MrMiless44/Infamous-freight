generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  shipments Shipment[]
  loads     Load[]
}

model Shipment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  ref         String
  originCity  String
  originState String
  destCity    String
  destState   String
  weightLb    Int
  rateCents   Int
  status      String   @default("CREATED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@unique([tenantId, ref])
}

model Load {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  originCity  String
  originState String
  destCity    String
  destState   String
  distanceMi  Int
  weightLb    Int
  rateCents   Int
  status      String   @default("OPEN")
  claimedByUserId String?
  claimedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}
