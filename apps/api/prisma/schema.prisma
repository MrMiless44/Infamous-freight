generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Carrier {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  mcNumber         String?
  dotNumber        String?
  phone            String?
  address          String?
  status           String   @default("trial")
  subscriptionTier String   @default("starter")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  drivers         Driver[]
  loads           Load[]
  invoices        Invoice[]
  documents       Document[]
  teamMembers     TeamMember[]
  quoteRequests   QuoteRequest[]
  loadAssignments LoadAssignment[]
  loadDispatches  LoadDispatch[]
  carrierPayments CarrierPayment[]
  aiUsageEvents   AiUsageEvent[]
  rateAgreement   RateAgreement?
}

model Driver {
  id             String   @id @default(cuid())
  carrierId      String
  name           String
  phone          String?
  licenseNumber  String?
  licenseState   String?
  equipmentType  String?
  status         String   @default("available")
  currentLat     Float?
  currentLng     Float?
  hosStatus      String   @default("off_duty")
  hoursRemaining Float    @default(11)
  lastLocationAt DateTime @default(now())
  createdAt      DateTime @default(now())

  carrier Carrier @relation(fields: [carrierId], references: [id])
  loads   Load[]

  @@index([carrierId, createdAt])
  @@index([carrierId, status])
}

model Load {
  id            String    @id @default(cuid())
  carrierId     String
  driverId      String?
  brokerName    String
  brokerMc      String?
  originCity    String
  originState   String
  originLat     Float
  originLng     Float
  destCity      String
  destState     String
  destLat       Float
  destLng       Float
  distance      Int
  rate          Float
  ratePerMile   Float
  equipmentType String
  weight        Int
  status        String    @default("available")
  pickupDate    DateTime
  deliveryDate  DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  carrier              Carrier               @relation(fields: [carrierId], references: [id])
  driver               Driver?               @relation(fields: [driverId], references: [id])
  invoice              Invoice?
  loadAssignment       LoadAssignment?
  loadDispatch         LoadDispatch?
  shipmentTracking     ShipmentTracking[]
  deliveryConfirmation DeliveryConfirmation?
  carrierPayments      CarrierPayment[]
  loadBoardPost        LoadBoardPost?

  @@index([carrierId, createdAt])
  @@index([carrierId, status])
}

model Invoice {
  id            String    @id @default(cuid())
  loadId        String    @unique
  carrierId     String
  invoiceNumber String    @unique
  brokerName    String
  brokerEmail   String?
  amount        Float
  status        String    @default("draft")
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  carrier Carrier @relation(fields: [carrierId], references: [id])
  load    Load    @relation(fields: [loadId], references: [id])
}

model Document {
  id         String    @id @default(cuid())
  carrierId  String
  type       String // insurance, authority, license, etc.
  fileUrl    String
  expiryDate DateTime?
  status     String    @default("active")
  createdAt  DateTime  @default(now())

  carrier Carrier @relation(fields: [carrierId], references: [id])
}

model TeamMember {
  id         String    @id @default(cuid())
  carrierId  String
  email      String
  name       String
  role       String    @default("dispatcher") // owner, dispatcher, safety, accountant, driver
  status     String    @default("active")
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  carrier Carrier @relation(fields: [carrierId], references: [id])
}

model QuoteRequest {
  id               String    @id @default(cuid())
  carrierId        String
  brokerName       String
  originCity       String
  destCity         String
  freightType      String
  weight           Int
  pickupDate       DateTime
  deliveryDeadline DateTime?
  shipperRate      Float
  carrierCost      Float
  profitMargin     Float
  status           String    @default("pending")
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  carrier Carrier @relation(fields: [carrierId], references: [id])

  @@index([carrierId])
  @@index([status])
}

model LoadAssignment {
  id            String    @id @default(cuid())
  loadId        String    @unique
  carrierId     String
  rateConfirmed Float
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  carrier Carrier @relation(fields: [carrierId], references: [id])
  load    Load    @relation(fields: [loadId], references: [id])

  @@index([carrierId])
  @@index([status])
}

model LoadDispatch {
  id                   String    @id @default(cuid())
  loadId               String    @unique
  carrierId            String
  pickupContactName    String?
  pickupContactPhone   String?
  pickupAppointment    DateTime?
  deliveryContactName  String?
  deliveryContactPhone String?
  deliveryAppointment  DateTime?
  commodityInfo        String?
  status               String    @default("pending")
  dispatchedAt         DateTime?
  confirmedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  carrier Carrier @relation(fields: [carrierId], references: [id])
  load    Load    @relation(fields: [loadId], references: [id])

  @@index([carrierId])
  @@index([status])
}

model ShipmentTracking {
  id                String    @id @default(cuid())
  loadId            String
  status            String    @default("in_transit")
  latitude          Float?
  longitude         Float?
  pickupConfirmedAt DateTime?
  deliveryETA       DateTime?
  deliveredAt       DateTime?
  podReceived       Boolean   @default(false)
  podVerified       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  load Load @relation(fields: [loadId], references: [id])

  @@index([loadId])
  @@index([status])
}

model DeliveryConfirmation {
  id           String    @id @default(cuid())
  loadId       String    @unique
  podSignature String?
  podDate      DateTime?
  deliveryTime DateTime?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  load Load @relation(fields: [loadId], references: [id])
}

model CarrierPayment {
  id            String    @id @default(cuid())
  loadId        String
  carrierId     String
  amount        Float
  paymentMethod String?
  status        String    @default("pending")
  paymentDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  carrier Carrier @relation(fields: [carrierId], references: [id])
  load    Load    @relation(fields: [loadId], references: [id])

  @@index([carrierId])
  @@index([status])
}

model RateAgreement {
  id            String    @id @default(cuid())
  carrierId     String    @unique
  baseRate      Float
  fuelSurcharge Float?
  effectiveDate DateTime
  expiryDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  carrier Carrier @relation(fields: [carrierId], references: [id])
}

model OperationalMetric {
  id              String   @id @default(cuid())
  date            DateTime
  period          String
  loadsBooked     Int      @default(0)
  grossMargin     Float    @default(0)
  onTimePickup    Float    @default(0)
  onTimeDelivery  Float    @default(0)
  daysOutstanding Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([period])
}

model LoadBoardPost {
  id          String    @id @default(cuid())
  loadId      String    @unique
  board       String
  boardPostId String
  postedAt    DateTime  @default(now())
  expiresAt   DateTime?
  status      String    @default("posted")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  load Load @relation(fields: [loadId], references: [id])

  @@index([board])
  @@index([status])
}

model AiUsageEvent {
  id             String   @id @default(cuid())
  carrierId      String
  feature        String
  actionCount    Int      @default(1)
  documentScans  Int      @default(0)
  voiceMinutes   Int      @default(0)
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  estimatedCost  Float    @default(0)
  idempotencyKey String?
  metadata       String?
  createdAt      DateTime @default(now())

  carrier Carrier @relation(fields: [carrierId], references: [id])

  @@unique([carrierId, idempotencyKey])
  @@index([carrierId, createdAt])
  @@index([feature])
}

model StripeWebhookEvent {
  id           String    @id @default(cuid())
  eventId      String    @unique
  eventType    String
  carrierId    String?
  status       String
  errorMessage String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@index([eventType])
  @@index([status])
  @@index([carrierId])
  @@index([receivedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // load, driver, invoice, etc.
  entityId   String
  action     String // create, update, delete, view
  userId     String
  userName   String
  details    String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
