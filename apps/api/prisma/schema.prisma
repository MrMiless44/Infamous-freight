model FraudAlert {
  id String @id @default(cuid())

  // What triggered the alert
  entityType String // "user" | "org" | "job" | "payment"
  entityId   String

  // Fraud classification
  fraudType FraudType
  riskLevel FraudRiskLevel
  riskScore Int // 0-100

  // Detection details
  detectedBy String @default("fraud-ai") // "fraud-ai" | "manual" | "rule-based"
  signals    String @db.Text // JSON: array of fraud signals

  // AI analysis
  aiExplanation String? @db.Text
  confidence    Int // 0-100

  // Status
  status String @default("active") // active | investigating | resolved | false_positive

  // Actions taken
  actionsTaken String?   @db.Text // JSON: array of actions
  blockedAt    DateTime?
  resolvedAt   DateTime?
  resolvedBy   String?
  resolution   String? // "blocked" | "warned" | "false_positive" | "legitimate"

  // Related entities
  userId String?
  orgId  String?
  jobId  String?

