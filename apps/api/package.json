{
  "name": "@infamous-freight/api",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infaemous-Freight/Infamous-freight.git",
    "directory": "apps/api"
  },
  "type": "commonjs",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "node dist/src/server.js",
    "test": "node scripts/run-jest.cjs --runInBand",
    "test:coverage": "node scripts/run-jest.cjs --runInBand --coverage",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@prisma/extension-accelerate": "3.0.1",
    "@sentry/node": "^8.55.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "6.19.3",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3"
  }
}
