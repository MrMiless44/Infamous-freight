    "db:push": "prisma db push",
    "openapi:write": "tsx src/config/openapi.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^9.14.0",
    "bullmq": "^5.16.0",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.7.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.1"
  }
}
