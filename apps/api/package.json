{
  "name": "@infamous/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @infamous-freight/shared build && tsc -p tsconfig.json",
    "build:nocheck": "tsc -p tsconfig.json --noEmitOnError false",
    "start": "node dist/server.js",
    "typecheck": "pnpm --filter @infamous-freight/shared build && tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "node scripts/run-vitest.mjs",
    "smoke": "node -e \"const base = (process.env.API_URL || 'http://localhost:4000').replace(/\\/$/, ''); fetch(base + '/health').then((res) => { if (!res.ok) process.exit(1); }).catch(() => process.exit(1));\"",
    "prisma:generate": "node scripts/prisma-generate-safe.mjs",
    "db:migrate": "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma migrate deploy --schema=prisma/schema.prisma",
    "db:migrate:dev": "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma migrate dev --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@infamous-freight/shared": "workspace:*",
    "@launchdarkly/node-server-sdk": "^9.10.10",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/node": "^10.47.0",
    "@sentry/profiling-node": "^10.47.0",
    "@types/pg": "^8.20.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.73.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^22.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
