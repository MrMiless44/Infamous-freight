  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "build": "node --check src/server.js src/routes/*.js src/middleware/*.js",
    "typecheck": "npm run build",
    "clean": "rm -rf coverage .cache .turbo dist node_modules",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "validate:env": "node scripts/env.validation.js",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down"
  },
