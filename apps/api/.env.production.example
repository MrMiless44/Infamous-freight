# apps/api production environment (reference)
# Copy values into deployment secrets manager; do not commit real secrets.

# Core app
NODE_ENV=production
APP_PORT=4000
PORT=4000
API_PORT=4000
DATABASE_URL=postgresql://user:password@host:5432/infamous_freight

# JWT/auth
# Recommended: HS256 for simplicity unless you have managed RS256 keys.
JWT_ALGORITHM=HS256
JWT_SECRET=replace-with-min-32-char-secret-value
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=infamous-freight
JWT_AUDIENCE=infamous-freight-api

# Cookies and security
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=if_refresh_token
AUTH_COOKIE_DOMAIN=.infamousfreight.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_PATH=/
COOKIE_SECRET=replace-with-min-32-char-secret-value
PASSWORD_PEPPER=

# API/cors/rate limiting
RATE_LIMIT_GENERAL_MAX=100
CORS_ORIGIN=https://www.infamousfreight.com,https://infamousfreight.com
RATE_LIMIT_AUTH_MAX=10

# Password hashing
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Persistence/cache/observability
REDIS_URL=
PERSISTENCE_MODE=auto
SENTRY_DSN=
WEBHOOK_SECRET=
LOG_LEVEL=info

# Avatar/storage
AVATAR_STORAGE=local
AVATAR_UPLOAD_DIR=apps/api/public/uploads
AVATAR_MAX_FILE_SIZE_MB=5
AVATAR_MAX_DIMENSIONS=2048x2048
AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/webp
AVATAR_DATA_STORE=apps/api/data/avatars.json

# AI provider
AI_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# S3 (optional)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=https://www.infamousfreight.com/billing/success
STRIPE_CANCEL_URL=https://www.infamousfreight.com/billing/cancel
