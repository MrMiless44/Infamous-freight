# ─────────────────────────────────────────────────────────────────────────────
# Infæmous Freight – apps/api Production Environment Variables
#
# Backend deployed on api.infamousfreight.com
# Frontend served from www.infamousfreight.com (Netlify)
#
# Copy these into your production deployment environment (Fly.io, Railway, etc.)
# NEVER commit actual values to source control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
APP_PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/infamous_freight

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=<RSA private key PEM – replace \n with \\n>
JWT_PUBLIC_KEY=<RSA public key PEM – replace \n with \\n>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=infamous-freight
JWT_AUDIENCE=infamous-freight-api

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# www.infamousfreight.com = Netlify primary domain
# infamousfreight.com     = apex domain (also redirects to www via Netlify)
CORS_ORIGIN=https://www.infamousfreight.com,https://infamousfreight.com

# ── Auth Cookies ──────────────────────────────────────────────────────────────
# Cross-origin cookies require SameSite=None + Secure=true.
# Frontend (www.infamousfreight.com) and backend (api.infamousfreight.com)
# are on different subdomains, so cross-origin cookie rules apply.
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=if_refresh_token
AUTH_COOKIE_DOMAIN=.infamousfreight.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_PATH=/

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>
STRIPE_SUCCESS_URL=https://www.infamousfreight.com/billing/success
STRIPE_CANCEL_URL=https://www.infamousfreight.com/billing/cancel

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_AUTH_TOKEN=<internal-integration-auth-token>
SENTRY_ORG_SLUG=<your-org-slug>
SENTRY_PROJECT_SLUG=<your-project-slug>
SENTRY_OAUTH_CLIENT_ID=<oauth-client-id>
SENTRY_OAUTH_CLIENT_SECRET=<oauth-client-secret>
SENTRY_OAUTH_REDIRECT_URI=https://api.infamousfreight.com/api/sentry/oauth/callback
