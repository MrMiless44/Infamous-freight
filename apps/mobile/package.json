{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "description": "React Native/Expo mobile app for Infamous Freight",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo build",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
