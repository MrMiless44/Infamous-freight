{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "moduleResolution": "node",
        "ignoreDeprecations": "5.0",
        "lib": ["ES2020"]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "tests",
        "build",
        "dist"
    ]
}
