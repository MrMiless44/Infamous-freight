{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "esnext",
        "target": "es2020",
        "jsx": "react-native",
        "lib": [
            "es2020"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "types": [
            "react",
            "react-native"
        ]
    },
    "include": [
        "src",
        "services"
    ],
    "exclude": [
        "node_modules",
        "build",
        "tests"
    ]
}