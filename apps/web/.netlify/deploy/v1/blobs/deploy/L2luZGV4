-auto w-full max-w-6xl px-6 flex items-center justify-between\"><p class=\"text-sm font-semibold tracking-wide text-slate-900\">INFÆMOUS FREIGHT<!-- --> <span class=\"text-slate-500\">Dispatcher</span></p><nav class=\"flex items-center gap-3 text-sm\"><a class=\"rounded-lg border border-slate-300 px-3 py-2 text-slate-700\" href=\"/login\">Sign in</a><a class=\"rounded-lg bg-slate-900 px-3 py-2 text-white\" href=\"/register\">Start free trial</a></nav></div></header><main class=\"flex-1\"><main class=\"min-h-screen bg-slate-50 text-slate-900\"><header class=\"border-b border-slate-200 bg-white/80 py-4 backdrop-blur-md\"><div class=\"mx-auto w-full max-w-6xl px-6 flex items-center justify-between\"><p class=\"text-sm font-semibold tracking-wide text-slate-900\">INFÆMOUS FREIGHT<!-- --> <span class=\"text-slate-500\">Dispatcher</span></p><nav class=\"flex items-center gap-3 text-sm\"><a class=\"rounded-lg border border-slate-300 px-3 py-2 text-slate-700\" href=\"/login\">Sign in</a><a class=\"rounded-lg bg-slate-900 px-3 py-2 text-white\" href=\"/register\">Start free trial</a></nav></div></header><section class=\"py-16\"><div class=\"mx-auto w-full max-w-6xl px-6\"><p class=\"text-xs font-medium uppercase tracking-[0.2em] text-slate-500\">Production-ready freight platform</p><h1 class=\"mt-4 max-w-3xl text-4xl font-semibold text-slate-900 md:text-5xl\">INFÆMOUS FREIGHT<!-- --> <!-- -->Dispatcher</h1><p class=\"mt-4 max-w-2xl text-base text-slate-600\">Freight orchestration for teams that move faster than the market.</p><p class=\"mt-2 max-w-2xl text-sm text-slate-500\">Unify quoting, dispatch, live visibility, and exception handling into one production-ready operating surface.</p><div class=\"mt-8 grid gap-4 md:grid-cols-3\"><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><p class=\"text-3xl font-semibold text-slate-900\">24k+</p><p class=\"mt-1 text-xs uppercase tracking-[0.18em] text-slate-500\">Weekly loads automated</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><p class=\"text-3xl font-semibold text-slate-900\">&lt; 2 min</p><p class=\"mt-1 text-xs uppercase tracking-[0.18em] text-slate-500\">Average response time</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><p class=\"text-3xl font-semibold text-slate-900\">+18%</p><p class=\"mt-1 text-xs uppercase tracking-[0.18em] text-slate-500\">Tender acceptance uplift</p></article></div></div></section><section class=\"py-12\"><div class=\"mx-auto w-full max-w-6xl px-6\"><h2 class=\"text-2xl font-semibold text-slate-900\">Core operations palette</h2><p class=\"mt-2 text-sm text-slate-600\">Every workflow block is composed for dispatchers first, then hardened for real production traffic.</p><div class=\"mt-6 grid gap-4 md:grid-cols-3\"><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Shipper intake</h3><p class=\"mt-2 text-sm text-slate-600\">Capture inbound requests, normalize lane details, and auto-score opportunities in one pass.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Carrier matching</h3><p class=\"mt-2 text-sm text-slate-600\">Prioritize carriers by lane performance, margin guardrails, and service-level history.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Exception intelligence</h3><p class=\"mt-2 text-sm text-slate-600\">Route disruptions trigger AI playbooks, owner handoff, and customer-safe communication.</p></article></div></div></section><section class=\"py-12\"><div class=\"mx-auto w-full max-w-6xl px-6\"><h2 class=\"text-2xl font-semibold text-slate-900\">Dispatcher dashboard</h2><p class=\"mt-2 text-sm text-slate-600\">A single control surface for live metrics, critical alerts, and high-confidence next actions.</p><div class=\"mt-6 grid gap-4 md:grid-cols-2\"><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Live board health</h3><p class=\"mt-2 text-sm text-slate-600\">Track lane fill rates, spot-market volatility, and SLA risk with minute-level freshness.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Decision queue</h3><p class=\"mt-2 text-sm text-slate-600\">Prioritized cards highlight where human intervention has the highest margin impact.</p></article></div></div></section><section class=\"py-12\"><div class=\"mx-auto w-full max-w-6xl px-6\"><h2 class=\"text-2xl font-semibold text-slate-900\">Loadboard intelligence</h2><p class=\"mt-2 text-sm text-slate-600\">Surface winning opportunities fast with lane-level context, historical price memory, and timing recommendations.</p><div class=\"mt-6 grid gap-4 md:grid-cols-2\"><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Lane confidence scoring</h3><p class=\"mt-2 text-sm text-slate-600\">Each posting is ranked by margin potential, equipment fit, and probability of fast tender acceptance.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Automated outreach</h3><p class=\"mt-2 text-sm text-slate-600\">Generate shipper-safe and carrier-safe communications with templated compliance controls.</p></article></div></div></section><section class=\"py-12 pb-16\"><div class=\"mx-auto w-full max-w-6xl px-6\"><h2 class=\"text-2xl font-semibold text-slate-900\">System guarantees</h2><p class=\"mt-2 text-sm text-slate-600\">Infrastructure and workflow conventions designed for dependable operations under load.</p><div class=\"mt-6 grid gap-4 md:grid-cols-3\"><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Auditability</h3><p class=\"mt-2 text-sm text-slate-600\">Action logs and decisions are traceable for compliance, customer communication, and post-mortems.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Role-safe access</h3><p class=\"mt-2 text-sm text-slate-600\">Scoped permissions keep brokers, dispatchers, and admins inside clearly bounded workflows.</p></article><article class=\"rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm backdrop-blur-sm\"><h3 class=\"text-lg font-semibold text-slate-900\">Resilient defaults</h3><p class=\"mt-2 text-sm text-slate-600\">Fallback states preserve velocity during upstream outages, delayed status events, or API failures.</p></article></div></div></section></main><!--$--><!--/$--></main><footer class=\"border-t border-gray-200 bg-gray-50\"><div class=\"mx-auto max-w-7xl px-6 py-12 lg:px-8\"><div class=\"grid grid-cols-2 gap-8 md:grid-cols-4\"><div><h3 class=\"text-sm font-semibold text-gray-900\">Product</h3><ul class=\"mt-4 space-y-2 text-sm text-gray-600\"><li><a href=\"/pricing\" class=\"hover:text-gray-900\">Pricing</a></li><li><a href=\"/dashboard\" class=\"hover:text-gray-900\">Dashboard</a></li><li><a href=\"#features\" class=\"hover:text-gray-900\">Features</a></li></ul></div><div><h3 class=\"text-sm font-semibold text-gray-900\">Company</h3><ul class=\"mt-4 space-y-2 text-sm text-gray-600\"><li><a href=\"/about\" class=\"hover:text-gray-900\">About</a></li><li><a href=\"/contact\" class=\"hover:text-gray-900\">Contact</a></li></ul></div><div><h3 class=\"tex