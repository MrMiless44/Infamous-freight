# ─────────────────────────────────────────────────────────────────────────────
# Infæmous Freight – apps/web Netlify Environment Variables
#
# Copy these into Netlify → Site Settings → Environment Variables.
# NEVER commit actual values to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node / Build ──────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
BUILD_TARGET=netlify
# Allow TS build errors to be bypassed during initial deploy if needed (set to false for strict)
ALLOW_WEB_TS_ERRORS=false

# ── Primary Frontend Domain ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.infamousfreight.com

# ── Backend API (Express on api.infamousfreight.com) ─────────────────────────
# Used by api-client.implementation.ts and lib/api.ts
NEXT_PUBLIC_API_BASE_URL=https://api.infamousfreight.com
# Legacy origin alias (bare API origin without /api suffix)
NEXT_PUBLIC_API_URL=https://api.infamousfreight.com
# Server-side only (not exposed to browser)
API_BASE_URL=https://api.infamousfreight.com

# ── WebSocket (real-time updates) ─────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=wss://api.infamousfreight.com/ws

# ── AI API ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AI_API_URL=https://api.infamousfreight.com
NEXT_PUBLIC_AI_BASE_URL=https://api.infamousfreight.com

# ── Authentication ────────────────────────────────────────────────────────────
# NextAuth or custom JWT – update to match your auth implementation
NEXTAUTH_URL=https://www.infamousfreight.com
NEXTAUTH_SECRET=<replace-with-long-random-value-minimum-32-characters>
JWT_SECRET=<replace-with-long-random-value-minimum-32-characters>

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<your-stripe-publishable-key>
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>
SENTRY_ORG=infamous-freight-enterprise
SENTRY_PROJECT=javascript-nextjs

# ── App Metadata ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Infæmous Freight
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── LaunchDarkly (Netlify Integration) ───────────────────────────────────────
# Configure Site ID + Syncing token in LaunchDarkly Integrations UI.
# Keep syncing credentials in LaunchDarkly only; do not store them in this repo.
LAUNCHDARKLY_CLIENT_SIDE_ID=<launchdarkly-client-side-id>
LAUNCHDARKLY_FLAG_KEY=enableMyNewFeature
