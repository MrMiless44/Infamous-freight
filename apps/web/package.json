  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:sentry": "SENTRY_RELEASE=$(git rev-parse HEAD) next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:security": "vitest run tests/security.test.ts",
    "test:watch": "vitest watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "sentry:sourcemaps": "sentry-cli sourcemaps upload --release=$SENTRY_RELEASE .next",
    "sentry:release": "sentry-cli releases new $SENTRY_RELEASE && sentry-cli releases set-commits $SENTRY_RELEASE --auto && sentry-cli releases finalize $SENTRY_RELEASE"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.33.0",
