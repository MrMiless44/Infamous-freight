    "mapbox-gl": "^3.18.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.7.0",
    "stripe": "^20.3.0",
    "styled-jsx": "^5.1.7",
    "zod": "^4.3.6"
  },
