{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "nodeVersion": "24.x",
  "installCommand": "corepack enable && cd .. && pnpm install --frozen-lockfile",
  "buildCommand": "cd .. && pnpm -r --filter @infamous-freight/shared build && pnpm --filter web build",
  "outputDirectory": ".next",
  "functions": {
    "pages/api/**/*.{js,ts}": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/supabase/:path*",
      "destination": "https://supabase.com/:path*"
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_ENV": "production"
    }
  },
  "crons": []
}
