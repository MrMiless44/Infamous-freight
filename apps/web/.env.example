# Infamous Freight — Web Frontend Environment
# Leave VITE_API_URL unset (or empty) to use the Vite dev-server proxy, which
# forwards /api/* to http://localhost:3001 automatically. Set it to an absolute
# URL only when running the built app without the Vite proxy.
VITE_API_URL=
VITE_SITE_URL=https://infamousfreight.com
# Optional: leave unset to reuse VITE_API_URL / same-origin proxying for sockets.
# Set this only if websocket traffic must use a different absolute origin.
VITE_SOCKET_URL=
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
VITE_SUPABASE_URL=https://wnaievjffghrztjuvutp.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_A--wLALxTW5UkOcgFnubLQ_SX_knoSR
# Backward compatibility for older setups:
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry error monitoring
# apps/web is a Vite + React app. Do not use the Vue or Next.js Sentry wizard here.
VITE_SENTRY_DSN=https://<public-key>@o<org-id>.ingest.us.sentry.io/<project-id>
# Set to "false" to disable Sentry even when a DSN is present.
# Defaults to enabled in production when DSN is set.
VITE_SENTRY_ENABLED=true

# Sentry source map uploads for production builds
# Configure these in CI/deployment settings. Never commit a real SENTRY_AUTH_TOKEN.
SENTRY_ORG=infmous
SENTRY_PROJECT=infamous-freight
SENTRY_AUTH_TOKEN=your-sentry-auth-token
