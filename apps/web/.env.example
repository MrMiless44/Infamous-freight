# Web/Frontend Environment Configuration

# ============================================
# Next.js Configuration
# ============================================
NODE_ENV=development

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_NAME=Infæmous Freight
NEXT_PUBLIC_ENV=development
# Base URL of the web app; use http://localhost:3000 for local dev and override with your production URL (e.g. Vercel) in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEB_PORT=3000

# ============================================
# API Configuration
# ============================================
# Internal API URL (server-side)
API_BASE_URL=http://localhost:4000/api

# Public API URL (client-side/browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_API_URL=https://infamous-freight-api.fly.dev

# ============================================
# Authentication
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_long_random_value_minimum_32_characters
JWT_SECRET=replace_with_long_random_value_minimum_32_characters

# ============================================
# Supabase (Authentication & Database)
# ============================================
# Supabase project URL (e.g., https://xxxxxxxxxxx.supabase.co)
# Get from: https://supabase.com/dashboard → Select Project → Settings → API
# For builds without Supabase, use: https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co

# Supabase anon key (public key for client-side auth)
# Get from: https://supabase.com/dashboard → Select Project → Settings → API → anon key
# For builds without Supabase, use: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder

# Supabase project ref (optional, for direct reference)
# Format: first part of the URL before .supabase.co
NEXT_PUBLIC_SUPABASE_PROJECT_REF=xxxxxxxxxxx

# ============================================
# OAuth Configuration (Supabase Auth)
# ============================================
# GitHub OAuth (optional, for GitHub sign-in)
# Create app at: https://github.com/settings/developers
# Then add to Supabase: https://supabase.com/dashboard → Authentication → OAuth Providers → GitHub
# Note: Client ID and Secret are managed in Supabase dashboard

# Google OAuth (optional, for Google sign-in)
# Create credentials at: https://console.cloud.google.com
# Then add to Supabase: https://supabase.com/dashboard → Authentication → OAuth Providers → Google
# Note: Client ID and Secret are managed in Supabase dashboard

# ============================================
# Payment Processing (Public Keys)
# ============================================
# Use your Stripe TEST publishable key in development; ensure it matches the mode of your backend Stripe keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ============================================
# Maps & Geolocation
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ============================================
# Analytics
# ============================================
# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Plausible (Privacy-friendly alternative)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_ENABLED=false

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# ============================================
# Error Tracking & Performance
# ============================================
# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog RUM
NEXT_PUBLIC_DD_APP_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=datadoghq.com
NEXT_PUBLIC_DD_SERVICE=infamous-freight-web
NEXT_PUBLIC_DD_ENV=development
NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=100
NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=20

# ============================================
# Feature Flags
# ============================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ENABLE_A_B_TESTING=false
NEXT_PUBLIC_ENABLE_CHAT_SUPPORT=true

# ============================================
# OAuth Providers
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# SEO & Meta
# ============================================
NEXT_PUBLIC_META_TITLE=Infamous Freight Enterprises | Global Logistics
NEXT_PUBLIC_META_DESCRIPTION=Enterprise freight management platform serving 120+ countries
NEXT_PUBLIC_OG_IMAGE=https://infamousfreight.com/og-image.png
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Email Configuration
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@infamousfreight.com

# ============================================
# CDN & Assets
# ============================================
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_ASSETS_URL=/

# ============================================
# Vercel Edge Infrastructure
# ============================================
# Edge Config (Feature Flags)
# Get from: Vercel Dashboard → Storage → Edge Config → Connection String
EDGE_CONFIG=

# KV Store (Redis) - Distributed Caching
# Get from: Vercel Dashboard → Storage → Redis → Environment Variables
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ============================================
# Development Settings
# ============================================
ANALYZE=false
NEXT_TELEMETRY_DISABLED=1
