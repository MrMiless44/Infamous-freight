#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "==> pre-commit-docs"

DOC_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '(^README\.md$|^docs/|\.md$)' || true)"

if [ -z "$DOC_FILES" ]; then
  echo "No docs files staged."
  exit 0
fi

echo "==> Formatting docs"
echo "$DOC_FILES" | tr '\n' '\0' | xargs -0 pnpm exec prettier --write
echo "$DOC_FILES" | tr '\n' '\0' | xargs -0 git add

if [ -f package.json ]; then
  if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts['lint:docs'] ? 0 : 1)" 2>/dev/null; then
    echo "==> Running docs lint"
    pnpm run lint:docs
  fi
fi

echo "✅ docs hook passed"
