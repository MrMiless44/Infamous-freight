#!/bin/bash
# .githooks/pre-commit-docs
# Prevents committing documentation status files and build logs
# Enable with: git config core.hooksPath .githooks

echo "🔍 Checking for documentation standards violations..."

VIOLATIONS=0

# Patterns that should NOT be committed
FORBIDDEN_PATTERNS=(
  "*_STATUS\.md"
  "*_COMPLETE\.md"
  "*_100\.md"
  "*_FINAL\.md"
  "\.log$"
  "build-.*\.txt"
  "deployment-.*\.log"
  "*_RECOMMENDED_RECOMMENDED\.md"
)

# Check staged files
STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
  for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ $file =~ $pattern ]]; then
      echo "❌ VIOLATION: $file matches forbidden pattern: $pattern"
      VIOLATIONS=$((VIOLATIONS + 1))
    fi
  done
done

if [ $VIOLATIONS -gt 0 ]; then
  echo ""
  echo "⚠️  COMMIT BLOCKED: $VIOLATIONS documentation violation(s) found"
  echo ""
  echo "📖 Documentation Standards:"
  echo "   • Use '-RECOMMENDED' suffix for active documentation"
  echo "   • No status files (*_STATUS, *_COMPLETE, *_100)"
  echo "   • No build logs (*.log files)"
  echo "   • Archive old docs to /archive directory"
  echo ""
  echo "📚 See DOCUMENTATION_STANDARDS-RECOMMENDED.md for details"
  echo ""
  echo "To override: git commit --no-verify"
  exit 1
fi

echo "✅ Documentation standards check passed"
exit 0
