# ═══════════════════════════════════════════════════════════════════
# TIER 1-5 PRODUCTION ENVIRONMENT CONFIGURATION
# All Branches Green 100% - Complete Enterprise Infrastructure
# ═══════════════════════════════════════════════════════════════════
# Generated: 2026-02-17
# Status: Production Ready
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# 🏗️ TIER 1: CRITICAL INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════════

# PostgreSQL HA (Patroni) Configuration
PATRONI_NAMESPACE=/service/infamous-freight
PATRONI_SCOPE=infamous-freight-cluster
PATRONI_NAME=postgresql-node-1
PATRONI_POSTGRESQL_DATA_DIR=/var/lib/postgresql/15/main
PATRONI_POSTGRESQL_BIN_DIR=/usr/lib/postgresql/15/bin
PATRONI_POSTGRESQL_LISTEN=0.0.0.0:5432
PATRONI_ETCD_HOST=etcd:2379
PATRONI_RESTAPI_LISTEN=0.0.0.0:8008

# PgBouncer Connection Pooling
PGBOUNCER_DATABASE_URL=postgres://infamous:password@patroni:5432/infamous_freight
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_LISTEN_ADDR=0.0.0.0
PGBOUNCER_LISTEN_PORT=6432

# Loki Log Aggregation
LOKI_URL=http://loki:3100
LOKI_RETENTION_PERIOD=720h
LOKI_CHUNK_IDLE_PERIOD=30m
LOKI_MAX_CHUNK_AGE=1h
PROMTAIL_LOKI_URL=http://loki:3100/loki/api/v1/push

# Jaeger Distributed Tracing
JAEGER_AGENT_HOST=jaeger-agent
JAEGER_AGENT_PORT=6831
JAEGER_COLLECTOR_ENDPOINT=http://jaeger-collector:14268/api/traces
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1
JAEGER_SERVICE_NAME=infamous-freight-api
JAEGER_DISABLED=false

# HashiCorp Vault Secret Management
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=s.xxxxxxxxxxxxxxxxxxxxxxxx
VAULT_NAMESPACE=infamous-freight
VAULT_PATH_PREFIX=secret/data/infamous-freight
VAULT_AUTH_METHOD=jwt
VAULT_ROLE=api-service
VAULT_SECRET_ROTATION_ENABLED=true
VAULT_SECRET_ROTATION_INTERVAL=7d

# ═══════════════════════════════════════════════════════════════════
# ⚡ TIER 2: PERFORMANCE OPTIMIZATION
# ═══════════════════════════════════════════════════════════════════

# Query Optimization Service
QUERY_OPTIMIZATION_ENABLED=true
QUERY_OPTIMIZATION_SLOW_QUERY_THRESHOLD=1000
QUERY_OPTIMIZATION_N_PLUS_ONE_DETECTION=true
QUERY_OPTIMIZATION_MISSING_INDEX_DETECTION=true
QUERY_OPTIMIZATION_AUTO_SUGGEST=true
QUERY_OPTIMIZATION_CACHE_TTL=3600

# Asset Optimization Service
ASSET_OPTIMIZATION_ENABLED=true
ASSET_OPTIMIZATION_WEBP_QUALITY=80
ASSET_OPTIMIZATION_IMAGE_MAX_WIDTH=2560
ASSET_OPTIMIZATION_IMAGE_MAX_HEIGHT=2560
ASSET_OPTIMIZATION_RESPONSIVE_SIZES=320,640,768,1024,1366,1920
ASSET_OPTIMIZATION_CDN_URL=https://cdn.infamousfreight.com
ASSET_OPTIMIZATION_CACHE_CONTROL=public, max-age=31536000, immutable

# Cost Optimization Service
COST_OPTIMIZATION_ENABLED=true
COST_OPTIMIZATION_AWS_REGION=us-east-1
COST_OPTIMIZATION_AWS_ACCESS_KEY_ID=AKIA_YOUR_KEY_HERE
COST_OPTIMIZATION_AWS_SECRET_ACCESS_KEY=your_secret_key_here
COST_OPTIMIZATION_FORECAST_DAYS=90
COST_OPTIMIZATION_ALERT_THRESHOLD=2700
COST_OPTIMIZATION_ANOMALY_DETECTION=true
COST_OPTIMIZATION_ANOMALY_THRESHOLD_PERCENTAGE=25

# ═══════════════════════════════════════════════════════════════════
# 🔒 TIER 3: SECURITY & COMPLIANCE
# ═══════════════════════════════════════════════════════════════════

# Kong API Gateway
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://kong:8000
KONG_ADMIN_TOKEN=your_kong_admin_token_here
KONG_RATE_LIMIT_MINUTE=1000
KONG_RATE_LIMIT_HOUR=10000
KONG_API_KEY_HEADER=X-API-Key
KONG_ENABLE_CORS=true
KONG_ENABLE_ACL=true
KONG_ENABLE_JWT=true

# Compliance Audit Service
COMPLIANCE_ENABLED=true
COMPLIANCE_GDPR_ENABLED=true
COMPLIANCE_SOC2_ENABLED=true
COMPLIANCE_AUDIT_LOG_RETENTION_DAYS=2555
COMPLIANCE_DATA_RETENTION_DAYS=365
COMPLIANCE_RIGHT_TO_FORGET_AUTO=true
COMPLIANCE_DATA_PORTABILITY_FORMAT=json
COMPLIANCE_SUSPICIOUS_ACTIVITY_THRESHOLD=5
COMPLIANCE_AUDIT_EXPORT_PATH=/var/exports/compliance

# ═══════════════════════════════════════════════════════════════════
# 🌍 TIER 4: MULTI-REGION & SCALING
# ═══════════════════════════════════════════════════════════════════

# Multi-Region Terraform Configuration
AWS_REGION_PRIMARY=us-east-1
AWS_REGION_REPLICA_1=eu-west-1
AWS_REGION_REPLICA_2=ap-northeast-1
AWS_GLOBAL_ACCELERATOR_ENABLED=true
AWS_ROUTE53_FAILOVER_ENABLED=true
AWS_AURORA_GLOBAL_DB_ENABLED=true
AWS_CROSS_REGION_REPLICATION_ENABLED=true
AWS_CLOUDFRONT_ENABLED=true

# Feature Flags Service (Unleash)
UNLEASH_URL=http://unleash:4242
UNLEASH_API_TOKEN=your_unleash_api_token_here
UNLEASH_APP_NAME=infamous-freight
UNLEASH_INSTANCE_ID=api-production-1
UNLEASH_ENVIRONMENT=production
UNLEASH_REFRESH_INTERVAL=15000
# Gradual Rollout Percentages
UNLEASH_ROLLOUT_CANARY=1
UNLEASH_ROLLOUT_SMALL=5
UNLEASH_ROLLOUT_MEDIUM=10
UNLEASH_ROLLOUT_LARGE=25
UNLEASH_ROLLOUT_HALF=50
UNLEASH_ROLLOUT_FULL=100

# Real-Time Notification Service
NOTIFICATION_ENABLED=true
NOTIFICATION_WEBSOCKET_PORT=8080
NOTIFICATION_RABBITMQ_URL=amqp://rabbitmq:5672
NOTIFICATION_RABBITMQ_EXCHANGE=notifications
NOTIFICATION_RABBITMQ_QUEUE=notification-queue
NOTIFICATION_RABBITMQ_PREFETCH=10
NOTIFICATION_RETRY_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BACKOFF_MS=1000
# Notification Channels
NOTIFICATION_PUSH_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_WEBHOOK_ENABLED=true
# Firebase Cloud Messaging (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════
# 🤖 TIER 5: ML & BUSINESS INTELLIGENCE
# ═══════════════════════════════════════════════════════════════════

# ML Anomaly Detection Service
ML_ANOMALY_DETECTION_ENABLED=true
ML_ANOMALY_ZSCORE_THRESHOLD=3
ML_ANOMALY_IQR_MULTIPLIER=1.5
ML_ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.1
ML_ANOMALY_ISOLATION_FOREST_ESTIMATORS=100
ML_ANOMALY_ARIMA_ORDER=1,1,1
ML_ANOMALY_DETECTION_WINDOW_HOURS=24
ML_ANOMALY_MINIMUM_DATA_POINTS=30

# Business Intelligence Service
BI_ENABLED=true
BI_DASHBOARD_REFRESH_INTERVAL=300000
BI_METRIC_RETENTION_DAYS=730
BI_EXPORT_FORMAT=json
BI_EXPORT_PATH=/var/exports/bi
# Metric Thresholds
BI_REVENUE_TARGET_MONTHLY=500000
BI_ERROR_RATE_THRESHOLD=0.001
BI_RESPONSE_TIME_TARGET=255
BI_CUSTOMER_SATISFACTION_TARGET=4.5

# ═══════════════════════════════════════════════════════════════════
# 🔄 CI/CD & DEPLOYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Deployment Strategy
DEPLOYMENT_STRATEGY=canary
DEPLOYMENT_CANARY_PERCENTAGE=5
DEPLOYMENT_CANARY_DURATION=900000
DEPLOYMENT_ROLLING_PERCENTAGE=25
DEPLOYMENT_ROLLING_DURATION=1800000
DEPLOYMENT_HEALTH_CHECK_INTERVAL=5000
DEPLOYMENT_HEALTH_CHECK_TIMEOUT=30000
DEPLOYMENT_ROLLBACK_ON_ERROR_RATE=0.01
DEPLOYMENT_ROLLBACK_ON_LATENCY_MS=1000

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=4000
HEALTH_CHECK_PATH=/api/health
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_VAULT=true
HEALTH_CHECK_EXTERNAL_SERVICES=true

# ═══════════════════════════════════════════════════════════════════
# 📊 MONITORING & OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION=30d

# Grafana Dashboards
GRAFANA_ENABLED=true
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_DATASOURCE_PROMETHEUS=http://prometheus:9090
GRAFANA_DATASOURCE_LOKI=http://loki:3100

# Alert Manager
ALERTMANAGER_ENABLED=true
ALERTMANAGER_URL=http://alertmanager:9093
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERTMANAGER_EMAIL_TO=ops@infamousfreight.com
ALERTMANAGER_EMAIL_FROM=alerts@infamousfreight.com

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/PROJECT_ID
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENABLE_TRACING=true

# Datadog APM
DD_AGENT_HOST=datadog-agent
DD_TRACE_ENABLED=true
DD_SERVICE=infamous-freight-api
DD_ENV=production
DD_VERSION=1.0.0
DD_RUNTIME_METRICS_ENABLED=true
DD_PROFILING_ENABLED=true
DD_TRACE_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════════════════════
# 🎯 PERFORMANCE TARGETS & SLA
# ═══════════════════════════════════════════════════════════════════

# API Performance Targets
TARGET_LATENCY_P50=50
TARGET_LATENCY_P95=150
TARGET_LATENCY_P99=255
TARGET_ERROR_RATE=0.001
TARGET_UPTIME=0.9999
TARGET_THROUGHPUT_RPS=5000

# Database Performance Targets
TARGET_DB_QUERY_P99=100
TARGET_DB_CONNECTION_POOL_UTILIZATION=0.7
TARGET_DB_REPLICATION_LAG=1
TARGET_DB_SLOW_QUERY_THRESHOLD=1000

# Infrastructure Performance Targets
TARGET_CPU_UTILIZATION=0.7
TARGET_MEMORY_UTILIZATION=0.8
TARGET_DISK_UTILIZATION=0.85
TARGET_NETWORK_UTILIZATION=0.5

# ═══════════════════════════════════════════════════════════════════
# 💰 COST OPTIMIZATION & BUDGETS
# ═══════════════════════════════════════════════════════════════════

# Monthly Budget Targets (USD)
BUDGET_TOTAL_MONTHLY=1100
BUDGET_COMPUTE_MONTHLY=400
BUDGET_DATABASE_MONTHLY=300
BUDGET_STORAGE_MONTHLY=150
BUDGET_NETWORKING_MONTHLY=100
BUDGET_MONITORING_MONTHLY=50
BUDGET_EXTERNAL_SERVICES_MONTHLY=100

# Cost Optimization Features
ENABLE_RESERVED_INSTANCES=true
ENABLE_SPOT_INSTANCES=true
ENABLE_AUTO_SCALING=true
ENABLE_HIBERNATION=true
ENABLE_S3_LIFECYCLE_POLICIES=true
ENABLE_CLOUDFRONT_COMPRESSION=true

# ═══════════════════════════════════════════════════════════════════
# 🔐 SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Security Headers
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# DDoS Protection
DDOS_PROTECTION_ENABLED=true
DDOS_CLOUDFLARE_ENABLED=true
DDOS_AWS_SHIELD_ENABLED=true
DDOS_AWS_WAF_ENABLED=true

# ═══════════════════════════════════════════════════════════════════
# 🚀 PRODUCTION DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════

# Pre-Deployment
# ✅ All environment variables configured
# ✅ Secrets stored in Vault
# ✅ Database backups completed
# ✅ Migration scripts tested
# ✅ Performance tests passed
# ✅ Security audit completed
# ✅ Documentation updated
# ✅ Team trained and ready

# Deployment Steps
# 1. Verify all services healthy
# 2. Enable maintenance mode (optional)
# 3. Run database migrations
# 4. Deploy canary (5% traffic)
# 5. Monitor for 15 minutes
# 6. Deploy rolling (25% traffic)
# 7. Monitor for 30 minutes
# 8. Deploy full (100% traffic)
# 9. Monitor continuously

# Post-Deployment
# ✅ Health checks passing
# ✅ Metrics within targets
# ✅ Error rates normal
# ✅ Performance acceptable
# ✅ Security monitoring active
# ✅ Compliance verified
# ✅ Business metrics tracked
# ✅ Team notified

# ═══════════════════════════════════════════════════════════════════
# 📞 SUPPORT & ESCALATION
# ═══════════════════════════════════════════════════════════════════

# On-Call Configuration
ONCALL_ENABLED=true
ONCALL_PAGERDUTY_API_KEY=your_pagerduty_api_key_here
ONCALL_PAGERDUTY_SERVICE_ID=PXXXXXX
ONCALL_SLACK_CHANNEL=#incidents
ONCALL_ESCALATION_TIMEOUT=900000

# Support Contacts
SUPPORT_EMAIL=support@infamousfreight.com
SUPPORT_PHONE=+1-800-FREIGHT
SUPPORT_SLACK_CHANNEL=#support
SUPPORT_JIRA_PROJECT=SUP

