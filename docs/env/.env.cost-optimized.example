# Cost Optimization Environment Variables
# Complete configuration for all cost-saving optimizations
# Estimated savings: $285/month ($3,420/year)

# =============================================================================
# AWS SES Configuration (Replaces SendGrid - Saves $20/month)
# =============================================================================
# AWS SES credentials (free tier: 62,000 emails/month)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=AKIA...
AWS_SES_SECRET_KEY=...
AWS_SES_FROM_EMAIL=noreply@infamousfreight.com
AWS_SES_FROM_NAME=Infamous Freight

# Legacy SendGrid (deprecated - migrate to AWS SES)
# SENDGRID_API_KEY=SG...  # Can be removed after migration
# SENDGRID_FROM_EMAIL=noreply@infamousfreight.com

# =============================================================================
# Sentry Optimization (Free tier - Saves $22/month)
# =============================================================================
SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% sampling (down from 100%)
SENTRY_ENVIRONMENT=production
# Free tier limit: 10K events/month
# Optimized to capture only 5xx errors + 10% trace sampling

# =============================================================================
# Plaid Configuration (Bank Transfers - Saves $50/month)
# =============================================================================
# Plaid for bank account verification (0% fees vs 2.9% cards)
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox  # or 'production'
PLAID_WEBHOOK_URL=https://api.infamousfreight.com/webhooks/plaid
# Target: 20% adoption = $50/month savings

# =============================================================================
# AI Provider Optimization (95% Synthetic - Saves $12/month)
# =============================================================================
AI_PROVIDER=synthetic  # 'synthetic', 'openai', or 'anthropic'
AI_SYNTHETIC_MODE=enhanced  # Use enhanced templates
AI_OPENAI_FALLBACK_RATE=0.05  # Only 5% use real OpenAI (high complexity)
# Reduces OpenAI usage from 90% to 5%

# OpenAI (used for 5% of complex requests only)
OPENAI_API_KEY=sk_live_...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (backup provider)
ANTHROPIC_API_KEY=sk_ant_...

# =============================================================================
# Redis Caching Configuration (Saves $35/month on external APIs)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_CACHE_ENABLED=true
REDIS_DEFAULT_TTL=300  # 5 minutes

# Cache TTL per endpoint (seconds)
CACHE_TTL_ROUTING=300     # 5 min
CACHE_TTL_WEATHER=1800    # 30 min
CACHE_TTL_SHIPMENTS=60    # 1 min
CACHE_TTL_AI=0            # No cache
# Target: 40-60% cache hit rate

# =============================================================================
# Batch Queue Configuration (Saves $30/month on API calls)
# =============================================================================
BATCH_QUEUE_ENABLED=true
BATCH_SIZE_MAPBOX=10      # Batch 10 routing requests
BATCH_SIZE_AI=5           # Batch 5 AI requests
BATCH_FLUSH_INTERVAL=1000 # 1 second
# Target: 80% batch efficiency

# =============================================================================
# Stripe Optimization (Volume Discount - Saves $20/month)
# =============================================================================
# Negotiated rate: 2.7% + $0.25 (down from 2.9% + $0.30)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_RATE_PERCENTAGE=0.027  # Negotiated rate
STRIPE_RATE_FIXED=0.25        # Negotiated rate

# =============================================================================
# Railway Configuration (Replaces Fly.io - Saves $70/month)
# =============================================================================
# Railway: $30/month vs Fly.io $108/month
RAILWAY_PROJECT_ID=...
RAILWAY_TOKEN=...
DATABASE_URL=postgresql://...  # Railway managed PostgreSQL
# Note: Migrate from Fly.io to Railway in Phase 2

# =============================================================================
# Upstash Redis (Replaces Fly.io Redis - Saves $10/month)
# =============================================================================
# Upstash: $8/month vs Fly.io $12/month
UPSTASH_REDIS_URL=redis://...
UPSTASH_REDIS_TOKEN=...
# Note: Migrate from Fly.io Redis to Upstash in Phase 2

# =============================================================================
# Backup Strategy Optimization (Saves $8/month)
# =============================================================================
# Use Fly.io/Railway native backups (included)
# S3 only for weekly cold storage
BACKUP_STRATEGY=native  # 'native' or 's3'
BACKUP_S3_BUCKET=infamous-freight-backups-cold
BACKUP_FREQUENCY=weekly  # Down from 'hourly'
BACKUP_RETENTION_DAYS=90
# S3 storage class: GLACIER_IR (saves 68%)

# =============================================================================
# Cost Monitoring & Alerts
# =============================================================================
COST_ALERT_THRESHOLD_MONTHLY=2700  # Alert at $2,700/month (11% over target)
COST_ALERT_EMAIL=admin@infamousfreight.com
COST_TRACKING_ENABLED=true

# =============================================================================
# Feature Flags for Cost Optimizations
# =============================================================================
FEATURE_AWS_SES_ENABLED=true          # AWS SES email
FEATURE_BANK_TRANSFER_ENABLED=true    # Bank transfers
FEATURE_AI_SYNTHETIC_ENHANCED=true    # Enhanced synthetic AI
FEATURE_REDIS_CACHE_ENABLED=true      # Redis caching
FEATURE_BATCH_QUEUE_ENABLED=true      # Request batching
FEATURE_SENTRY_OPTIMIZED=true         # Optimized Sentry

# =============================================================================
# Monitoring & Verification
# =============================================================================
# Verify optimizations are working
LOG_LEVEL=info
ENABLE_COST_LOGGING=true
ENABLE_CACHE_STATS=true
ENABLE_BATCH_STATS=true

# =============================================================================
# OPTIMIZATION SUMMARY
# =============================================================================
# Phase 1 (Week 1):
#   - AWS SES: -$20/month
#   - Sentry downgrade: -$22/month
#   - Bank transfer: -$50/month
#   - AI synthetic: -$12/month
#   Subtotal: -$104/month
#
# Phase 2 (Weeks 2-4):
#   - Stripe negotiation: -$20/month
#   - Railway migration: -$70/month
#   - S3 optimization: -$8/month
#   Subtotal: -$98/month
#
# Phase 3 (Months 2-3):
#   - API caching: -$35/month
#   - Request batching: -$30/month
#   Subtotal: -$65/month
#
# TOTAL MONTHLY SAVINGS: -$267/month
# TOTAL ANNUAL SAVINGS: -$3,204/year
# OPTIMIZED COST: $2,160/month (vs $2,427 before)
