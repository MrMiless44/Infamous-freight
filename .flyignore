# Minimal Fly.io ignore list for monorepo builds.
# Keep workspace manifests and source trees available to Docker COPY steps.

# VCS + local tooling
.git/
.github/
.devcontainer/
.codex/
.vscode/
.idea/
.githooks/
.husky/
.githooks/
.husky/

# Dependency caches and local artifacts
node_modules/
**/node_modules/
.pnpm-store/
.turbo/
.cache/

# Test/build outputs
coverage/
**/coverage/
**/.next/
**/dist/
**/build/

# Logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store

# Local environment overrides (keep .env.example)
.env
.env.*
!.env.example
