# Firebase Environment Configuration Template
# Copy this to .env and fill in your values

# ==================================================
# FIREBASE CONFIGURATION
# ==================================================

# Project Configuration
FIREBASE_PROJECT_ID=infamous-freight-prod
FIREBASE_STORAGE_BUCKET=infamous-freight-prod.appspot.com
FIREBASE_DATABASE_URL=https://infamous-freight-prod-default-rtdb.firebaseio.com

# Service Account (Backend Only)
# Option 1: Provide path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Or provide the entire JSON as a string (escape quotes)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"..."}'

# ==================================================
# MOBILE APP CONFIGURATION  
# ==================================================

# Firebase Web/Mobile Configuration
# Get these from Firebase Console → Project Settings → General → Your apps
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=infamous-freight-prod.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Web Push Notifications (VAPID Key)
# Get from: Firebase Console → Cloud Messaging → Web Push certificates → Generate Key Pair
FIREBASE_VAPID_KEY=BNXXXXXXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Expo Configuration
EXPO_PROJECT_ID=your-expo-project-id-here

# ==================================================
# iOS APNs CONFIGURATION
# ==================================================

# Apple Developer Team ID (10 characters)
# Find at: https://developer.apple.com/account
APNS_TEAM_ID=XXXXXXXXXX

# APNs Key ID (10 characters)
# From: https://developer.apple.com/account/resources/authkeys/list
APNS_KEY_ID=XXXXXXXXXX

# Path to APNs .p8 file (keep secure, don't commit!)
APNS_KEY_PATH=./apns-key.p8

# Bundle Identifier
IOS_BUNDLE_ID=com.infamousfreight.app

# ==================================================
# ANDROID FCM CONFIGURATION
# ==================================================

# Package name
ANDROID_PACKAGE_NAME=com.infamousfreight.app

# Server Key (legacy, if needed)
# Get from: Firebase Console → Cloud Messaging → Server key
FCM_SERVER_KEY=AAAA_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ==================================================
# FEATURE FLAGS
# ==================================================

# Enable Firebase features
ENABLE_FIREBASE_NOTIFICATIONS=true
ENABLE_FIREBASE_ANALYTICS=true
ENABLE_FIREBASE_CRASHLYTICS=true
ENABLE_FIREBASE_PERFORMANCE=true

# ==================================================
# DEVELOPMENT/TESTING
# ==================================================

# Use Firebase emulators for local development
USE_FIREBASE_EMULATORS=false

# Emulator host URLs (when USE_FIREBASE_EMULATORS=true)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# ==================================================
# MONITORING & ALERTS
# ==================================================

# Slack webhook for Firebase alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty integration key
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key_here

# Email for critical alerts
FIREBASE_ALERT_EMAIL=ops@infamousfreight.com

# ==================================================
# COST MANAGEMENT
# ==================================================

# Daily cost alert threshold (USD)
FIREBASE_DAILY_COST_ALERT=10

# Monthly budget limit (USD)
FIREBASE_MONTHLY_BUDGET=250

# ==================================================
# SECURITY
# ==================================================

# Allowed origins for Firebase (comma-separated)
FIREBASE_ALLOWED_ORIGINS=https://app.infamousfreight.com,https://admin.infamousfreight.com

# Enable Firebase App Check (bot protection)
ENABLE_FIREBASE_APP_CHECK=true

# App Check debug token (development only)
FIREBASE_APP_CHECK_DEBUG_TOKEN=

# ==================================================
# NOTES
# ==================================================

# 1. Never commit the actual .env file or firebase-service-account.json
# 2. Store production credentials in a secure secret manager (Vault, AWS Secrets Manager, 1Password)
# 3. Rotate service account keys every 90 days
# 4. Use different Firebase projects for dev/staging/production
# 5. Monitor costs daily for the first week after deployment

# ==================================================
# MULTI-ENVIRONMENT SETUP
# ==================================================

# For different environments, create:
# - .env.development
# - .env.staging  
# - .env.production

# Then load based on NODE_ENV:
# NODE_ENV=production node app.js
