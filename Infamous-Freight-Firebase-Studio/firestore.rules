rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Basic role helpers using custom claims on the auth token.
    // Assumes a single string role in request.auth.token.role such as "admin" or "driver".
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isDriver() {
      return hasRole("driver");
    }

    // RBAC helpers for shipments
    // For new shipments, ensure the authenticated driver is assigned as driverId.
    function isDriverForNewShipment() {
      return isDriver()
        && request.resource.data.driverId == request.auth.uid;
    }

    // For existing shipments, ensure the authenticated driver matches the stored driverId.
    function isDriverForShipment() {
      return isDriver()
        && resource.data.driverId == request.auth.uid;
    }

    // Shipment field validation helpers
    function isValidShipmentStatus() {
      return request.resource.data.status in [
        "pending",
        "assigned",
        "in_transit",
        "delivered",
        "cancelled"
      ];
    }

    function hasRequiredShipmentFields() {
      // Require at least status and driverId on create.
      return request.resource.data.keys().hasAll(["status", "driverId"]);
    }

    function isValidShipmentCreate() {
      return hasRequiredShipmentFields()
        && isValidShipmentStatus();
    }

    function isValidShipmentUpdate() {
      // Ensure status remains valid and no unexpected fields are introduced.
      // This helps prevent clients from adding arbitrary fields.
      return isValidShipmentStatus()
        && request.resource.data.keys().hasAll(resource.data.keys())
        && resource.data.keys().hasAll(request.resource.data.keys());
    }

    match /shipments/{shipmentId} {
      allow read: if isAuthenticated();
      // Only admins or the assigned driver can create a shipment, with basic field validation.
      allow create: if (isAdmin() || isDriverForNewShipment())
        && isValidShipmentCreate();
      // Only admins or the assigned driver can update a shipment, with field validation.
      allow update: if (isAdmin() || isDriverForShipment())
        && isValidShipmentUpdate();
      // Deletion remains disabled for all users.
      allow delete: if false;
    }

    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
