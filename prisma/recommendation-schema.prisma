// AI-Powered Recommendation System Database Schema
// Recommendation logs, feedback, preferences, and insights

// Recommendation logs - Track all recommendations generated
model RecommendationLog {
  id                   String   @id @default(cuid())
  customerId           String?  // Optional: associated customer
  shipmentId           String?  // Optional: associated shipment
  recommendationType   String   // "service", "route", "driver", "vehicle", "pricing", "personalized"
  context              String   @db.Text // JSON string of input parameters
  recommendations      String   @db.Text // JSON array of generated recommendations
  algorithmVersion     String   @default("1.0.0")
  timestamp            DateTime @default(now())

  @@index([customerId, timestamp])
  @@index([recommendationType, timestamp])
  @@index([timestamp])
  @@map("recommendation_logs")
}

// Recommendation feedback - User feedback for learning
model RecommendationFeedback {
  id                   String   @id @default(cuid())
  recommendationId     String   // References recommendation log
  recommendationType   String   // Type of recommendation
  itemId               String   // ID of recommended item
  action               String   // "accepted", "rejected", "modified"
  rating               Int?     // 1-5 star rating (optional)
  feedback             String?  @db.Text // Text feedback (optional)
  userId               String   // User who provided feedback
  timestamp            DateTime @default(now())

  @@index([recommendationId])
  @@index([recommendationType, action])
  @@index([userId, timestamp])
  @@map("recommendation_feedback")
}

// Customer preferences - Personalization settings
model CustomerPreferences {
  id                      String   @id @default(cuid())
  customerId              String   @unique
  preferredServiceTypes   Json     @default("[]") // Array of preferred service types
  avoidTolls              Boolean  @default(false)
  avoidHighways           Boolean  @default(false)
  preferredFuelType       String?  // "diesel", "electric", "hybrid", etc.
  maxBudgetPerShipment    Float?   // Maximum budget per shipment
  urgencyDefault          String   @default("standard") // "express", "standard", "economy"
  notificationPreferences Json     @default("{}") // Notification settings
  specialRequirements     Json     @default("[]") // Array of special requirements
  loyaltyTier             String   @default("bronze") // "bronze", "silver", "gold", "platinum"
  marketingOptIn          Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([customerId])
  @@index([loyaltyTier])
  @@map("customer_preferences")
}

// Service ratings - Track service performance
model ServiceRating {
  id              String   @id @default(cuid())
  serviceId       String
  serviceName     String
  serviceType     String   // "express", "standard", "economy"
  customerId      String
  shipmentId      String?
  rating          Int      // 1-5 stars
  onTimeDelivery  Boolean
  goodCondition   Boolean
  goodCommunication Boolean
  wouldRecommend  Boolean
  comment         String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([serviceId, rating])
  @@index([customerId])
  @@index([createdAt])
  @@map("service_ratings")
}

// Driver ratings - Track driver performance
model DriverRating {
  id                String   @id @default(cuid())
  driverId          String
  customerId        String?
  shipmentId        String?
  rating            Int      // 1-5 stars
  professionalism   Int      // 1-5
  communication     Int      // 1-5
  timeliness        Int      // 1-5
  cargoHandling     Int      // 1-5
  comment           String?  @db.Text
  createdAt         DateTime @default(now())

  @@index([driverId, rating])
  @@index([createdAt])
  @@map("driver_ratings")
}

// Route performance - Historical route data
model RoutePerformance {
  id                    String   @id @default(cuid())
  routeId               String
  originLatitude        Float
  originLongitude       Float
  destinationLatitude   Float
  destinationLongitude  Float
  plannedDistance       Float    // km
  actualDistance        Float    // km
  plannedDuration       Int      // minutes
  actualDuration        Int      // minutes
  fuelCost              Float
  tollCost              Float
  trafficDelayMinutes   Int      @default(0)
  weatherConditions     String?  // "clear", "rain", "snow", etc.
  completionStatus      String   // "completed", "delayed", "failed"
  driverId              String?
  vehicleId             String?
  createdAt             DateTime @default(now())

  @@index([routeId])
  @@index([originLatitude, originLongitude])
  @@index([destinationLatitude, destinationLongitude])
  @@index([completionStatus])
  @@index([createdAt])
  @@map("route_performance")
}

// Price history - Track pricing trends
model PriceHistory {
  id              String   @id @default(cuid())
  origin          String
  destination     String
  distance        Float    // km
  weight          Float    // kg
  serviceType     String   // "express", "standard", "economy"
  price           Float    // Actual charged price
  marketPrice     Float?   // Market average price
  discount        Float    @default(0) // Discount percentage
  customerId      String?
  seasonalFactor  Float    @default(1.0) // Seasonal pricing multiplier
  demandLevel     String   @default("normal") // "low", "normal", "high"
  createdAt       DateTime @default(now())

  @@index([origin, destination])
  @@index([serviceType])
  @@index([createdAt])
  @@map("price_history")
}

// Recommendation insights - Cached insights for performance
model RecommendationInsight {
  id                  String   @id @default(cuid())
  customerId          String   @unique
  totalShipments      Int      @default(0)
  totalSpending       Float    @default(0)
  averageShipmentValue Float   @default(0)
  preferredServices   Json     @default("[]") // Array of preferred services
  frequentRoutes      Json     @default("[]") // Array of frequent routes
  shippingPatterns    Json     @default("{}") // Shipping pattern analysis
  costSavings         Float    @default(0)    // Potential savings identified
  nextBestAction      String?  @db.Text       // Recommended next action
  lastCalculated      DateTime @default(now())
  validUntil          DateTime                // Cache expiration

  @@index([customerId])
  @@index([lastCalculated])
  @@map("recommendation_insights")
}

// A/B test results - Test recommendation algorithms
model ABTestResult {
  id                String   @id @default(cuid())
  testName          String
  variantName       String   // "control", "variant_a", "variant_b", etc.
  customerId        String?
  recommendationType String
  shown             Boolean  @default(true)
  clicked           Boolean  @default(false)
  converted         Boolean  @default(false)
  conversionValue   Float?   // Value of conversion (e.g., order amount)
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([testName, variantName])
  @@index([recommendationType])
  @@index([createdAt])
  @@map("ab_test_results")
}

// Similar items cache - Precomputed similarity scores
model SimilarItemsCache {
  id              String   @id @default(cuid())
  itemType        String   // "customer", "shipment", "driver", "vehicle"
  itemId          String
  similarItems    Json     @default("[]") // Array of {id, score, reason}
  algorithmUsed   String   @default("collaborative_filtering")
  lastCalculated  DateTime @default(now())
  validUntil      DateTime

  @@unique([itemType, itemId])
  @@index([itemType, itemId])
  @@index([lastCalculated])
  @@map("similar_items_cache")
}

// Trending data - Popular services, routes, features
model TrendingData {
  id              String   @id @default(cuid())
  category        String   // "service", "route", "feature"
  itemName        String
  itemData        Json     @default("{}")
  popularity      Int      @default(0) // Popularity score
  trendDirection  String   @default("stable") // "rising", "stable", "falling"
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime @default(now())

  @@index([category, popularity])
  @@index([periodStart, periodEnd])
  @@map("trending_data")
}
