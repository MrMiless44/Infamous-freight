// GPS Satellite Tracking Database Schema
// Location tracking, geofencing, routes, and alerts

// Location records - GPS coordinates with metadata
model Location {
  id          String   @id @default(cuid())
  entityType  String   // "vehicle", "driver", "shipment"
  entityId    String   // ID of the tracked entity
  latitude    Float
  longitude   Float
  altitude    Float?   // Meters above sea level
  speed       Float?   // Speed in km/h
  heading     Float?   // Direction in degrees (0-360)
  accuracy    Float?   // GPS accuracy in meters
  source      String   @default("gps") // "gps", "cellular", "wifi", "manual"
  timestamp   DateTime @default(now())
  metadata    Json     @default("{}")

  @@index([entityType, entityId, timestamp])
  @@index([timestamp])
  @@map("locations")
}

// Tracking summary - Current location and aggregated stats
model TrackingSummary {
  id                    String   @id @default(cuid())
  entityType            String   // "vehicle", "driver", "shipment"
  entityId              String   // ID of the tracked entity
  currentLatitude       Float
  currentLongitude      Float
  currentSpeed          Float    @default(0)
  lastUpdated           DateTime @default(now())
  totalDistanceTraveled Float    @default(0) // Total km traveled
  totalUpdates          Int      @default(0) // Total location updates received
  
  @@unique([entityType, entityId])
  @@index([lastUpdated])
  @@map("tracking_summaries")
}

// Geofence zones - Geographic boundaries with alerts
model Geofence {
  id              String   @id @default(cuid())
  name            String
  type            String   // "circle" or "polygon"
  centerLatitude  Float?   // For circle geofences
  centerLongitude Float?   // For circle geofences
  radiusMeters    Int?     // For circle geofences
  polygon         Json     @default("[]") // For polygon geofences [{lat, lng}, ...]
  entityType      String?  // Optional: specific to entity type
  entityId        String?  // Optional: specific to entity ID
  alertOnEnter    Boolean  @default(true)
  alertOnExit     Boolean  @default(true)
  active          Boolean  @default(true)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events GeofenceEvent[]

  @@index([active])
  @@index([entityType, entityId])
  @@map("geofences")
}

// Geofence events - Entry/exit tracking
model GeofenceEvent {
  id          String   @id @default(cuid())
  geofenceId  String
  entityType  String   // "vehicle", "driver", "shipment"
  entityId    String   // ID of the entity that triggered event
  eventType   String   // "enter" or "exit"
  latitude    Float    // Location where event occurred
  longitude   Float
  timestamp   DateTime @default(now())

  geofence Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)

  @@index([geofenceId, timestamp])
  @@index([entityType, entityId, timestamp])
  @@map("geofence_events")
}

// Routes - Planned routes with progress tracking
model Route {
  id                    String    @id @default(cuid())
  shipmentId            String?   // Optional: associated shipment
  vehicleId             String?   // Optional: associated vehicle
  driverId              String?   // Optional: associated driver
  originName            String
  originLatitude        Float
  originLongitude       Float
  destinationName       String
  destinationLatitude   Float
  destinationLongitude  Float
  waypoints             Json      @default("[]") // Array of {lat, lng, name}
  totalDistanceKm       Float?    // Total planned distance
  distanceRemainingKm   Float?    // Current distance remaining
  progressPercent       Float     @default(0) // 0-100
  expectedArrival       DateTime? // Planned arrival time
  estimatedArrival      DateTime? // Current ETA based on speed
  actualArrival         DateTime? // Actual arrival time
  status                String    @default("planned") // "planned", "in_progress", "completed", "cancelled"
  lastUpdated           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  metadata              Json      @default("{}")

  @@index([shipmentId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@map("routes")
}

// Tracking alerts - Notifications for events
model TrackingAlert {
  id              String    @id @default(cuid())
  entityType      String    // "vehicle", "driver", "shipment"
  entityId        String    // ID of the entity
  alertType       String    // "delay", "geofence_entry", "geofence_exit", "approaching_destination", "speed_limit", "offline"
  severity        String    // "info", "low", "medium", "high", "critical"
  message         String
  metadata        Json      @default("{}")
  acknowledged    Boolean   @default(false)
  acknowledgedAt  DateTime?
  acknowledgedBy  String?   // User ID who acknowledged
  createdAt       DateTime  @default(now())

  @@index([entityType, entityId, acknowledged])
  @@index([alertType, acknowledged])
  @@index([severity, acknowledged])
  @@index([createdAt])
  @@map("tracking_alerts")
}

// Vehicle extensions - Add tracking fields to vehicles
model Vehicle {
  id                  String   @id @default(cuid())
  licensePlate        String   @unique
  make                String
  model               String
  year                Int
  vin                 String?  @unique
  gpsDeviceId         String?  @unique // Hardware GPS device ID
  gpsDeviceType       String?  // Device type/model
  currentLatitude     Float?
  currentLongitude    Float?
  lastGpsUpdate       DateTime?
  trackingEnabled     Boolean  @default(true)
  speedLimitKmh       Float?   // Speed limit for alerts
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([gpsDeviceId])
  @@index([trackingEnabled])
  @@map("vehicles")
}

// Driver extensions - Add tracking fields to drivers
model Driver {
  id                  String   @id @default(cuid())
  userId              String   @unique
  name                String
  licenseNumber       String   @unique
  phone               String
  currentLatitude     Float?
  currentLongitude    Float?
  lastGpsUpdate       DateTime?
  trackingEnabled     Boolean  @default(true)
  onDuty              Boolean  @default(false)
  currentVehicleId    String?  // Currently assigned vehicle
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([trackingEnabled])
  @@index([onDuty])
  @@map("drivers")
}

// Shipment extensions - Add tracking fields to shipments
model Shipment {
  id                  String   @id @default(cuid())
  trackingNumber      String   @unique
  status              String
  origin              String
  destination         String
  originLatitude      Float?
  originLongitude     Float?
  destinationLatitude Float?
  destinationLongitude Float?
  currentLatitude     Float?
  currentLongitude    Float?
  lastGpsUpdate       DateTime?
  trackingEnabled     Boolean  @default(true)
  estimatedArrival    DateTime?
  actualArrival       DateTime?
  vehicleId           String?  // Assigned vehicle
  driverId            String?  // Assigned driver
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([trackingNumber])
  @@index([trackingEnabled])
  @@index([status])
  @@map("shipments")
}
