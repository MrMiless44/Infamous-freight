// Logistics Management System Database Schema
// Comprehensive schema for shipment tracking, warehouse operations,
// inventory management, fleet operations, and supply chain analytics

// ==================== SHIPMENT MODELS ====================

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  eventType   String   // created, assigned, picked_up, in_transit, out_for_delivery, delivered, delayed, cancelled
  description String   @db.Text
  location    Json?    // { lat, lng, address }
  timestamp   DateTime @default(now())
  metadata    Json?    // Additional event data

  @@index([shipmentId, timestamp])
  @@index([eventType])
  @@map("shipment_events")
}

// ==================== WAREHOUSE MODELS ====================

model Warehouse {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique // Warehouse code (e.g., "NYC01", "LA02")
  type            String   // distribution_center, fulfillment, storage, cross_dock
  location        Json     // { address, city, state, country, lat, lng }
  totalArea       Float    // Square meters
  storageCapacity Float    // Cubic meters
  status          String   @default("active") // active, inactive, maintenance
  operatingHours  Json?    // { open, close, days }
  contactInfo     Json?    // { phone, email, manager }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([type])
  @@index([status])
  @@map("warehouses")
}

model WarehouseZone {
  id           String   @id @default(cuid())
  warehouseId  String
  name         String   // Zone name (e.g., "A1", "Receiving", "Shipping")
  type         String   // storage, receiving, shipping, staging, returns
  capacity     Float    // Cubic meters
  utilization  Float    @default(0) // Current utilization percentage
  temperature  String?  // ambient, refrigerated, frozen
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([warehouseId, name])
  @@index([warehouseId, type])
  @@map("warehouse_zones")
}

model WarehouseEquipment {
  id              String   @id @default(cuid())
  warehouseId     String
  type            String   // forklift, pallet_jack, conveyor, scanner
  name            String
  serialNumber    String?  @unique
  status          String   @default("operational") // operational, maintenance, out_of_service
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  assignedTo      String?  // Employee ID
  createdAt       DateTime @default(now())

  @@index([warehouseId, status])
  @@index([type])
  @@map("warehouse_equipment")
}

model WarehouseReceiving {
  id          String   @id @default(cuid())
  warehouseId String
  shipmentId  String?
  receivedBy  String   // Employee ID
  receivedAt  DateTime @default(now())
  condition   String   // good, damaged, partial
  notes       String?  @db.Text
  items       Json     // Array of received items
  attachments Json?    // Photos, documents

  @@index([warehouseId, receivedAt])
  @@index([shipmentId])
  @@map("warehouse_receiving")
}

model PickList {
  id          String   @id @default(cuid())
  warehouseId String
  orderId     String
  pickerId    String   // Employee ID
  status      String   // pending, in_progress, completed, cancelled
  priority    String   @default("standard") // low, standard, high, urgent
  items       Json     // Array of items to pick
  route       Json?    // Optimized pick route
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?  @db.Text

  @@index([warehouseId, status])
  @@index([orderId])
  @@index([pickerId])
  @@map("pick_lists")
}

// ==================== INVENTORY MODELS ====================

model Inventory {
  id              String   @id @default(cuid())
  warehouseId     String
  productId       String
  quantity        Int      @default(0)
  location        String   // Zone/bin location
  reorderPoint    Int      @default(10)
  reorderQuantity Int      @default(50)
  unitValue       Float    // Value per unit
  lastRestocked   DateTime?
  lastCounted     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([warehouseId, productId])
  @@index([warehouseId, quantity])
  @@index([productId])
  @@map("inventory")
}

model InventoryMovement {
  id            String   @id @default(cuid())
  warehouseId   String
  productId     String
  movementType  String   // receiving, picking, transfer_in, transfer_out, adjustment
  quantity      Int
  fromLocation  String?
  toLocation    String?
  fromWarehouse String?  // For transfers
  toWarehouse   String?  // For transfers
  reference     String?  // Reference to order, transfer, etc.
  reason        String?
  performedBy   String?  // Employee ID
  timestamp     DateTime @default(now())

  @@index([warehouseId, timestamp])
  @@index([productId, timestamp])
  @@index([movementType])
  @@map("inventory_movements")
}

model InventoryReservation {
  id          String   @id @default(cuid())
  warehouseId String?
  productId   String
  quantity    Int
  orderId     String?
  shipmentId  String?
  reservedBy  String   // User/System ID
  expiresAt   DateTime
  status      String   @default("active") // active, fulfilled, expired, cancelled
  createdAt   DateTime @default(now())

  @@index([productId, status])
  @@index([orderId])
  @@index([shipmentId])
  @@index([expiresAt])
  @@map("inventory_reservations")
}

model InventoryTransfer {
  id              String   @id @default(cuid())
  productId       String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Int
  reason          String   // rebalancing, demand, consolidation
  requestedBy     String   // User ID
  status          String   // pending, in_transit, completed, cancelled
  requestedAt     DateTime @default(now())
  shippedAt       DateTime?
  receivedAt      DateTime?
  trackingNumber  String?
  notes           String?  @db.Text

  @@index([fromWarehouseId, status])
  @@index([toWarehouseId, status])
  @@index([productId])
  @@map("inventory_transfers")
}

model InventoryAdjustment {
  id               String   @id @default(cuid())
  warehouseId      String
  productId        String
  previousQuantity Int
  newQuantity      Int
  difference       Int
  reason           String   // cycle_count, damage, theft, correction
  cycleCountId     String?
  adjustedBy       String   // Employee ID
  adjustedAt       DateTime @default(now())
  notes            String?  @db.Text

  @@index([warehouseId, adjustedAt])
  @@index([productId])
  @@index([reason])
  @@map("inventory_adjustments")
}

model CycleCount {
  id          String   @id @default(cuid())
  warehouseId String
  zone        String?  // Specific zone or null for full count
  countedBy   String   // Employee ID
  countDate   DateTime @default(now())
  status      String   // scheduled, in_progress, completed
  accuracy    Float?   // Calculated accuracy percentage
  notes       String?  @db.Text

  @@index([warehouseId, countDate])
  @@index([status])
  @@map("cycle_counts")
}

// ==================== FLEET MODELS ====================

model VehicleMaintenance {
  id              String   @id @default(cuid())
  vehicleId       String
  maintenanceType String   // routine, repair, inspection, tire_change, oil_change, brake_service
  scheduledDate   DateTime
  completedDate   DateTime?
  description     String   @db.Text
  cost            Float?
  estimatedCost   Float?
  mileage         Int?     // Mileage at time of maintenance
  performedBy     String?  // Mechanic/Shop ID
  priority        String   @default("routine") // routine, high, critical
  status          String   @default("scheduled") // scheduled, in_progress, completed, cancelled
  parts           Json?    // Parts replaced
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([vehicleId, scheduledDate])
  @@index([status])
  @@index([maintenanceType])
  @@map("vehicle_maintenance")
}

model VehicleInspection {
  id            String   @id @default(cuid())
  vehicleId     String
  inspectionType String  // daily, weekly, monthly, annual, dot
  inspectedBy   String   // Inspector ID
  inspectionDate DateTime @default(now())
  overallStatus String   // passed, failed, needs_attention
  brakes        String?  // pass, fail, needs_service
  tires         String?
  lights        String?
  engine        String?
  transmission  String?
  suspension    String?
  emissions     String?
  notes         String?  @db.Text
  defects       Json?    // Array of defects found
  nextInspectionDue DateTime?

  @@index([vehicleId, inspectionDate])
  @@index([overallStatus])
  @@map("vehicle_inspections")
}

model FuelTransaction {
  id           String   @id @default(cuid())
  vehicleId    String
  driverId     String?
  fuelType     String   // diesel, gasoline, electric
  quantity     Float    // Liters or kWh
  cost         Float
  pricePerUnit Float
  location     String?  // Gas station or charging station
  odometer     Int?     // Mileage at refueling
  timestamp    DateTime @default(now())
  paymentMethod String? // card, cash, account
  receiptUrl   String?

  @@index([vehicleId, timestamp])
  @@index([driverId])
  @@map("fuel_transactions")
}

// ==================== PRODUCT MODELS ====================

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?  @db.Text
  category    String?
  weight      Float?   // kg
  dimensions  Json?    // { length, width, height } in cm
  volume      Float?   // Cubic meters
  unitValue   Float?   // Value per unit
  barcode     String?  @unique
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sku])
  @@index([category])
  @@map("products")
}

// ==================== ORDER MODELS ====================

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  status          String   // pending, processing, picked, packed, shipped, delivered, cancelled
  orderDate       DateTime @default(now())
  requiredDate    DateTime?
  shippedDate     DateTime?
  deliveredDate   DateTime?
  warehouseId     String?
  totalAmount     Float
  items           Json     // Array of order items
  shippingAddress Json
  billingAddress  Json?
  notes           String?  @db.Text
  priority        String   @default("standard")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderNumber])
  @@index([customerId, orderDate])
  @@index([status])
  @@index([warehouseId])
  @@map("orders")
}

// ==================== ROUTE MODELS ====================

model RouteTemplate {
  id              String   @id @default(cuid())
  name            String
  originAddress   String
  destinationAddress String
  originLat       Float
  originLng       Float
  destinationLat  Float
  destinationLng  Float
  distance        Float    // km
  estimatedDuration Int    // minutes
  waypoints       Json?    // Array of waypoint coordinates
  avoidTolls      Boolean  @default(false)
  avoidHighways   Boolean  @default(false)
  vehicleType     String?  // Recommended vehicle type
  notes           String?  @db.Text
  usageCount      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([originLat, originLng])
  @@index([destinationLat, destinationLng])
  @@map("route_templates")
}

// ==================== ANALYTICS MODELS ====================

model PerformanceMetric {
  id          String   @id @default(cuid())
  metricType  String   // shipment, warehouse, fleet, inventory
  category    String   // on_time_rate, utilization, accuracy, cost
  value       Float
  target      Float?
  unit        String?  // percentage, hours, dollars
  period      String   // daily, weekly, monthly, quarterly, yearly
  periodStart DateTime
  periodEnd   DateTime
  entityId    String?  // Reference to warehouse, vehicle, etc.
  metadata    Json?
  recordedAt  DateTime @default(now())

  @@index([metricType, category, periodStart])
  @@index([entityId])
  @@map("performance_metrics")
}

model SupplyChainAlert {
  id          String   @id @default(cuid())
  alertType   String   // low_stock, vehicle_maintenance, delay, capacity
  severity    String   // info, warning, critical
  title       String
  description String   @db.Text
  entityType  String?  // warehouse, vehicle, shipment, inventory
  entityId    String?
  status      String   @default("active") // active, acknowledged, resolved
  createdAt   DateTime @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt  DateTime?
  resolvedBy  String?
  actions     Json?    // Recommended actions

  @@index([alertType, severity, status])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("supply_chain_alerts")
}

model LoadConsolidation {
  id              String   @id @default(cuid())
  corridor        String   // Destination corridor identifier
  shipmentIds     Json     // Array of consolidated shipment IDs
  vehicleId       String?
  totalWeight     Float
  totalVolume     Float
  weightUtilization Float
  volumeUtilization Float
  estimatedCost   Float
  estimatedSavings Float
  status          String   @default("planned") // planned, confirmed, completed
  plannedDate     DateTime?
  completedDate   DateTime?
  createdAt       DateTime @default(now())

  @@index([corridor, status])
  @@index([createdAt])
  @@map("load_consolidations")
}

// ==================== EMPLOYEE MODELS ====================

model WarehouseEmployee {
  id          String   @id @default(cuid())
  employeeId  String   @unique
  name        String
  email       String?  @unique
  phone       String?
  role        String   // picker, packer, receiver, supervisor, manager
  warehouseId String
  status      String   @default("active") // active, inactive, on_leave
  certifications Json? // Array of certifications
  hireDate    DateTime
  terminationDate DateTime?
  createdAt   DateTime @default(now())

  @@index([warehouseId, role])
  @@index([status])
  @@map("warehouse_employees")
}
