// Simplified devcontainer for Infamous Freight Enterprises
// Node.js/TypeScript monorepo with API (Express), Web (Next.js), Mobile (Expo)
{
  "name": "Infamous Freight Dev Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  // Essential features only - removed 300+ unnecessary features
  "features": {
    // Core development tools
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    // Database and infrastructure
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},
    // Cloud deployment tools
    "ghcr.io/dhoeric/features/flyctl:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    // AI/ML coding assistant
    "ghcr.io/jsburckhardt/devcontainer-features/codex:1": {},
    // Development utilities
    "ghcr.io/devcontainers-extra/features/pnpm:2": {
      "version": "10.28.2"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "mssql.connections": [
          {
            "server": "localhost,1433",
            "database": "",
            "authenticationType": "SqlLogin",
            "user": "sa",
            "password": "P@ssw0rd",
            "emptyPasswordInput": false,
            "savePassword": false,
            "profileName": "mssql-container"
          }
        ],
        "typescript.tsdk": "node_modules/typescript/lib",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      },
      // Essential extensions for Node.js/TypeScript development
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "Prisma.prisma",
        "ms-playwright.playwright",
        "christian-kohler.path-intellisense",
        "YoavBls.pretty-ts-errors",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "postStartCommand": "bash .devcontainer/postStartCommand.sh",
  // Forward ports for API, Web, and common services
  "forwardPorts": [
    3000,
    3001,
    4000,
    5432,
    6379,
    8080
  ],
  "portsAttributes": {
    "3000": {
      "label": "Web (Next.js)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "API (Docker)",
      "onAutoForward": "notify"
    },
    "4000": {
      "label": "API (Standalone)",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "vscode"
}