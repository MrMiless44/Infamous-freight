model Dispute {
  id            String   @id @default(uuid())
  userId        String
  transactionId String
  processor     String
  status        String
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model EnforcementAction {
  id        String   @id @default(uuid())
  userId    String
  level     String
  reason    String
  createdAt DateTime @default(now())
}

model RiskScore {
  id        String   @id @default(uuid())
  userId    String
  score     Float
  factors   Json
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([actor, createdAt])
  @@index([action])
  @@index([createdAt])
}
