{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API (Node)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "api", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Launch Web (Next.js)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter web dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Launch Mobile (Expo)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter mobile dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Current Jest File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "exec",
        "jest",
        "${fileBasenameNoExtension}",
        "--runInBand"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Launch Web + API",
      "configurations": ["Launch API (Node)", "Launch Web (Next.js)"]
    }
  ]
}
